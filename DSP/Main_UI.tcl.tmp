proc vTclWindow.top1 {base} {
    global vTcl
    if {$base == ""} {
        set base .top1
    }
    if {[winfo exists $base]} {
        wm deiconify $base; return
    }
    set top $base
    set target $base

############ toplevel.wgt #############################
    ###################
    # CREATING WIDGETS
    ###################
    vTcl::widgets::core::toplevel::createCmd $top -class Toplevel \
        -borderwidth 0 -relief flat -background #dcdad5 -container 0 \
        -height 0 -highlightbackground #dcdad5 -highlightcolor black \
        -highlightthickness 0 -padx 0 -pady 0 -takefocus 0 -width 0 
    wm focusmodel $top passive
    wm geometry $top 880x687+566+152
    update
    # set in toplevel.wgt.
    global vTcl
    global img_list
    set vTcl(save,dflt,origin) 0
    wm maxsize $top 1924 1061
    wm minsize $top 120 1
    wm overrideredirect $top 0
    wm resizable $top 1 1
    wm deiconify $top
    set toptitle "Toplevel 0"
    wm title $top $toptitle
    namespace eval ::widgets::${top}::ClassOption {}
    set ::widgets::${top}::ClassOption(-toptitle) $toptitle
    vTcl:DefineAlias "$top" "Toplevel1" vTcl:Toplevel:WidgetProc "" 1
    set vTcl(real_top) {}
    entry "$top.ent50" \
        -background #d9d9d9 -borderwidth 1 -cursor fleur \
        -disabledbackground SystemButtonFace -disabledforeground #a5a4a0 \
        -exportselection 0 -font "TkFixedFont" -foreground black \
        -highlightbackground #dcdad5 -highlightcolor black \
        -highlightthickness 0 -insertbackground black -insertborderwidth 0 \
        -insertofftime 300 -insertontime 600 -insertwidth 2 -justify left \
        -readonlybackground SystemButtonFace -relief sunken \
        -selectbackground #d9d9d9 -selectborderwidth 0 \
        -selectforeground black -state normal -validate none -width 114 
    vTcl:DefineAlias "$top.ent50" "Entry1" vTcl:WidgetProc "Toplevel1" 1
    button "$top.but49" \
        -activebackground #d9d9d9 -activeforeground black -anchor center \
        -background #dcdad5 -borderwidth 2 -compound left -default disabled \
        -disabledforeground #a5a4a0 -font "TkDefaultFont" -foreground black \
        -height 0 -highlightbackground #dcdad5 -highlightcolor black \
        -highlightthickness 1 -justify center -padx 1 -pady 1 -relief raised \
        -repeatdelay 0 -repeatinterval 0 -state normal -text "Button" \
        -underline -1 -width 0 -wraplength 0 
    vTcl:DefineAlias "$top.but49" "Button1" vTcl:WidgetProc "Toplevel1" 1
    frame "$top.fra51" \
        -borderwidth 2 -relief groove -background #dcdad5 -container 0 \
        -height 75 -highlightbackground #dcdad5 -highlightcolor black \
        -highlightthickness 0 -padx 0 -pady 0 -takefocus 0 -width 125 
    vTcl:DefineAlias "$top.fra51" "Frame1" vTcl:WidgetProc "Toplevel1" 1
    ###################
    # SETTING GEOMETRY
    ###################
# add p1 basename = $top.ent50
    place $top.ent50 \
        -in $top -x 0 -relx 0.25 -y 0 -rely 0.073 -width 114 -relwidth 0 \
        -height 17 -relheight 0 -anchor nw -bordermode ignore 
# add p1 basename = $top.but49
    place $top.but49 \
        -in $top -x 0 -relx 0.284 -y 0 -rely 0.131 -width 48 -relwidth 0 \
        -height 26 -relheight 0 -anchor nw -bordermode ignore 
# add p1 basename = $top.fra51
    place $top.fra51 \
        -in $top -x 0 -relx 0.057 -y 0 -rely 0.058 -width 0 -relwidth 0.142 \
        -height 0 -relheight 0.109 -anchor nw -bordermode ignore 

############# Spot ttt ##############################

    vTcl:FireEvent $base <<Ready>>
}

proc 36 {args} {return 1}


Window show .
set btop1 ""
if {$vTcl(borrow)} {
    set btop1 .bor[expr int([expr rand() * 100])]
    while {[lsearch $btop1 $vTcl(tops)] != -1} {
        set btop1 .bor[expr int([expr rand() * 100])]
    }
}
set vTcl(btop) $btop1
Window show .top1 $btop1
if {$vTcl(borrow)} {
    $btop1 configure -background plum
}

