#include <stdio.h>
#include <stdint.h>
#include <system.h>
#include <unistd.h>

#define LED_REG (*(volatile uint32_t*)PIO_LED_BASE)
#define ms		1000

int main()
{
	int i = 0;
    while(1)
    {
    	if(i<0xFF){
    		LED_REG = (uint32_t)i++;
    	}
    	else{
    		i = 0;
    	}
    	usleep(100*ms);
    }
    return 0;
}
