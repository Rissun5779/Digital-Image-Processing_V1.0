#include <stdio.h>
#include <stdint.h>
#include <system.h>
#include <unistd.h>
// Memory Map
#define LED_REG  (*(volatile uint32_t*)PIO_LED_BASE)
#define HEX0_REG (*(volatile uint32_t*)PIO_HEX_0_BASE)
#define HEX1_REG (*(volatile uint32_t*)PIO_HEX_1_BASE)
#define HEX2_REG (*(volatile uint32_t*)PIO_HEX_2_BASE)
#define HEX3_REG (*(volatile uint32_t*)PIO_HEX_3_BASE)
// Timer
#define SYS_CLK_TIMER_FREQ SYS_CLK_TIMER_FREQ

// VAR
#define ms		 		   1000

/****************
HEX_TBL(A-F)=>
   A: 000_1000
   B: 000_0011
   C: 100_0110
   D: 010_0001
   E: 000_0110
   F: 000_1110
 *****************/
unsigned char HEX_TBL[16]={
  0XC0, 0XF9, 0XA4, 0XB0, 0X99,
  0X92, 0X82, 0XF8, 0X80, 0X90,
  0x08, 0x03, 0x46, 0x21, 0x06,
  0x0e
};

/*****************
 * Timer Reg Map
 * ------------------
 * 0 | status   | 	      	  1     0
 * 				  	   	 	 run   to
 * 1 | control  | 3     2     1     0
 * 				 stop start cont  ito
 * 2 | periodl  | 15..0
 * 3 | periodh  | 31..16
 * 4 | snapl    | 15..0
 * 5 | snaph    | 31..16
 *
 *****************/

int main()
{
	int i = 0;
	// Set timer for 1 second
	IOWR(SYS_CLK_TIMER_BASE, 2, (short)(SYS_CLK_TIMER_FREQ & 0x0000FFFF));
	IOWR(SYS_CLK_TIMER_BASE, 3, (short)(SYS_CLK_TIMER_FREQ & 0xFFFF0000));
	// Set timer running
	IOWR(SYS_CLK_TIMER_BASE, 1, 0x04);
	while(1)
    {
    	if(i<=0xFF){
    		LED_REG  = (uint32_t)i;
    		HEX0_REG = HEX_TBL[i%10];
    		HEX1_REG = HEX_TBL[(i%100)/10];
    		HEX2_REG = HEX_TBL[(i%1000)/100];
    		HEX3_REG = HEX_TBL[(i%1000)/1000];
    	}
    	else{
    		i = 0;
    	}
    	usleep(100*ms);
    	i++;
    }
    return 0;
}
