proc ::nf_xcvr_native::parameters::20nm1_getValue_cdr_pll_loopback_mode { device_revision cdr_pll_prot_mode cdr_pll_tx_pll_prot_mode pma_rx_buf_diag_lp_en pma_rx_buf_prot_mode pma_rx_buf_refclk_en pma_tx_buf_enable_idle_tx_channel_support } {

   set legal_values [list "loopback_disabled" "loopback_received_data" "loopback_recovered_data"]

   if [expr { (($pma_rx_buf_refclk_en=="disable")&&($pma_rx_buf_prot_mode=="unused")) }] {
      set legal_values [intersect $legal_values [list "loopback_disabled" "loopback_recovered_data"]]
   } else {
      if [expr { ($pma_rx_buf_refclk_en=="enable") }] {
         set legal_values [intersect $legal_values [list "rx_refclk" "rx_refclk_cdr_loopback"]]
      }
   }
   if [expr { ($pma_tx_buf_enable_idle_tx_channel_support=="true") }] {
      if [expr { ($pma_rx_buf_refclk_en=="enable") }] {
         set legal_values [intersect $legal_values [list "rx_refclk_cdr_loopback"]]
      } else {
         set legal_values [intersect $legal_values [list "loopback_recovered_data"]]
      }
   } else {
      if [expr { ((($pma_rx_buf_refclk_en=="enable")&&($cdr_pll_prot_mode=="unused"))&&($cdr_pll_tx_pll_prot_mode=="txpll_unused")) }] {
         set legal_values [intersect $legal_values [list "rx_refclk"]]
      } else {
         if [expr { ((($pma_rx_buf_refclk_en=="disable")&&($cdr_pll_prot_mode=="unused"))&&($cdr_pll_tx_pll_prot_mode=="txpll_unused")) }] {
            set legal_values [intersect $legal_values [list "loopback_disabled"]]
         } else {
            if [expr { ($pma_rx_buf_refclk_en=="enable") }] {
               set legal_values [intersect $legal_values [list "rx_refclk"]]
            }
         }
      }
   }
   if [expr { ($pma_rx_buf_diag_lp_en=="dlp_off") }] {
      set legal_values [intersect $legal_values [list "loopback_recovered_data" "loopback_disabled" "unused2"]]
   } else {
      if [expr { ($pma_rx_buf_diag_lp_en=="dlp_on") }] {
         set legal_values [intersect $legal_values [list "loopback_received_data" "rx_refclk" "rx_refclk_cdr_loopback" "unused1"]]
      }
   }
   if [expr { (($cdr_pll_prot_mode=="unused")&&($cdr_pll_tx_pll_prot_mode=="txpll_unused")) }] {
      set legal_values [intersect $legal_values [list "loopback_disabled" "rx_refclk" "rx_refclk_cdr_loopback"]]
   }

   return $legal_values
}


