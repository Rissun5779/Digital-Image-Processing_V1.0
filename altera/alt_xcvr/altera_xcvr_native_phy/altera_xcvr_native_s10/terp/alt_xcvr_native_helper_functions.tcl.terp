    if {\$native_debug == 1} {
      post_message -type info "IP SDC: After getting RX digital release_aib_first resync node info: [dict get \$native_pins rx_digital_release_aib_first_resync]"
    }

    dict set native_pins rx_digital_release_aib_first_resync [join [lsort -dictionary [dict get \$native_pins rx_digital_release_aib_first_resync]]]

  } else {
    if {\$native_debug == 1} {
      post_message -type info "IP SDC: Could not find registers for RX digital release_aib_first synchronizers"
    }
  }

}

# -------------------------------------------------------------------------- #
# ---                                                                    --- #
# --- Procedure to create clocks for all channels in an instance         --- #
# ---                                                                    --- #
# -------------------------------------------------------------------------- #
proc native_create_clocks_all_ch_${random_str} { instance clk_group channel_number freq clk_list profile_cnt profile} {
  global ::native_debug

  set clock_name_list [list]

  foreach clk \$clk_list {

    # Shorten the clock name if multiple profiles are not used
    if { \$profile_cnt > 1 } { 
      set clock_name \$instance\|profile\$profile\|\$clk_group\|ch\$channel_number
    } else {
      set clock_name \$instance\|\$clk_group\|ch\$channel_number      
    }
    # Add the clock name to the list 
    lappend clock_name_list \$clock_name
    
    if { \$native_debug == 1 } {
      post_message -type info "IP SDC: Clock name = \$clock_name"
    }

    create_clock \\
      -name \$clock_name \\
      -period "\$freq MHz" \\
      \$clk -add

    incr channel_number

  }

  # Return the list of clock names  
  return \$clock_name_list

}


