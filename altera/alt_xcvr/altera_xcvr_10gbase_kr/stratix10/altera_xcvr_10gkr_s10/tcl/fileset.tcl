# This proc will return new string name -depending upon GUI params
proc ::altera_xcvr_10gkr_s10::fileset::get_replacement_string {string_to_be_replaced} {

  set ref_clk_10g [get_parameter_value REF_CLK_FREQ_10G]
  set ini_dpath   [get_parameter_value INI_DATAPATH]
  set synth_1588  [expr [get_parameter_value SYNTH_1588_ALL] == 1] 
  set synth_fec   [expr [get_parameter_value SYNTH_FEC] == 1]
  set synth_lt    [expr [get_parameter_value SYNTH_LT ] == 1]
  set synth_an    [expr [get_parameter_value SYNTH_AN ] == 1]
  set debug_cpu   [expr [get_parameter_value USE_DEBUG_CPU] == 1]
  set ecc_cpu     [expr [get_parameter_value USE_ECC_CPU] == 1]
  set hard_prbs   [get_parameter_value HARD_PRBS_ENABLE]
  set es_device   [get_parameter_value ES_DEVICE]

  # FOR CPU TYPE
   if { [expr  $debug_cpu & !$ecc_cpu] } {
     set cpu_name kr_dbg_cpu_s10
   } elseif { [expr  $debug_cpu &  $ecc_cpu] } {   
     set cpu_name kr_dbg_cpu_s10_ecc
   } elseif { [expr  !$debug_cpu &  $ecc_cpu] } {   
     set cpu_name kr_cpu_s10_ecc
   } else {
     set cpu_name kr_cpu_s10
   }	   
  # FOR RECONFIG DATA
  set native_package_name native_xcvr_s10kr
  # return string here
  if {$string_to_be_replaced == "cpu_module_instance"} {
   return $cpu_name
  } elseif {$string_to_be_replaced == "s10_kr_reconfig_profiles"} {
   return $native_package_name
  } elseif {$string_to_be_replaced == "native_phy_xcvr"} {
   set autogeneratedfixedname [get_instance_property native_phy_xcvr HDLINSTANCE_GET_GENERATED_NAME]	  
   return $autogeneratedfixedname
  }	  
}	
# Generate dynamic files here 
# Input1 --> take in fileset array; 
# Input2 --> hash - (top file has qsys_unique_name; other files only have hash in name
proc ::altera_xcvr_10gkr_s10::fileset::generate_dynamic_fileset {qsys_output_name list_of_unique_files} {

 # set path to terp file(s)
 set path [::alt_xcvr::utils::fileset::get_alt_xcvr_path]
 set path "${path}/altera_xcvr_10gbase_kr/stratix10/altera_xcvr_10gkr_s10/terp/"
 set path [::alt_xcvr::utils::fileset::abs_to_rel_path $path]

 # split the qsys_output_name to extract the ip_module_name, ip_component_name and random str 
 set elements [::alt_xcvr::utils::common::wsplit $qsys_output_name "_altera_xcvr_10gkr_s10_"] 
 
 set ip_name [lindex $elements 0]
 set release_number [lindex [split [lindex $elements 1] "_"] 0]
 set ip_component_name altera_xcvr_10gkr_s10_${release_number} 
 set random_str [lindex [split [lindex $elements 1] "_"] end]

 # Get IP Params 
 set synth_fec   [expr [get_parameter_value SYNTH_FEC] == 1]

 # For now only consider first - eventually need to do foreach for mutliple files
 set file [lindex  $list_of_unique_files 0]
 foreach file $list_of_unique_files {
     # read the template
     set filename ${path}/${file} 
     set file_handle [open ${filename} r] 
     set template [read $file_handle]
     set template_params(module_name) ${qsys_output_name}
     set template_params(random_str) ${random_str}
     set template_params(cpu_module_instance) [get_replacement_string cpu_module_instance]
     set template_params(s10_kr_reconfig_profiles)       [get_replacement_string s10_kr_reconfig_profiles]
     set template_params(native_phy_xcvr)       [get_replacement_string native_phy_xcvr]
     if {$synth_fec} {     
        set template_params(synth_fec) true
     } else {
        set template_params(synth_fec) false
     }	     
     set contents [altera_terp $template template_params]
     # filename = qsys-name for top file
     # filename = name_random for other files
     if {$file eq "altera_xcvr_10gkr_s10.sv.terp"} {
       set output_filename ${qsys_output_name}.sv
     } else {
       set elements [::alt_xcvr::utils::common::wsplit $file ".sv.terp"] 
       set output_filename [lindex $elements 0]_${random_str}.sv
     }	     
     add_fileset_file "./${output_filename}" SYSTEM_VERILOG TEXT $contents
  }     
}



proc ::altera_xcvr_10gkr_s10::fileset::callback_quartus_synth {name} {
  # Get IP Params 
  set synth_rcfg  [expr [get_parameter_value SYNTH_RCFG] == 1]
  callback_optional_files
  common_add_fileset_files {ALTERA_XCVR_10GBASE_KR} {PLAIN QIP QENCRYPT}
  # generate dynamic files
  set list_of_unique_files []
  lappend list_of_unique_files altera_xcvr_10gkr_s10.sv.terp
  lappend list_of_unique_files ultra_chnl.sv.terp
  if {$synth_rcfg} {  
    lappend list_of_unique_files rcfg_top.sv.terp
    lappend list_of_unique_files rcfg_data.sv.terp
  }
  generate_dynamic_fileset $name $list_of_unique_files 
  
}

