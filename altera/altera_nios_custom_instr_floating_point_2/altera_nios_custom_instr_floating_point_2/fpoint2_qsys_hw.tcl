proc compose {} { 
    array set fpci2_arith {	
        fabss   s1.0	
        fnegs   s1.1
        round   s2.0
        fmuls   s2.4
        fadds   s2.5
        fsubs   s2.6
        fdivs   s2.7
    }
    array set fpci2_root {	
        fsqrts  s2.3
    }
    array set fpci2_convert {	
        fixsi   s2.1	
        floatis s2.2
    }
    array set fpci2_compare {	
        fcmpnes s1.2
        fcmpeqs s1.3       
        fcmpges s1.4
        fcmpgts s1.5
        fcmples s1.6
        fcmplts s1.7
        fmaxs   s1.8
        fmins   s1.9
    }

    set arithmetic_present [ get_parameter_value arithmetic_present ]
    set root_present       [ get_parameter_value root_present       ]
    set conversion_present [ get_parameter_value conversion_present ]
    set comparison_present [ get_parameter_value comparison_present ]
    set deviceFamily 	   [ get_parameter_value deviceFamily ]

	# Validate prohibited device
    set prohibited_device { "MAX II" "MAX V" }
    foreach prohibited $prohibited_device {
        if { $prohibited == $deviceFamily } {
          send_message error "Selected device family does not support this module."
        }	      
    }

    # +-----------------------------------
    # | submodule instantiation        
    # |  
    add_instance fpci_combi altera_nios_custom_instr_floating_point_2_combi 
    add_instance fpci_multi altera_nios_custom_instr_floating_point_2_multi

    set_instance_parameter_value fpci_combi arithmetic_present $arithmetic_present
    set_instance_parameter_value fpci_combi comparison_present $comparison_present

    set_instance_parameter_value fpci_multi arithmetic_present $arithmetic_present
    set_instance_parameter_value fpci_multi root_present $root_present
    set_instance_parameter_value fpci_multi conversion_present $conversion_present
    # | 
    # +-----------------------------------  

    # +-----------------------------------
    # | submodule interface connections
    # |                     
    add_interface s1 nios_custom_instruction end
    add_interface s2 nios_custom_instruction end
    
    set_interface_property s1 EXPORT_OF fpci_combi.s1
    set_interface_property s2 EXPORT_OF fpci_multi.s1
    
    if {$arithmetic_present} {
    	foreach function [array names fpci2_arith] {
    	    set strs [split $fpci2_arith($function) .]
    	    set_interface_assignment [lindex $strs 0] "embeddedsw.customInstruction.[lindex $strs 0].[lindex $strs 1]"  true
    	}
    }
    
    if {$root_present} {
        if { [ string match "MAX*10*" "$deviceFamily" ] } {
    	    send_message warning "Root function requires ram initialization"
    	}
    	foreach function [array names fpci2_root] {
    	    set strs [split $fpci2_root($function) .]
    	    set_interface_assignment [lindex $strs 0] "embeddedsw.customInstruction.[lindex $strs 0].[lindex $strs 1]"  true
    	}
    }
    
    if {$conversion_present} {
    	foreach function [array names fpci2_convert] {
    	    set strs [split $fpci2_convert($function) .]
    	    set_interface_assignment [lindex $strs 0] "embeddedsw.customInstruction.[lindex $strs 0].[lindex $strs 1]"  true
    	}
    }
    
    if {$comparison_present} {
    	foreach function [array names fpci2_compare] {
    	    set strs [split $fpci2_compare($function) .]
    	    set_interface_assignment [lindex $strs 0] "embeddedsw.customInstruction.[lindex $strs 0].[lindex $strs 1]"  true
    	    set_interface_assignment [lindex $strs 0] "embeddedsw.test.customInstruction.[lindex $strs 0].[lindex $strs 1]"  true
    	}
    }
    
    # | 
    # +-----------------------------------                   

}

