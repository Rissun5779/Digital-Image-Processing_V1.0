# +-----------------------------------
# | elaboration callback 
# | 
# | 
# +-----------------------------------
proc elaboration_callback {} {
    set supported_families [list "Stratix V" "Arria V" "Cyclone V" "Arria V GZ" "Arria 10"]
	set current_family [get_parameter_value device_family]
	if {[lsearch $supported_families $current_family] == -1} {
		send_message error "The selected device family is not supported. Please select $supported_families."
	}

    set usr_mif_enabled [get_parameter_value ENABLE_MIF]

    set mif_supported_families [list "Stratix V" "Arria V" "Cyclone V" "Arria V GZ" "Arria 10"]
    if {[lsearch $mif_supported_families $current_family] == -1} {
        set is_mif_supported 0
    } else {
        set is_mif_supported 1
    }

    set mif_enabled [expr { $usr_mif_enabled && $is_mif_supported }]

    set_parameter_property ENABLE_MIF ENABLED $is_mif_supported
    set_parameter_property MIF_FILE_NAME ENABLED $mif_enabled

    #Set WAIT_FOR_LOCK to false if the ini is there. 
    set ini_value [get_quartus_ini permit_nf_pll_reconfig_out_of_lock STRING]
    if {$ini_value == "" || $current_family != "Arria 10"} {
       set_parameter_value WAIT_FOR_LOCK true
    } elseif {[regexp -nocase {^[\t\r\n ]*yes[\t\r\n ]*$|^[\t\r\n ]*on[\t\r\n ]*$|^[\t\r\n ]*1[\t\r\n ]*$} $ini_value match] == 1} {
       set_parameter_value WAIT_FOR_LOCK false
       send_message warning "Reconfiguration with the PLL out of lock has been enabled using the ini 'permit_nf_pll_reconfig_out_of_lock'. The PLL must be reset immediately after reconfiguration."
    } else {
        set_parameter_value WAIT_FOR_LOCK true
    }

    #declare constants for widths
    if {$current_family == "Arria 10"} {
        set w_rd 32
        set w_wd 32
        set w_add 9
        set reconf_width_val 64
    } else {
        set w_rd 32
        set w_wd 32
        set w_add 6
        set reconf_width_val 64
    }

    add_interface_port mgmt_avalon_slave mgmt_readdata readdata output $w_rd
    add_interface_port mgmt_avalon_slave mgmt_address address input $w_add
    add_interface_port mgmt_avalon_slave mgmt_writedata writedata input $w_wd
    add_interface_port reconfig_to_pll reconfig_to_pll reconfig_to_pll output $reconf_width_val
    add_interface_port reconfig_from_pll reconfig_from_pll reconfig_from_pll input $reconf_width_val
	
    # Set Bus width values
    set_parameter_value RECONFIG_ADDR_WIDTH $w_add
    set_parameter_value RECONFIG_DATA_WIDTH $w_wd
    set_parameter_value reconf_width $reconf_width_val

	
	# Conditionally add byteenable port
	set byte_enable [get_parameter_value ENABLE_BYTEENABLE]
	set reconfig_width [get_parameter_value RECONFIG_DATA_WIDTH]
	set reconfig_width_bytes [expr $reconfig_width/8]
    set_parameter_value BYTEENABLE_WIDTH $reconfig_width_bytes
	
	add_interface_port mgmt_avalon_slave mgmt_byteenable byteenable input $reconfig_width_bytes
	if {$byte_enable} {
		send_message info "Byteenable is intended to permit writes to altera_pll_reconfig from a peripheral of greater data bus width. Writes are only permitted to all bytes."
	} else {
		#the following line ensures that mgmt_byteenable will NOT be a port on the top level module, but will be one on the altera_pll_reconfig that it instantiates. 
		set_port_property mgmt_byteenable TERMINATION true
	}


}


