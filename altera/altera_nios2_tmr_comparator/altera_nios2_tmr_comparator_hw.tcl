            add_interface_port     $INTF_NAME$suffix      "dtcm${i}_writedata${suffix}"         "writedata"         "input"    $local_dtcm_data_width
            add_interface_port     $INTF_NAME$suffix      "dtcm${i}_byteenable${suffix}"        "byteenable"        "input"    4

            if { $dtcm_ecc_present } {
                set_interface_property  $INTF_NAME$suffix      "bitsPerSymbol"     "39"
                set_interface_property  $INTF_NAME$suffix      "addressUnits"     "WORDS"
                set_port_property "dtcm${i}_byteenable$suffix" TERMINATION true
            } else {
                set_interface_property $INTF_NAME$suffix bitsPerSymbol 8
                set_interface_property $INTF_NAME$suffix addressUnits SYMBOLS
            }
            set_port_property "dtcm${i}_response${suffix}" TERMINATION [ expr !$response_present ]

            set_interface_property $INTF_NAME$suffix ENABLED [ expr $dtcm_num > $i ]
        }
        set_interface_property $INTF_NAME ENABLED [ expr $dtcm_num > $i ]
        
    }
    
    
}

