set itcm_ecc_present [ get_parameter_value itcm_ecc_present ]
set itcm_num [ get_parameter_value itcm_num ]

if { $itcm_ecc_present } {
    set local_itcm_data_width 39
} else {
    set local_itcm_data_width 32
}

set_parameter_value TCIM_MASTER_DATA_WIDTH $local_itcm_data_width
   
foreach i {0 1 2 3} {
    set INTF_NAME "tightly_coupled_instruction_master_${i}"
    set TCI_NAME  "TCIM_MASTER_ADDRESS_WIDTH${i}"
    
    if { $i < 4 } {
        set local_itcm_width [ get_parameter_value ${TCI_NAME} ]
        add_interface           $INTF_NAME      "avalon"                    "master"             clock
        add_interface_port      $INTF_NAME      "itcm${i}_readdata"          "readdata"          "input"     $local_itcm_data_width
        add_interface_port      $INTF_NAME      "itcm${i}_response"          "response"          "input"     2
        add_interface_port      $INTF_NAME      "itcm${i}_address"           "address"           "output"    $local_itcm_width
        add_interface_port      $INTF_NAME      "itcm${i}_read"              "read"              "output"    1
        add_interface_port      $INTF_NAME      "itcm${i}_clken"             "clken"             "output"    1
        add_interface_port      $INTF_NAME      "itcm${i}_writedata"     "writedata"         "output"    $local_itcm_data_width
        add_interface_port      $INTF_NAME      "itcm${i}_write"         "write"             "output"    1
            
        set_interface_property  $INTF_NAME      "addressGroup"              "1"
        set_interface_property  $INTF_NAME      "registerIncomingSignals"   "false"
        set_interface_property  $INTF_NAME      "ENABLED"                   "true"
        set_interface_property  $INTF_NAME      "associatedReset"           "reset"
        set_interface_property  $INTF_NAME      readLatency 1
        set_interface_property  $INTF_NAME      readWaitTime 0
        set_interface_property  $INTF_NAME      writeWaitTime 0

        # When ECC enabled, allow write ports for recoverable ECC error
        if { $itcm_ecc_present } {   
            set_interface_property  $INTF_NAME      "bitsPerSymbol"     "39"
            set_interface_property  $INTF_NAME      "addressUnits"     "WORDS"
        } else {
            set_port_property "itcm${i}_writedata" TERMINATION true
            set_port_property "itcm${i}_write" TERMINATION true
        }
        set_port_property "itcm${i}_response" TERMINATION [ expr !$response_present ]

        foreach suffix { "_a" "_b" "_c" } {
            add_interface $INTF_NAME$suffix avalon end
            set_interface_property $INTF_NAME$suffix associatedClock clock
            set_interface_property $INTF_NAME$suffix associatedReset reset           
            set_interface_property $INTF_NAME$suffix maximumPendingReadTransactions 0
            set_interface_property $INTF_NAME$suffix maximumPendingWriteTransactions 0
            set_interface_property $INTF_NAME$suffix readLatency 1
            set_interface_property $INTF_NAME$suffix readWaitTime 0
            set_interface_property $INTF_NAME$suffix setupTime 0
            set_interface_property $INTF_NAME$suffix timingUnits Cycles
            set_interface_property $INTF_NAME$suffix writeWaitTime 0
            set_interface_property $INTF_NAME$suffix bridgesToMaster $INTF_NAME
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_readdata${suffix}"          "readdata"          "output"     $local_itcm_data_width
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_response${suffix}"          "response"          "output"     2
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_address${suffix}"           "address"           "input"    $local_itcm_width
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_read${suffix}"              "read"              "input"    1
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_clken${suffix}"             "clken"             "input"    1
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_writedata${suffix}"     "writedata"         "input"    $local_itcm_data_width
            add_interface_port      $INTF_NAME$suffix      "itcm${i}_write${suffix}"         "write"             "input"    1
                
            # When ECC enabled, allow write ports for recoverable ECC error
            if { $itcm_ecc_present } {
                set_interface_property  $INTF_NAME$suffix      "bitsPerSymbol"     "39"
                set_interface_property  $INTF_NAME$suffix      "addressUnits"     "WORDS"
            } else {
                set_port_property "itcm${i}_writedata${suffix}" TERMINATION true
                set_port_property "itcm${i}_write${suffix}" TERMINATION true
                set_interface_property $INTF_NAME$suffix bitsPerSymbol 8
                set_interface_property $INTF_NAME$suffix addressUnits SYMBOLS
            }
            set_interface_property $INTF_NAME$suffix ENABLED [ expr $itcm_num > $i ]
            set_port_property "itcm${i}_response${suffix}" TERMINATION [ expr !$response_present ]
        }
        set_interface_property $INTF_NAME ENABLED [ expr $itcm_num > $i ]
    }   
}

