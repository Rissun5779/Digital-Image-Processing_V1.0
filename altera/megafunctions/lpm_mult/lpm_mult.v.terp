@@ #-----------------------------------------------------------------------------------
@@ #
@@ # Name: lpm_mult.v.terp
@@ # 
@@ # Purpose: transfer all parameters from hw.tcl file to verilog file
@@ #
@@ # Usage: IP core independent, general verilog format output for lpm ip cores, do not change.
@@ #        use ip specific tcl file to do ip dependent params transfer.
@@ #
@@ #--------------------------------------------------------------------------------------
@@
// synopsys translate_off
`timescale 1 ps / 1 ps
// synopsys translate_on
module  ${output_name}  (
@@
@@  #----- write module port list -----#
@@  set delim ","
@@  set port_last [lindex $module_port_list end-3]
@@  foreach {port direction width wdithL} $module_port_list {
@@      if {$port eq $port_last} {
@@          set delim ");"
@@      }
@@
            $port$delim
@@
@@  }
@@

@@
@@  #----- write input and output port lists -----#
@@  foreach {port direction width widthL} $module_port_list {
@@      set dir_string ""
@@      set width_string ""
@@
@@      if {$direction eq "IN"} {
@@          set dir_string "input"
@@      } elseif {$direction eq "OUT"} {
@@          set dir_string "output"
@@      }
@@
@@      if {$width != -1} {
@@          set width_string "\[[expr {$width+$widthL-1}]:$widthL\]"
@@      }
@@
            $dir_string $width_string $port;
@@
@@  }
@@

@@
@@  #----- write output ports wire connections -----#
@@  foreach {name width widthL constant} $sub_wire_list {
@@      set width_string ""
@@      set const_string ""
@@
@@      if {$width != -1} {
@@          set width_string "\[[expr {$width+$widthL-1}]:$widthL\]"
@@      }
@@
@@      if {$constant ne ""} {
@@          set const_string " = $constant"
@@      }
@@
@@
            wire $width_string $name$const_string;
@@
@@  }
@@
@@  foreach {dest src width widthL} $wire_list {
@@      set width_string ""
@@
@@      if {$width != -1} {
@@          set width_string "\[[expr {$width+$widthL-1}]:$widthL\]"
@@      }
@@
            wire $width_string $dest = $src$width_string;    
@@
@@  }
@@

@@
@@  #----- write component information -----#
@@
            $ip_name        ${ip_name}_component (
@@
@@  #----- write component port list ------#
@@  set comp_ports [list]
@@
@@  foreach {port connect direction width widthL} $port_map_list {
@@      lappend comp_ports $port $connect
@@  }
@@
@@  foreach {port connect} $ports_not_added_list {
@@      lappend comp_ports $port $connect
@@  }
@@
@@  set delim ","
@@  set port_last [lindex $comp_ports end-1]
@@  foreach {port connect} $comp_ports {
@@      if {$port eq $port_last} {
@@          set delim ");"
@@      }
@@
                                        .$port ($connect)$delim
@@
@@  }
@@
@@  #----- write component parameters -----#
@@
            defparam
@@
@@  set delim ","
@@  set name_last [lindex $params_list end-2]
@@  foreach {name str value} $params_list {
@@      
@@      if {$str eq "STRING"} {
@@          set value "\"$value\""
@@      }
@@
@@      if {$name eq $name_last} {
@@          set delim ";"
@@      }
@@
                    ${ip_name}_component.$name = $value$delim
@@
@@  }
@@


endmodule

