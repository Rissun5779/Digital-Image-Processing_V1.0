         set_false_path -from [get_keepers {*inst_phy|altera_jesd204_*x_mlpcs:inst_*x_mlpcs|*x_pcs_inst|*pcfifo|o_fifo_full}] -to [get_keepers {*|altera_jesd204_*x_base:inst_*x|altera_jesd204_*x_csr:altera_jesd204_*x_csr_inst|phy_csr_*x_pcfifo_full*}]
         #TimeQuest constraints to constrain the timing across asynchronous clock domain crossings.
         #The idea is to minimize skew to less than one clock period to keep the gray encoding, 
         #and to minimize latency on the pointer crossing. Refer to case:206467 for details
         set pcfifo_gray_wr_ptr [get_keepers {*|altera_jesd204_pcfifo:pcfifo|*dcfifo|gray_wr_ptr[*]*}]
         set pcfifo_sync_gray_wr_ptr [get_keepers {*|altera_jesd204_pcfifo:pcfifo|*dcfifo|sync_gray_wr_ptr[*]*}]
         set pcfifo_gray_rd_ptr [get_keepers {*|altera_jesd204_pcfifo:pcfifo|*dcfifo|gray_rd_ptr[*]*}]
         set pcfifo_sync_gray_rd_ptr [get_keepers {*|altera_jesd204_pcfifo:pcfifo|*dcfifo|sync_gray_rd_ptr[*]*}]
         set_max_delay -from \$pcfifo_gray_wr_ptr -to \$pcfifo_sync_gray_wr_ptr 100ns
         set_min_delay -from \$pcfifo_gray_wr_ptr -to \$pcfifo_sync_gray_wr_ptr -100ns
         set_max_delay -from \$pcfifo_gray_rd_ptr -to \$pcfifo_sync_gray_rd_ptr 100ns
         set_min_delay -from \$pcfifo_gray_rd_ptr -to \$pcfifo_sync_gray_rd_ptr -100ns 
         set_net_delay -max 2ns -from \$pcfifo_gray_wr_ptr -to \$pcfifo_sync_gray_wr_ptr
         set_net_delay -min 0ns -from \$pcfifo_gray_wr_ptr -to \$pcfifo_sync_gray_wr_ptr
         set_net_delay -max 2ns -from \$pcfifo_gray_rd_ptr -to \$pcfifo_sync_gray_rd_ptr
         set_net_delay -min 0ns -from \$pcfifo_gray_rd_ptr -to \$pcfifo_sync_gray_rd_ptr
            if { [string equal "quartus_sta" \$::TimeQuestInfo(nameofexecutable)] } {     
               for {set lane 0} {\$lane < $L} {incr lane} { 
               set tx_pcfifo_gray_wr_ptr_per_lane [get_keepers *inst_phy\\|*inst_tx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|gray_wr_ptr\\[*\\]*]
               set tx_pcfifo_sync_gray_wr_ptr_per_lane [get_keepers *inst_phy\\|*inst_tx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|sync_gray_wr_ptr\\[*\\]*]
               set tx_pcfifo_gray_rd_ptr_per_lane [get_keepers *inst_phy\\|*inst_tx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|gray_rd_ptr\\[*\\]*]
               set tx_pcfifo_sync_gray_rd_ptr_per_lane [get_keepers *inst_phy\\|*inst_tx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|sync_gray_rd_ptr\\[*\\]*]      
               set_max_skew ${linkclk_period_ns}ns -from \$tx_pcfifo_gray_wr_ptr_per_lane -to \$tx_pcfifo_sync_gray_wr_ptr_per_lane
               set_max_skew ${phyclk_period_ns}ns -from \$tx_pcfifo_gray_rd_ptr_per_lane -to \$tx_pcfifo_sync_gray_rd_ptr_per_lane            
               set rx_pcfifo_gray_wr_ptr_per_lane [get_keepers *inst_phy\\|*inst_rx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|gray_wr_ptr\\[*\\]*]
               set rx_pcfifo_sync_gray_wr_ptr_per_lane [get_keepers *inst_phy\\|*inst_rx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|sync_gray_wr_ptr\\[*\\]*]
               set rx_pcfifo_gray_rd_ptr_per_lane [get_keepers *inst_phy\\|*inst_rx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|gray_rd_ptr\\[*\\]*]
               set rx_pcfifo_sync_gray_rd_ptr_per_lane [get_keepers *inst_phy\\|*inst_rx_mlpcs\\|*\\[\${lane}\\]*altera_jesd204_pcfifo:pcfifo\\|*dcfifo\\|sync_gray_rd_ptr\\[*\\]*]      
               set_max_skew ${linkclk_period_ns}ns -from \$rx_pcfifo_gray_wr_ptr_per_lane -to \$rx_pcfifo_sync_gray_wr_ptr_per_lane
               set_max_skew ${phyclk_period_ns}ns -from \$rx_pcfifo_gray_rd_ptr_per_lane -to \$rx_pcfifo_sync_gray_rd_ptr_per_lane                    
               }
            } 
         @@ }  
      @@ } elseif {$device_family == "Arria 10" || $device_family == "Stratix 10"} {
      # Please uncomment and remove the REMOVE_ME and constraint the PLL reference clock 
      # REMOVE_ME create_clock -name "< tx_pll_ref_clk >" -period < refclk_period_ns >ns [get_ports *< tx_pll_ref_clk >*]
      set jesd204_rx_pll_ref_clk_ext  [jesd204_port_existence rx_pll_ref_clk]
      set jesd204_rx_pll_ref_clk_lsrc [lsearch -exact \$jesd204_clock_target_list rx_pll_ref_clk]
      set jesd204_rxlink_clk_ext      [jesd204_port_existence rxlink_clk]
      set jesd204_rxlink_clk_lsrc     [lsearch -exact \$jesd204_clock_target_list rxlink_clk]
      set jesd204_txlink_clk_ext      [jesd204_port_existence txlink_clk]
      set jesd204_txlink_clk_lsrc     [lsearch -exact \$jesd204_clock_target_list txlink_clk]

      if {\$jesd204_rx_pll_ref_clk_ext && \$jesd204_rx_pll_ref_clk_lsrc == -1} {
         create_clock -name "rx_pll_ref_clk" -period ${refclk_period_ns}ns [get_ports rx_pll_ref_clk] 
      }
      # REMOVE_ME derive_pll_clocks -create_base_clocks
      # REMOVE_ME derive_clock_uncertainty

      if {\$jesd204_rxlink_clk_ext && \$jesd204_rxlink_clk_lsrc == -1} {
         create_clock -name "rxlink_clk" -period ${linkclk_period_ns}ns [get_ports rxlink_clk]
      }
      if {\$jesd204_txlink_clk_ext && \$jesd204_txlink_clk_lsrc == -1} {
         create_clock -name "txlink_clk" -period ${linkclk_period_ns}ns [get_ports txlink_clk]
      }
      if {\$jesd204_rxlink_clk_ext && \$jesd204_rx_pll_ref_clk_ext && \$jesd204_txlink_clk_ext} {
         set_clock_groups -asynchronous -group {rxlink_clk} -group {rx_pll_ref_clk} -group {txlink_clk}
      }
      @@ if {$reconfig_en == "true"} {
      @@ if {$rcfg_shared == "true" || $L == 1} {
      set jesd204_reconfig_clk_ext  [jesd204_port_existence reconfig_clk]
      set jesd204_reconfig_clk_lsrc [lsearch -exact \$jesd204_clock_target_list reconfig_clk]

      if {\$jesd204_reconfig_clk_ext && \$jesd204_reconfig_clk_lsrc == -1} {
         # Set reconfig_clk to 100MHz. Users are responsible to constraint the reconfig_clk at desired value
         create_clock -name "reconfig_clk" -period 10ns [get_ports reconfig_clk] 
      }
      @@ } else {
      set jesd204_reconfig_clk_ext  [jesd204_port_existence reconfig_clk[*]]
      set jesd204_reconfig_clk_lsrc [lsearch -regexp \$jesd204_clock_target_list \{reconfig_clk\\[\\d\\]\}]

      if {\$jesd204_reconfig_clk_ext && \$jesd204_reconfig_clk_lsrc == -1} {
         # Set reconfig_clk to 100MHz. Users are responsible to constraint the reconfig_clk at desired value
         create_clock -name "reconfig_clk" -period 10ns [get_ports reconfig_clk[*]] 
      }
      @@ }
      @@ }
      @@ }
   @@ }
@@ }


@@ if {$wrapper == "base_phy"} {
   @@ if {$test_components_en == "true"} {
   # This section is only for Altera Internal Use. 
   create_clock -name "xcvr_rst_ctrl_clk" -period ${linkclk_period_ns}ns [get_ports xcvr_rst_ctrl_clk]
   @@ }
@@ }


