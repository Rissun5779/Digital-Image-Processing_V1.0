set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 0_9V -to rx_serial_data[4]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 0_9V -to rx_serial_data[5]
