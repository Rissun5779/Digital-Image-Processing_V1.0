set_location_assignment YOUR_PIN_LOCATION -to user_pb[1]
set_location_assignment YOUR_PIN_LOCATION -to user_pb[2]
set_location_assignment YOUR_PIN_LOCATION -to fmcb_dp_c2m_p[0]
set_location_assignment YOUR_PIN_LOCATION -to fmcb_dp_c2m_p[1]
set_location_assignment YOUR_PIN_LOCATION -to fmcb_dp_c2m_p[2]
set_location_assignment YOUR_PIN_LOCATION -to fmcb_dp_c2m_p[3]
set_location_assignment YOUR_PIN_LOCATION -to fmcb_dp_m2c_p[0]
