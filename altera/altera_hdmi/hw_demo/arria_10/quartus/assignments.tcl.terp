set_location_assignment YOUR_PIN_LOCATION -to "fmcb_gbtclk_m2c_p_0(n)"
set_location_assignment YOUR_PIN_LOCATION -to fmcb_la_rx_p_9
set_location_assignment YOUR_PIN_LOCATION -to fmcb_la_rx_p_8
set_location_assignment YOUR_PIN_LOCATION -to fmcb_la_rx_n_8
set_location_assignment YOUR_PIN_LOCATION -to fmcb_la_tx_p_10
set_location_assignment YOUR_PIN_LOCATION -to fmcb_la_tx_p_12
