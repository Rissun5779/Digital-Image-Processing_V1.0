# ------------------------------------------------------------------------------
# Look up table to store sequence slot content to be displayed to CMACRO
# ------------------------------------------------------------------------------
proc csd_slot_value_to_string {csd_slot_value_to_convert} {
    set csd_slot_tbl {{csd_slot_value string_code}}
    lappend csd_slot_tbl {0 CH0}
    lappend csd_slot_tbl {1 CH1}
    lappend csd_slot_tbl {2 CH2}
    lappend csd_slot_tbl {3 CH3}
    lappend csd_slot_tbl {4 CH4}
    lappend csd_slot_tbl {5 CH5}
    lappend csd_slot_tbl {6 CH6}
    lappend csd_slot_tbl {7 CH7}
    lappend csd_slot_tbl {8 CH8}
    lappend csd_slot_tbl {9 CH9}
    lappend csd_slot_tbl {10 CH10}
    lappend csd_slot_tbl {11 CH11}
    lappend csd_slot_tbl {12 CH12}
    lappend csd_slot_tbl {13 CH13}
    lappend csd_slot_tbl {14 CH14}
    lappend csd_slot_tbl {15 CH15}
    lappend csd_slot_tbl {16 CH16}
    lappend csd_slot_tbl {17 TSD}

    # Loop up code for the csd slot value
    for {set i 1} {$i <= [llength $csd_slot_tbl]} {incr i} {
        if { [ expr { $csd_slot_value_to_convert == [lindex $csd_slot_tbl $i 0] } ] } {
            return [lindex $csd_slot_tbl $i 1]
        }
    }

    # Cannot find csd slot value in loop up table
    send_message warning "Error converting csd slot value $csd_slot_value_to_convert to string output code."
    return 0
}

