# ------------------------------------------------------------------------------
# Elaborate GUI of Sequencer Tab
# ------------------------------------------------------------------------------
if { [ expr {$disable_sequencer_tab == 0} ] } {
    set_display_item_property "Sequencer" VISIBLE true
    # Show/Hide seq_order_slot_ based on seq_order_length
    set total_slot_name [get_parameter_value seq_order_length]
    for {set i 1} {$i <= 64} {incr i} {
        set current_slot_name "seq_order_slot_$i"
        #send_message info  "I inside first loop: $current_slot_name"
        if { [ expr { $i <= $total_slot_name } ] } {
            set_parameter_property        $current_slot_name    VISIBLE             true
            
            set current_slot_value_is_valid 0
        
            foreach {slot_val} $list_of_channel_in_use {
                set value_of_current_slot_name [get_parameter_value $current_slot_name]
                if {$value_of_current_slot_name != 17} {
                    set formatted_value_of_current_slot_name "$value_of_current_slot_name:CH $value_of_current_slot_name"
                } else {
                    set formatted_value_of_current_slot_name "$value_of_current_slot_name:TSD"
                }
                if { $formatted_value_of_current_slot_name == $slot_val} {
                    set current_slot_value_is_valid 1
                }
            }

            if {$current_slot_value_is_valid == 0} {
                send_message error "Sequencer Slot $i is pointing to Channel which is not available in current selected device part. Please re-configure Sequencer Slot $i."
            }
            
            set_parameter_property        $current_slot_name    ALLOWED_RANGES      $list_of_channel_in_use
        
        } else {
            set_parameter_property        $current_slot_name    VISIBLE             false
            set_parameter_property        $current_slot_name    ALLOWED_RANGES      {"30:Invalid" "0:CH 0" "1:CH 1" "2:CH 2" "3:CH 3" "4:CH 4" "5:CH 5" "6:CH 6" "7:CH 7" "8:CH 8" "9:CH 9" "10:CH 10" "11:CH 11" "12:CH 12" "13:CH 13" "14:CH 14" "15:CH 15" "16:CH 16" "17:TSD"}
        }
            
    }
} else {
    set_display_item_property "Sequencer" VISIBLE false
}

# ------------------------------------------------------------------------------
# Elaborate available ADC Input Clock options based on selected ADC Sampling Rate
# ------------------------------------------------------------------------------
set sample_rate [get_parameter_value sample_rate]

# $sample_rate == 0 -> 1 Mhz
# $sample_rate == 1 -> 500 Khz
# $sample_rate == 2 -> 250 Khz
# $sample_rate == 3 -> 200 Khz
# $sample_rate == 4 -> 125 Khz
# $sample_rate == 5 -> 100 Khz
# $sample_rate == 6 -> 50 Khz
# $sample_rate == 7 -> 25 Khz
# tsclkdiv == 0 -> Div by 10
# tsclkdiv == 1 -> Div by 20

if {$sample_rate == 0} {
    set_parameter_property clkdiv ALLOWED_RANGES {"1:2 Mhz" "2:10 Mhz" "3:20 Mhz" "4:40 Mhz" "5:80 Mhz"}  
} elseif {$sample_rate == 1} {
    set_parameter_property clkdiv ALLOWED_RANGES {"2:10 Mhz" "3:20 Mhz" "4:40 Mhz"}  
} elseif {$sample_rate == 2} {
    set_parameter_property clkdiv ALLOWED_RANGES {"2:10 Mhz" "3:20 Mhz"}  
} elseif {$sample_rate == 3} {
    set_parameter_property clkdiv ALLOWED_RANGES {"1:2 Mhz"}  
} elseif {$sample_rate == 4} {
    set_parameter_property clkdiv ALLOWED_RANGES {"2:10 Mhz"}  
} else {
    set_parameter_property clkdiv ALLOWED_RANGES {"1:2 Mhz"}  
}

# ------------------------------------------------------------------------------
# Verification on ADC Input Clock's content in order to resolve issue where
# old invalid value being retained in clkdiv parameter when sample rate option changes
# Derives out the effective clk divider setting based on selected sample rate and adc input clock
# Derives out sample_freq and sample_freq_temp_sense for Debug assignment
# ------------------------------------------------------------------------------
set clkdiv      [get_parameter_value clkdiv]

if {$sample_rate == 0} {
    
    if {$clkdiv != 1 && $clkdiv != 2 && $clkdiv != 3 && $clkdiv != 4 && $clkdiv != 5} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }

    set_parameter_value derived_clkdiv $clkdiv
    set_parameter_value tsclkdiv 1

    set sample_freq 1000000
    set sample_freq_temp_sense 50000 

} elseif {$sample_rate == 1} {
    
    if {$clkdiv != 2 && $clkdiv != 3 && $clkdiv != 4} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }

    set_parameter_value derived_clkdiv [ expr {$clkdiv + 1} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 500000
    set sample_freq_temp_sense 50000 

} elseif {$sample_rate == 2} {
    
    if {$clkdiv != 2 && $clkdiv != 3} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 2} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 250000
    set sample_freq_temp_sense 25000 

} elseif {$sample_rate == 3} {
    
    if {$clkdiv != 1} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 1} ]
    set_parameter_value tsclkdiv 0

    set sample_freq 200000
    set sample_freq_temp_sense 20000

} elseif {$sample_rate == 4} {
    
    if {$clkdiv != 2} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 3} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 125000
    set sample_freq_temp_sense 12500

} elseif {$sample_rate == 5} {
    
    if {$clkdiv != 1} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 2} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 100000
    set sample_freq_temp_sense 10000

} elseif {$sample_rate == 6} {
    
    if {$clkdiv != 1} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 3} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 50000
    set sample_freq_temp_sense 5000

} elseif {$sample_rate == 7} {
    
    if {$clkdiv != 1} {
        send_message error  "Selected ADC Input Clock is invalid. Please re-configure ADC Input Clock option."
    }
    
    set_parameter_value derived_clkdiv [ expr {$clkdiv + 4} ]
    set_parameter_value tsclkdiv 0
    
    set sample_freq 25000
    set sample_freq_temp_sense 2500

}

