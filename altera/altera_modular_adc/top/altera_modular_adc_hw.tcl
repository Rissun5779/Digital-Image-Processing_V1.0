#
#    // 2nd stage clock divider.
#    // 0 = DIV by 10;
#    // 1 = DIV by 20
#    parameter           tsclkdiv  = 1;
#    Note:
#    Divide the 1st stage clock divider of 1 Mhz by 20 to get a 50 Khz clock for internal TSD mode.
#    By having 1Mhz output from 1st stage clock divider.  This should always set to 1 = DIV by 20; and never need to set to 0 = DIV by 10; unless output of 1st stage clock divider is less than <= 500 Khz.
add_parameter                  tsclkdiv             INTEGER             1
set_parameter_property         tsclkdiv             DESCRIPTION         "The output of the 1st stage clock divider must be 1 Mhz.  Setting this to one will divide the 1st stage clock divider of 1 Mhz by 20 to get a 50 Khz clock for internal TSD mode.  A value of zero will divide by 10."
