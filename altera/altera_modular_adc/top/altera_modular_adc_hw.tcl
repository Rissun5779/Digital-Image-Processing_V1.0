    set_instance_parameter st_splitter_internal USE_PACKETS 1
    set_instance_parameter st_splitter_internal USE_CHANNEL 1
    set_instance_parameter st_splitter_internal USE_ERROR 0
    set_instance_parameter st_splitter_internal USE_DATA 1
    set_instance_parameter st_splitter_internal DATA_WIDTH 12
    set_instance_parameter st_splitter_internal CHANNEL_WIDTH 5
    set_instance_parameter st_splitter_internal BITS_PER_SYMBOL 12
    set_instance_parameter st_splitter_internal MAX_CHANNELS 31
}

proc do_compose {} {

set threshold_detect_core_en    [ expr { [get_parameter_value CORE_VAR] == 1 } ]
set disable_sequencer_tab       [ expr { [get_parameter_value CORE_VAR] == 3 } ]

# ------------------------------------------------------------------------------
# Elaborate GUI of General Tab
# ------------------------------------------------------------------------------

# Set device_adc_type based on DEVICE_PART
set device_part_string [get_parameter_value DEVICE_PART]
set partname_first7char [string range $device_part_string 0 6]
set partname_package_info [string range $device_part_string 7 10]

if { $partname_package_info == "M153" || $partname_package_info == "U169" || $partname_package_info == "E144" } {
    set only_lower_channel_bond_out 1
} else {
    set only_lower_channel_bond_out 0
}

#"41:10M25SA - single ADCs and single supply voltage"
#"42:10M40SA - single ADCs and single supply voltage"
#"43:10M50SA - single ADCs and single supply voltage"
#"31:10M25DA - dual ADCs and dual supply voltage"
#"32:10M40DA - dual ADCs and dual supply voltage"
#"33:10M50DA - dual ADCs and dual supply voltage"
#"21:10M04SA - single ADC and single supply voltage"
#"22:10M08SA - single ADC and single supply voltage"
#"23:10M16SA - single ADC and single supply voltage"
#"11:10M04DA - single ADC and dual supply voltage"
#"12:10M08DA - single ADC and dual supply voltage"
#"13:10M16DA - single ADC and dual supply voltage"
if { $partname_first7char == "10M25SA" } {
    set_parameter_value  device_adc_type  41
} elseif {
    $partname_first7char == "10M40SA" } {
    set_parameter_value  device_adc_type  42
} elseif {
    $partname_first7char == "10M50SA" } {
    set_parameter_value  device_adc_type  43
} elseif {
    $partname_first7char == "10M25DA" } {
    set_parameter_value  device_adc_type  31
} elseif {
    $partname_first7char == "10M40DA" } {
    set_parameter_value  device_adc_type  32
} elseif {
    $partname_first7char == "10M50DA" } {
    set_parameter_value  device_adc_type  33
} elseif {
    $partname_first7char == "10M04SA" } {
    set_parameter_value  device_adc_type  21
} elseif {
    $partname_first7char == "10M08SA" } {
    set_parameter_value  device_adc_type  22
} elseif {
    $partname_first7char == "10M16SA" } {
    set_parameter_value  device_adc_type  23
} elseif {
    $partname_first7char == "10M04DA" } {
    set_parameter_value  device_adc_type  11
} elseif {
    $partname_first7char == "10M08DA" } {
    set_parameter_value  device_adc_type  12
} elseif {
    $partname_first7char == "10M16DA" } {
    set_parameter_value  device_adc_type  13
} else {
    send_message error "The selected device part number ${device_part_string} does not support ADC"
}

# Find out which silicon die, the count of ADCs and the supply voltage
set adc_type [get_parameter_value device_adc_type]
if { [ expr { $adc_type >= 40 } ] } {
    set_parameter_value  max_adc_count_on_die      2
    set_parameter_value  adc_count_on_device       1
    set_parameter_value  device_power_supply_type  1
} else {
    if { [ expr { $adc_type >= 30 } ] } {
        set_parameter_value  max_adc_count_on_die      2
        set_parameter_value  adc_count_on_device       2
        set_parameter_value  device_power_supply_type  2
    } else {
        if { [ expr { $adc_type >= 20 } ] } {
            set_parameter_value  max_adc_count_on_die      1
            set_parameter_value  adc_count_on_device       1
            set_parameter_value  device_power_supply_type  1
        } else {
            set_parameter_value  max_adc_count_on_die      1
            set_parameter_value  adc_count_on_device       1
            set_parameter_value  device_power_supply_type  2
        }
    }
}

# Set the device_partname_fivechar_prefix parameter
if { $adc_type == 11 || $adc_type == 21 } {
    set_parameter_value  device_partname_fivechar_prefix "10M04"
} elseif { $adc_type == 12 || $adc_type == 22 } {
    set_parameter_value  device_partname_fivechar_prefix "10M08"
} elseif { $adc_type == 13 || $adc_type == 23 } {
    set_parameter_value  device_partname_fivechar_prefix "10M16"
} elseif { $adc_type == 31 || $adc_type == 41 } {
    set_parameter_value  device_partname_fivechar_prefix "10M25"
} elseif { $adc_type == 32 || $adc_type == 42 } {
    set_parameter_value  device_partname_fivechar_prefix "10M40"
} elseif { $adc_type == 33 || $adc_type == 43 } {
    set_parameter_value  device_partname_fivechar_prefix "10M50"
} else {
    send_message error "Error adc_type - Unsupported device"
}

# If there is only one ADC, do not ask "Mega Wizard is setting up for which ADCs?"
if { [ expr { [get_parameter_value adc_count_on_device] == 1 } ] } {
    set_parameter_property  ip_is_for_which_adc    VISIBLE   false
} else {
    set_parameter_property  ip_is_for_which_adc    VISIBLE   true
}

if { [ expr { [get_parameter_value adc_count_on_device] == 1 } ] } {
    #If the device only have one ADC only, this parameters is unused.
    set_parameter_property      is_this_first_or_second_adc  HDL_PARAMETER   false

	# If this is a dual ADCs die which 2nd ADC removed.
	if { [ expr { [get_parameter_value max_adc_count_on_die] == 2 } ] || $only_lower_channel_bond_out == 1 } {
	    # Channel availalbe are: TSD, CH0 to CH8
		set_display_item_property "No TSD" VISIBLE false
		set_display_item_property "TSD" VISIBLE true
		set_display_item_property "CH0" VISIBLE true
		set_display_item_property "CH1" VISIBLE true
		set_display_item_property "CH2" VISIBLE true
		set_display_item_property "CH3" VISIBLE true
		set_display_item_property "CH4" VISIBLE true
		set_display_item_property "CH5" VISIBLE true
		set_display_item_property "CH6" VISIBLE true
		set_display_item_property "CH7" VISIBLE true
		set_display_item_property "CH8" VISIBLE true
		set_display_item_property "CH9" VISIBLE false
		set_display_item_property "CH10" VISIBLE false
		set_display_item_property "CH11" VISIBLE false
		set_display_item_property "CH12" VISIBLE false
		set_display_item_property "CH13" VISIBLE false
		set_display_item_property "CH14" VISIBLE false
		set_display_item_property "CH15" VISIBLE false
		set_display_item_property "CH16" VISIBLE false
		#set_display_item_property "CH17" VISIBLE false
                set ch9_to_ch16_avail 0
                set tsd_avail 1
	} else {
	    # Channel availalbe are: TSD, CH0 to CH16
		set_display_item_property "No TSD" VISIBLE false
		set_display_item_property "TSD" VISIBLE true
		set_display_item_property "CH0" VISIBLE true
		set_display_item_property "CH1" VISIBLE true
		set_display_item_property "CH2" VISIBLE true
		set_display_item_property "CH3" VISIBLE true
		set_display_item_property "CH4" VISIBLE true
		set_display_item_property "CH5" VISIBLE true
		set_display_item_property "CH6" VISIBLE true
		set_display_item_property "CH7" VISIBLE true
		set_display_item_property "CH8" VISIBLE true
		set_display_item_property "CH9" VISIBLE true
		set_display_item_property "CH10" VISIBLE true
		set_display_item_property "CH11" VISIBLE true
		set_display_item_property "CH12" VISIBLE true
		set_display_item_property "CH13" VISIBLE true
		set_display_item_property "CH14" VISIBLE true
		set_display_item_property "CH15" VISIBLE true
		set_display_item_property "CH16" VISIBLE true
		#set_display_item_property "CH17" VISIBLE false
                set ch9_to_ch16_avail 1
                set tsd_avail 1
	}
} else {
    if { [ expr { [get_parameter_value ip_is_for_which_adc] == 1 } ] } {
        # "1:1st ADC"
        set_parameter_property  is_this_first_or_second_adc  HDL_PARAMETER   true
        set_parameter_value is_this_first_or_second_adc  1
	    # Channel availalbe are: TSD, CH0 to CH8
		set_display_item_property "No TSD" VISIBLE false
		set_display_item_property "TSD" VISIBLE true
		set_display_item_property "CH0" VISIBLE true
		set_display_item_property "CH1" VISIBLE true
		set_display_item_property "CH2" VISIBLE true
		set_display_item_property "CH3" VISIBLE true
		set_display_item_property "CH4" VISIBLE true
		set_display_item_property "CH5" VISIBLE true
		set_display_item_property "CH6" VISIBLE true
		set_display_item_property "CH7" VISIBLE true
		set_display_item_property "CH8" VISIBLE true
		set_display_item_property "CH9" VISIBLE false
		set_display_item_property "CH10" VISIBLE false
		set_display_item_property "CH11" VISIBLE false
		set_display_item_property "CH12" VISIBLE false
		set_display_item_property "CH13" VISIBLE false
		set_display_item_property "CH14" VISIBLE false
		set_display_item_property "CH15" VISIBLE false
		set_display_item_property "CH16" VISIBLE false
		#set_display_item_property "CH17" VISIBLE false	
                set ch9_to_ch16_avail 0
                set tsd_avail 1
    } elseif { [ expr { [get_parameter_value ip_is_for_which_adc] == 2 } ] } {
        # "2:2nd ADC"
        set_parameter_property  is_this_first_or_second_adc  HDL_PARAMETER   true
        set_parameter_value is_this_first_or_second_adc  2
	    # Channel availalbe are: CH0 to CH8
		set_display_item_property "No TSD" VISIBLE true
		set_display_item_property "TSD" VISIBLE false
		set_display_item_property "CH0" VISIBLE true
		set_display_item_property "CH1" VISIBLE true
		set_display_item_property "CH2" VISIBLE true
		set_display_item_property "CH3" VISIBLE true
		set_display_item_property "CH4" VISIBLE true
		set_display_item_property "CH5" VISIBLE true
		set_display_item_property "CH6" VISIBLE true
		set_display_item_property "CH7" VISIBLE true
		set_display_item_property "CH8" VISIBLE true
		set_display_item_property "CH9" VISIBLE false
		set_display_item_property "CH10" VISIBLE false
		set_display_item_property "CH11" VISIBLE false
		set_display_item_property "CH12" VISIBLE false
		set_display_item_property "CH13" VISIBLE false
		set_display_item_property "CH14" VISIBLE false
		set_display_item_property "CH15" VISIBLE false
		set_display_item_property "CH16" VISIBLE false
		#set_display_item_property "CH17" VISIBLE false
                set ch9_to_ch16_avail 0
                set tsd_avail 0
    } else {
        # Need a "3:Dual ADCs" FSM that instantiate both ADC
        # This parameter will need to be set by the FSM supporting both in one FSM
        set_parameter_property  is_this_first_or_second_adc  HDL_PARAMETER   false
		# Channel availalbe are: (ADC1 TSD, CH0 to CH8) + (ADC2 CH0 to CH8 aka CH9..CH17)
    }
}

#Voltage reference source
if { [ expr { [get_parameter_value refsel] == 0 } ] } {
    #External
    set_parameter_property  int_vref_vr          VISIBLE   false
    set_parameter_property  int_vref_nonvr       VISIBLE   false
    set_parameter_property  external_vref        VISIBLE   true
    set_parameter_value     reference_voltage   [get_parameter_value external_vref]
    update_threshold_allowed_range [get_parameter_value external_vref]
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  external_vref        ALLOWED_RANGES  "0:2.5"
    } else {
        #Single Supply
		set_parameter_property  external_vref        ALLOWED_RANGES  "0:3.63"
    }
} else {
    #Internal
    set_parameter_property  external_vref        VISIBLE   false
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  int_vref_vr      VISIBLE   false
        set_parameter_property  int_vref_nonvr   VISIBLE   true
        set_parameter_value     reference_voltage   [get_parameter_value int_vref_nonvr]
        update_threshold_allowed_range [get_parameter_value int_vref_nonvr]
    } else {
        #Single Supply
        set_parameter_property  int_vref_vr      VISIBLE   true
        set_parameter_property  int_vref_nonvr   VISIBLE   false
        set_parameter_value     reference_voltage   [get_parameter_value int_vref_vr]
        update_threshold_allowed_range [get_parameter_value int_vref_vr]
    }
}


# Set Prescaler parameter bits
# prescalar_mux 0 : Dual ADC device with 2nd ADC
# prescalar_mux 1 : Invalid. This path always false.
# prescalar_mux 2 : Dual ADC device with 1st ADC
# prescalar_mux 3 : Single ADC device
#
set prescalar_mux [expr { (
[expr { $tsd_avail == 1 ? 2 : 0 }] +
[expr { $ch9_to_ch16_avail == 1 ? 1 : 0 }] ) } ]

switch $prescalar_mux {
    0 {
        set_parameter_value prescalar [expr { ([get_parameter_value prescaler_ch8] == true) && ([get_parameter_value use_ch8] == true) ? 2 : 0 }] 
    }

    1 {
        set_parameter_value prescalar 0
    }

    2 {
        set_parameter_value prescalar [expr { ([get_parameter_value prescaler_ch8] == true) && ([get_parameter_value use_ch8] == true) ? 1 : 0 }] 
    }

    3 {
        set_parameter_value prescalar [expr { (
        [expr { ([get_parameter_value prescaler_ch8]  == true) && ([get_parameter_value use_ch8] == true) ? 1 : 0 }] +
        [expr { ([get_parameter_value prescaler_ch16] == true) && ([get_parameter_value use_ch16] == true) ? 2 : 0 }] ) } ]
    }

}

