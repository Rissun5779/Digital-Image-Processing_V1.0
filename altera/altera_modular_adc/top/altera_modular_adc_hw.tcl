set_parameter_property         tsclkdiv             HDL_PARAMETER       false
set_parameter_property         tsclkdiv             DERIVED             true
set_parameter_property         tsclkdiv             ALLOWED_RANGES      {"0:DIV by 10" "1:DIV by 20"}
add_display_item "Clocks"      tsclkdiv             PARAMETER

