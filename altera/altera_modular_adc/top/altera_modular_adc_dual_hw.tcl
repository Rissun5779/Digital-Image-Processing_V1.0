# ------------------------------------------------------------------------------
# Convert voltage from GUI to ADC digital output correspondence code
# ------------------------------------------------------------------------------
proc voltage_to_code {voltage_to_convert voltage_to_convert_ref} {
    # Calculate 12 bits corresponding value
    # Calculate using the De facto coding scheme for ADC/DAC - Unipolar Straight Binary coding scheme
    # It is important to note that the analog value represented by the all-ones code is not full-scale (abbreviated FS)
    # but FS - 1 LSB.  This is a common convention in data conversion notation and applies to both ADCs and DACs.
    set result [expr { int(($voltage_to_convert / $voltage_to_convert_ref) * 4096) }]
    if { [ expr { $result >= 4096 } ] } {
    set result 4095
    }
    return $result
}

