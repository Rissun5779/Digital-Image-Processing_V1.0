proc do_compose {} {

set threshold_detect_core_en    [ expr { [get_parameter_value CORE_VAR] == 1 } ]
set disable_sequencer_tab       [ expr { [get_parameter_value CORE_VAR] == 3 } ]

# ------------------------------------------------------------------------------
# Elaborate GUI of General Tab
# ------------------------------------------------------------------------------

# Set device_adc_type based on DEVICE_PART
set device_part_string [get_parameter_value DEVICE_PART]
set partname_first7char [string range $device_part_string 0 6]

#"41:10M25SA - single ADCs and single supply voltage"
#"42:10M40SA - single ADCs and single supply voltage"
#"43:10M50SA - single ADCs and single supply voltage"
#"31:10M25DA - dual ADCs and dual supply voltage"
#"32:10M40DA - dual ADCs and dual supply voltage"
#"33:10M50DA - dual ADCs and dual supply voltage"
#"21:10M04SA - single ADC and single supply voltage"
#"22:10M08SA - single ADC and single supply voltage"
#"23:10M16SA - single ADC and single supply voltage"
#"11:10M04DA - single ADC and dual supply voltage"
#"12:10M08DA - single ADC and dual supply voltage"
#"13:10M16DA - single ADC and dual supply voltage"
if { $partname_first7char == "10M25SA" } {
    set_parameter_value  device_adc_type  41
} elseif {
    $partname_first7char == "10M40SA" } {
    set_parameter_value  device_adc_type  42
} elseif {
    $partname_first7char == "10M50SA" } {
    set_parameter_value  device_adc_type  43
} elseif {
    $partname_first7char == "10M25DA" } {
    set_parameter_value  device_adc_type  31
} elseif {
    $partname_first7char == "10M40DA" } {
    set_parameter_value  device_adc_type  32
} elseif {
    $partname_first7char == "10M50DA" } {
    set_parameter_value  device_adc_type  33
} elseif {
    $partname_first7char == "10M04SA" } {
    set_parameter_value  device_adc_type  21
} elseif {
    $partname_first7char == "10M08SA" } {
    set_parameter_value  device_adc_type  22
} elseif {
    $partname_first7char == "10M16SA" } {
    set_parameter_value  device_adc_type  23
} elseif {
    $partname_first7char == "10M04DA" } {
    set_parameter_value  device_adc_type  11
} elseif {
    $partname_first7char == "10M08DA" } {
    set_parameter_value  device_adc_type  12
} elseif {
    $partname_first7char == "10M16DA" } {
    set_parameter_value  device_adc_type  13
} else {
    send_message error "The selected device part number ${device_part_string} does not support ADC"
}

# Find out which silicon die, the count of ADCs and the supply voltage
set adc_type [get_parameter_value device_adc_type]
if { [ expr { $adc_type >= 40 } ] } {
    set_parameter_value  max_adc_count_on_die      2
    set_parameter_value  adc_count_on_device       1
    set_parameter_value  device_power_supply_type  1
} else {
    if { [ expr { $adc_type >= 30 } ] } {
        set_parameter_value  max_adc_count_on_die      2
        set_parameter_value  adc_count_on_device       2
        set_parameter_value  device_power_supply_type  2
    } else {
        if { [ expr { $adc_type >= 20 } ] } {
            set_parameter_value  max_adc_count_on_die      1
            set_parameter_value  adc_count_on_device       1
            set_parameter_value  device_power_supply_type  1
        } else {
            set_parameter_value  max_adc_count_on_die      1
            set_parameter_value  adc_count_on_device       1
            set_parameter_value  device_power_supply_type  2
        }
    }
}

# Set the device_partname_fivechar_prefix parameter
if { $adc_type == 11 || $adc_type == 21 } {
    set_parameter_value  device_partname_fivechar_prefix "10M04"
} elseif { $adc_type == 12 || $adc_type == 22 } {
    set_parameter_value  device_partname_fivechar_prefix "10M08"
} elseif { $adc_type == 13 || $adc_type == 23 } {
    set_parameter_value  device_partname_fivechar_prefix "10M16"
} elseif { $adc_type == 31 || $adc_type == 41 } {
    set_parameter_value  device_partname_fivechar_prefix "10M25"
} elseif { $adc_type == 32 || $adc_type == 42 } {
    set_parameter_value  device_partname_fivechar_prefix "10M40"
} elseif { $adc_type == 33 || $adc_type == 43 } {
    set_parameter_value  device_partname_fivechar_prefix "10M50"
} else {
    send_message error "Error adc_type - Unsupported device"
}

if { [ expr { [get_parameter_value adc_count_on_device] == 1 } ] } {
    send_message error "The selected device part number ${device_part_string} only has one ADC. Altera Modular ADC core (Dual Mode) is for device part with two ADCs."
}

#Voltage reference source - ADC1
if { [ expr { [get_parameter_value refsel] == 0 } ] } {
    #External
    set_parameter_property  int_vref_vr          VISIBLE   false
    set_parameter_property  int_vref_nonvr       VISIBLE   false
    set_parameter_property  external_vref        VISIBLE   true
    set_parameter_value     reference_voltage   [get_parameter_value external_vref]
    update_threshold_allowed_range [get_parameter_value external_vref]
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  external_vref        ALLOWED_RANGES  "0:2.5"
    } else {
        #Single Supply
	set_parameter_property  external_vref        ALLOWED_RANGES  "0:3.63"
    }
} else {
    #Internal
    set_parameter_property  external_vref        VISIBLE   false
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  int_vref_vr      VISIBLE   false
        set_parameter_property  int_vref_nonvr   VISIBLE   true
        set_parameter_value     reference_voltage   [get_parameter_value int_vref_nonvr]
        update_threshold_allowed_range [get_parameter_value int_vref_nonvr]
    } else {
        #Single Supply
        set_parameter_property  int_vref_vr      VISIBLE   true
        set_parameter_property  int_vref_nonvr   VISIBLE   false
        set_parameter_value     reference_voltage   [get_parameter_value int_vref_vr]
        update_threshold_allowed_range [get_parameter_value int_vref_vr]
    }
}

#Voltage reference source - ADC2
if { [ expr { [get_parameter_value refsel_adc2] == 0 } ] } {
