    set_parameter_value     reference_voltage_adc2      [get_parameter_value external_vref_adc2]
    update_threshold_allowed_range [get_parameter_value external_vref_adc2]
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  external_vref_adc2        ALLOWED_RANGES  "0:2.5"
    } else {
        #Single Supply
	set_parameter_property  external_vref_adc2        ALLOWED_RANGES  "0:3.63"
    }
} else {
    #Internal
    set_parameter_property  external_vref_adc2          VISIBLE   false
    if { [ expr { [get_parameter_value device_power_supply_type] == 2 } ] } {
        #Dual Supply
        set_parameter_property  int_vref_vr_adc2        VISIBLE   false
        set_parameter_property  int_vref_nonvr_adc2     VISIBLE   true
        set_parameter_value     reference_voltage_adc2  [get_parameter_value int_vref_nonvr_adc2]
        update_threshold_allowed_range [get_parameter_value int_vref_nonvr_adc2]
    } else {
        #Single Supply
        set_parameter_property  int_vref_vr_adc2        VISIBLE   true
        set_parameter_property  int_vref_nonvr_adc2     VISIBLE   false
        set_parameter_value     reference_voltage_adc2  [get_parameter_value int_vref_vr_adc2]
        update_threshold_allowed_range [get_parameter_value int_vref_vr_adc2]
    }
}

set_parameter_value prescalar [expr { ([get_parameter_value prescaler_ch8] == true) && ([get_parameter_value use_ch8] == true) ? 1 : 0 }] 
