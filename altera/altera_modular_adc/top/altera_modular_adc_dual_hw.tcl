#    Note:
#    The GUI discourage user from using frequency that cannot be perfectly divide by 1, 2, 10, 20, 40 or 80 to get 1Mhz.
#    This will ensure that the SAR ADC fMAX is 1Msps at 1Mhz and not in the kilohertz range.
add_parameter                  clkdiv               INTEGER             "2"
set_parameter_property         clkdiv               DISPLAY_NAME        "ADC Input Clock"
set_parameter_property         clkdiv               DESCRIPTION         "Frequency of PLL-C0 Clock supply for ADC Core.<br/>The ADC core clock is sourced directly from clock counter zero (C0)of either PLL1 or PLL3. Although the routing is hard wired in silicon, the user MUST configure the PLL correctly to supply the ADC core clock.<br/>The ADC Core runs at sampling rate configured in ADC Sample Rate parameter. The PLL supplied frequency must match then the ADCs built-in clock divider which must be configured correctly by a factor of 2, 10, 20, 40 or 80.<br/><br/>Follow the steps below to ensure that the configuration is correct.<br/>1. Configures ADC Sample Rate as well as ADC Input Clock parameter of this ADC MegaCore.<br/>2. In the ALTPLL MegaCore, Configure C0 to output frequency equivalent to frequency configured in ADC Input Clock parameter.<br/>3. Connect the PLL.C0 output signal to the ADC.clk_in_pll_c0 input signal.<br/>"
set_parameter_property         clkdiv               ALLOWED_RANGES      {"1:2 Mhz" "2:10 Mhz" "3:20 Mhz" "4:40 Mhz" "5:80 Mhz"}
