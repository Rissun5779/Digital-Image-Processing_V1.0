proc is_enabled {parameter} {
    if {[get_parameter_value $parameter] == "true"} {
	return 1
    } else {
	return 0
    }
}

# ------------------------------------------------------------------------------
# Elaboration Callback
# ------------------------------------------------------------------------------
proc elaboration {} {
    if { [is_enabled dual_adc_mode] } {
        set_interface_property sync_handshake ENABLED true
        add_interface_port conduit_end clk_in_pll_locked internal_conduit_in Input 1
    } else {
        set_interface_property sync_handshake ENABLED false
        add_interface_port conduit_end clk_in_pll_locked export Input 1
    }
}
