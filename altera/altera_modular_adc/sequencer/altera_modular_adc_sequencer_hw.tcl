# display items
# 


# 
# connection point clock
# 
add_interface clock clock end
set_interface_property clock clockRate 0
set_interface_property clock ENABLED true
set_interface_property clock EXPORT_OF ""
set_interface_property clock PORT_NAME_MAP ""
set_interface_property clock CMSIS_SVD_VARIABLES ""
set_interface_property clock SVD_ADDRESS_GROUP ""

add_interface_port clock clk clk Input 1


# 
# connection point reset_sink
# 
add_interface reset_sink reset end
set_interface_property reset_sink associatedClock clock
set_interface_property reset_sink synchronousEdges DEASSERT
set_interface_property reset_sink ENABLED true
set_interface_property reset_sink EXPORT_OF ""
set_interface_property reset_sink PORT_NAME_MAP ""
set_interface_property reset_sink CMSIS_SVD_VARIABLES ""
set_interface_property reset_sink SVD_ADDRESS_GROUP ""

add_interface_port reset_sink rst_n reset_n Input 1


# 
# connection point command
# 
add_interface command avalon_streaming start
set_interface_property command associatedClock clock
set_interface_property command associatedReset reset_sink
set_interface_property command dataBitsPerSymbol 8
set_interface_property command errorDescriptor ""
set_interface_property command firstSymbolInHighOrderBits true
set_interface_property command maxChannel 31
set_interface_property command readyLatency 0
set_interface_property command ENABLED true
set_interface_property command EXPORT_OF ""
set_interface_property command PORT_NAME_MAP ""
set_interface_property command CMSIS_SVD_VARIABLES ""
set_interface_property command SVD_ADDRESS_GROUP ""

add_interface_port command cmd_ready ready Input 1
add_interface_port command cmd_valid valid Output 1
add_interface_port command cmd_channel channel Output 5
add_interface_port command cmd_sop startofpacket Output 1
add_interface_port command cmd_eop endofpacket Output 1

# 
# connection point command_2 - ADC2
# 
add_interface command_2 avalon_streaming start
set_interface_property command_2 associatedClock clock
set_interface_property command_2 associatedReset reset_sink
set_interface_property command_2 dataBitsPerSymbol 8
