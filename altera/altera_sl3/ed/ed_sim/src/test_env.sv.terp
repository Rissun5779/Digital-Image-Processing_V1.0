// sole purpose of programming logic devices manufactured by Intel and sold by 
// Intel or its authorized distributors.  Please refer to the applicable 
// agreement for further details.


`timescale 1 ps / 1 ps

import altera_sl3_tb_params::*;

module test_env #
(
   parameter  real            MGMT_CLK_PERIOD            = 10.000e3,
   parameter                  TOTAL_SAMPLES_TO_TRANSFER  = 2000,
   parameter                  SKEW_INSERTION_ENABLE      = 1

);

   wire                           tx_link_up;
   wire   [(LANES*64)-1:0]        tx_data;
   wire   [7:0]                   tx_channel;
   wire   [3:0]                   tx_error;
   wire                           tx_startofpacket;
   wire                           tx_endofpacket;
   wire                           tx_user_clock_reset;
   wire                           tx_xcvr_pll_ref_clk;
   wire                           tx_valid;
   wire                           tx_user_clock;
   wire                           tx_core_reset;

   wire                           rx_link_up;
   wire   [(LANES*64)-1:0]        rx_data;
   wire   [7:0]                   rx_channel;
   wire   [(LANES+5)-1:0]         rx_error;
   wire                           rx_startofpacket;
   wire                           rx_endofpacket;
   wire                           rx_user_clock_reset;
   wire                           rx_xcvr_pll_ref_clk;
   wire                           rx_valid;
   wire                           rx_user_clock;
   wire                           rx_core_reset;

   wire   [63:0]                  burst_descr;
   wire                           burst_descr_ready;
   wire                           burst_descr_read;

   wire   [LANES-1:0]             pre_skew_serial_data;
   wire   [LANES-1:0]             post_skew_serial_data;

   wire                           mgmt_clk;

   wire                           tx_phy_mgmt_clk;
   wire                           tx_phy_mgmt_clk_reset;
   wire   [31:0]                  tx_phy_mgmt_readdata;
   wire   [31:0]                  tx_phy_mgmt_writedata;
   wire   [ADDRESS_WIDTH-1:0]     tx_phy_mgmt_address;
   wire                           tx_phy_mgmt_read;
   wire                           tx_phy_mgmt_write;
   wire                           tx_phy_mgmt_waitrequest;

   wire                           rx_phy_mgmt_clk;
   wire                           rx_phy_mgmt_clk_reset;
   wire   [31:0]                  rx_phy_mgmt_readdata;
   wire   [31:0]                  rx_phy_mgmt_writedata;
   wire   [ADDRESS_WIDTH-1:0]     rx_phy_mgmt_address;
   wire                           rx_phy_mgmt_read;
   wire                           rx_phy_mgmt_write;
   wire                           rx_phy_mgmt_waitrequest;

   wire                           tg_enable;
   wire                           tg_test_mode;
   wire                           tg_enable_stalls;

   wire   [15:0]                  tg_burst_count;
   wire   [63:0]                  tg_words_transferred;

   wire                           tc_enable;
   wire   [26:0]                  tc_burst_count;
   wire   [63:0]                  tc_words_transferred;
   wire   [LANES-1:0]             tc_lane_swap_error;
   wire   [LANES-1:0]             tc_lane_sequence_error;
   wire   [LANES-1:0]             tc_lane_alignment_error;

   wire                           pll_locked;
   
   wire   [7:0]                   tx_empty;
   wire   [7:0]                   rx_empty;
   wire                           tx_err_interrupt;
   wire                           rx_err_interrupt;

   wire                           tb_gen_rx_user_clock; // rx_user_clock generated by tb. For SCM usage
   wire                           tb_gen_rx_user_clock_reset; // tx_user_clock_reset generated by tb. For SCM usage
   wire                           rxcore_clock; // for ACM, ouput from SL3
   wire                           rxcore_clock_reset; // for ACM, ouput from SL3

   generate
   if (ADVANCED_CLOCKING == 1) begin : acm_rx_user_clk
      assign rx_user_clock       = rxcore_clock;
      assign rx_user_clock_reset = rxcore_clock_reset;
   end else begin : scm_rx_user_clk
      assign rx_user_clock       = tb_gen_rx_user_clock;
      assign rx_user_clock_reset = tb_gen_rx_user_clock_reset;
   end
   endgenerate

   //
   // Source traffic generator
   //
   traffic_gen #
   (
      .LANES                     (LANES),
      .STREAM                    (STREAM),
      .TOTAL_SAMPLES_TO_TRANSFER (TOTAL_SAMPLES_TO_TRANSFER),
      .MIN_INTER_BURST_GAP       (BURST_GAP)
   )
   traffic_gen
   (
      // Clocks and reset
      .user_clock                (tx_user_clock),
      .user_clock_reset          (tx_user_clock_reset),

      // Traffic checker ports
      .burst_descr               (burst_descr),
      .burst_descr_read          (burst_descr_read),
      .burst_descr_read_clk      (rx_user_clock),
      .burst_descr_ready         (burst_descr_ready),

      // Streaming data interface
      .data                      (tx_data),
      .sync                      (tx_channel),
      .empty                     (tx_empty),
      .valid                     (tx_valid),
      .start_of_burst            (tx_startofpacket),
      .end_of_burst              (tx_endofpacket),
      .link_up                   (tx_link_up),

      // Test control ports
      .tg_enable                 (tg_enable),
      .tg_test_mode              (tg_test_mode),
      .tg_enable_stalls          (tg_enable_stalls),

      // Status interface
      .tg_burst_count            (tg_burst_count),
      .tg_words_transferred      (tg_words_transferred)
   );
   
   //
   // Source Interlaken PHY IP management interface tie-offs
   //
   assign tx_phy_mgmt_clk        = mgmt_clk;
   assign tx_phy_mgmt_clk_reset  = tx_core_reset;
   assign tx_phy_mgmt_address    = 9'd0;
   assign tx_phy_mgmt_read       = 1'b0;
   assign tx_phy_mgmt_write      = 1'b0;
   assign tx_phy_mgmt_writedata  = 32'd0;


   // Determine the total number of PLLS on per Six Pack
   // e.g. if lanes=14, 3 PLLs will be instantiated - 1 per 6 Pack		  
//   localparam     PLL_SHARED_LANES   = 6 ;
//   localparam     XSLICES            = LANES/PLL_SHARED_LANES;
//   localparam     XREMAIN            = LANES % PLL_SHARED_LANES;
//   localparam     TOTAL_PLLS         = (XREMAIN >0)? XSLICES +1 : XSLICES;
//   wire   [TOTAL_PLLS-1:0]     pll_locked_per_pll ;
//   wire   [TOTAL_PLLS-1:0]     tx_serial_clk_per_pll;
//   wire   [LANES-1:0]          tx_serial_clk ;

   // ATX PLL 
//   assign pll_locked = &pll_locked_per_pll ; // AND pll-locked from each pll

//   generate
//   genvar i;
//   for (i=0;i<TOTAL_PLLS; i=i+1) begin : PLL_WO_MCGB
//      altera_atx_pll_a10 a10_atx_pll_inst (
//         .pll_powerdown   (pll_powerdown), // pll_powerdown.pll_powerdown
//         .pll_refclk0     (tx_xcvr_pll_ref_clk),   //   pll_refclk0.clk
//         .tx_serial_clk   (tx_serial_clk_per_pll[i]), // tx_serial_clk.clk
//         .pll_locked      (pll_locked_per_pll[i]),    //    pll_locked.pll_locked
//         .pll_cal_busy    ()  //  pll_cal_busy.pll_cal_busy
//      );
//   end
//   for (i=1;i<=XSLICES;i=i+1) begin : CONTACT_GRP
//      assign tx_serial_clk[PLL_SHARED_LANES*i-1:PLL_SHARED_LANES*(i-1)] = {PLL_SHARED_LANES{tx_serial_clk_per_pll[i-1]}};
//   end	       
//   if (XREMAIN>0) begin : CONCAT_REST
//      assign tx_serial_clk[LANES-1:LANES-XREMAIN] = {XREMAIN{tx_serial_clk_per_pll[TOTAL_PLLS-1]}};
//   end

   // Following is to just show-case usage of sharing single PLL across 6 pack using MCGB o/p of PLL
   //       altera_atx_pll_a10 a10_atx_pll_inst (
   //          .pll_powerdown  (pll_powerdown), // pll_powerdown.pll_powerdown
   //          .mcgb_rst(pll_powerdown),
   //          .pll_refclk0    (src_xcvr_pll_ref_clk),   //   pll_refclk0.clk
   //          .tx_serial_clk  (), // tx_serial_clk.clk
   //          .pll_locked     (pll_locked),    //    pll_locked.pll_locked
   //          .mcgb_serial_clk (tx_serial_clk),
   //          .pll_cal_busy ()  //  pll_cal_busy.pll_cal_busy
   //       );

//   endgenerate 


   // Instantiate ATX PLL
   wire            tx_serial_clk ;
@@ if { $lanes > 6 } {  
   wire            mcgb_serial_clk ;
@@ }
   wire            serial_clk ;

   // tx_serial_clk or mcgb_serial_clk assignment
@@ if { $lanes > 6 } {
   assign serial_clk  = mcgb_serial_clk;
@@ } else { 
   assign serial_clk  = tx_serial_clk;
@@ } 

   altera_sl3_atx_pll atx_pll_inst (
      .pll_refclk0     (tx_xcvr_pll_ref_clk),   //   pll_refclk0.clk
@@ if { $lanes > 6 } {
      .mcgb_serial_clk   (mcgb_serial_clk),
      .tx_serial_clk   (), // tx_serial_clk.clk
@@ } else {
      .tx_serial_clk   (tx_serial_clk), // tx_serial_clk.clk
@@ }
      .pll_locked      (pll_locked),    //    pll_locked.pll_locked
      .pll_cal_busy    ()  //  pll_cal_busy.pll_cal_busy
   );
   
   
   //
   // Link Skew Insertion
   //
   //parameter real   data_rate_real  =  data_rate_real_val;
                                      //(data_rate == "10312.5 Mbps") ? 10312.5e6 :
                                      //(data_rate == "3125 Mbps")    ?    3125e6 : 0e0;

   skew_insertion #
   (
      .LANES(LANES),
      .ENABLE(SKEW_INSERTION_ENABLE),
      .max_skew(107)
   )
   skew_insertion_inst
   (
      .rx_serial_data(pre_skew_serial_data),
      .tx_serial_data(post_skew_serial_data)
   );

   generate
   if (DIRECTION == "Duplex") begin : duplex_inst
   //
   // Duplex Core
   //
      if (ADVANCED_CLOCKING == 1) begin : acm
   
      altera_sl3_dup duplex_inst (
      //duplex SCM FULL
         .phy_mgmt_clk        (tx_phy_mgmt_clk), // input phy_mgmt_clk (from testbench)
         .phy_mgmt_clk_reset  (tx_phy_mgmt_clk_reset), // input phy_mgmt_clk_reset (from testbench)
         .phy_mgmt_address    (tx_phy_mgmt_address), // input phy_mgmt_address
         .phy_mgmt_read       (tx_phy_mgmt_read), // input phy_mgmt_read
         .phy_mgmt_readdata   (tx_phy_mgmt_readdata), // output phy_mgmt_readdata
         .phy_mgmt_waitrequest(tx_phy_mgmt_waitrequest), // output
         .phy_mgmt_write      (tx_phy_mgmt_write), // input
         .phy_mgmt_writedata  (tx_phy_mgmt_writedata), // input
         .user_clock_tx       (tx_user_clock), // input user_clock_tx (from testbench)
         .user_clock_reset_tx (tx_user_clock_reset), // input user_clock_reset_tx (from testbench)
         .data_tx             (tx_data), // input data (from traffic_gen)
         .valid_tx            (tx_valid), // input valid (from traffic_gen)
         .link_up_tx          (tx_link_up), // output link_up_tx
         .ready_tx            (), // output 
         .error_tx            (tx_error), // output error_tx
         .err_interrupt_tx    (tx_err_interrupt), // output NEW PORT
         .tx_serial_data      (pre_skew_serial_data), // output tx_serial_data (to skew_insertion)
         .xcvr_pll_ref_clk    (rx_xcvr_pll_ref_clk), // input xcvr_pll_ref_clk
         .data_rx             (rx_data), // output data_rx (to traffic_check)
         .valid_rx            (rx_valid), // output valid_rx (to traffic_check)
         .ready_rx            (tc_enable), // input NEW PORT
         .error_rx            (rx_error), // output error_rx
         .link_up_rx          (rx_link_up), // output link_up_rx
         .rx_serial_data      (post_skew_serial_data), // input rx_serial_data (from skew_insertion)
         .err_interrupt_rx    (rx_err_interrupt), // output NEW PORT
         .tx_pll_locked       (pll_locked), // ATX PLL signal
         .tx_serial_clk       ({LANES{serial_clk}}), // ATX PLL signal
         .crc_error_inject    (6'd0),
         .sync_tx             (tx_channel), // input sync_tx
         .start_of_burst_tx    (tx_startofpacket), // input start_of_burst (from traffic gen)
         .end_of_burst_tx      (tx_endofpacket), // input end_of_burst_tx (from traffic_gen)

         .sync_rx          (rx_channel), // output sync_rx
         .start_of_burst_rx    (rx_startofpacket), // output start_of_burst_rx
         .end_of_burst_rx      (rx_endofpacket), // output end_of_burst_rx
         // ACM
         .interface_clock_rx        (rxcore_clock), // output
         .interface_clock_reset_rx  (rxcore_clock_reset) // output
   );
   
   end else begin : scm

      altera_sl3_dup duplex_inst (
      //duplex SCM FULL
         .phy_mgmt_clk        (tx_phy_mgmt_clk), // input phy_mgmt_clk (from testbench)
         .phy_mgmt_clk_reset  (tx_phy_mgmt_clk_reset), // input phy_mgmt_clk_reset (from testbench)
         .phy_mgmt_address    (tx_phy_mgmt_address), // input phy_mgmt_address
         .phy_mgmt_read       (tx_phy_mgmt_read), // input phy_mgmt_read
         .phy_mgmt_readdata   (tx_phy_mgmt_readdata), // output phy_mgmt_readdata
         .phy_mgmt_waitrequest(tx_phy_mgmt_waitrequest), // output
         .phy_mgmt_write      (tx_phy_mgmt_write), // input
         .phy_mgmt_writedata  (tx_phy_mgmt_writedata), // input
         .user_clock_tx       (tx_user_clock), // input user_clock_tx (from testbench)
         .user_clock_reset_tx (tx_user_clock_reset), // input user_clock_reset_tx (from testbench)
         .data_tx             (tx_data), // input data (from traffic_gen)
         .valid_tx            (tx_valid), // input valid (from traffic_gen)
         .link_up_tx          (tx_link_up), // output link_up_tx
         .ready_tx            (), // output 
         .error_tx            (tx_error), // output error_tx
         .err_interrupt_tx    (tx_err_interrupt), // output NEW PORT
         .tx_serial_data      (pre_skew_serial_data), // output tx_serial_data (to skew_insertion)
         .xcvr_pll_ref_clk    (rx_xcvr_pll_ref_clk), // input xcvr_pll_ref_clk
         .data_rx             (rx_data), // output data_rx (to traffic_check)
         .valid_rx            (rx_valid), // output valid_rx (to traffic_check)
         .ready_rx            (tc_enable), // input NEW PORT
         .error_rx            (rx_error), // output error_rx
         .link_up_rx          (rx_link_up), // output link_up_rx
         .rx_serial_data      (post_skew_serial_data), // input rx_serial_data (from skew_insertion)
         .err_interrupt_rx    (rx_err_interrupt), // output NEW PORT
         .tx_pll_locked       (pll_locked), // ATX PLL signal
         .tx_serial_clk       ({LANES{serial_clk}}), // ATX PLL signal
         .crc_error_inject    (6'd0),
         .sync_tx             (tx_channel), // input sync_tx
         .start_of_burst_tx    (tx_startofpacket), // input start_of_burst (from traffic gen)
         .end_of_burst_tx      (tx_endofpacket), // input end_of_burst_tx (from traffic_gen)

         .sync_rx          (rx_channel), // output sync_rx
         .start_of_burst_rx    (rx_startofpacket), // output start_of_burst_rx
         .end_of_burst_rx      (rx_endofpacket), // output end_of_burst_rx
         // SCM
         .user_clock_rx       (rx_user_clock), // input
         .user_clock_reset_rx (rx_user_clock_reset) // input
   );
   
   end
      
   end else begin : simplex_inst

   //
   // Source core
   //
      altera_sl3_tx tx_inst (
         .phy_mgmt_address(tx_phy_mgmt_address), // input
         .phy_mgmt_read(tx_phy_mgmt_read), // input
         .phy_mgmt_readdata(tx_phy_mgmt_readdata), // output
         .phy_mgmt_waitrequest(tx_phy_mgmt_waitrequest), // output
         .phy_mgmt_write(tx_phy_mgmt_write), // input
         .phy_mgmt_writedata(tx_phy_mgmt_writedata), // input
         .phy_mgmt_clk(tx_phy_mgmt_clk), // input
         .phy_mgmt_clk_reset(tx_phy_mgmt_clk_reset), // input
         .data(tx_data), // input
         .valid(tx_valid), // input
         .ready(), // output
         .link_up(tx_link_up), // output
         .err_interrupt(tx_err_interrupt), // output
         .error(tx_error), // output
         .tx_serial_data(pre_skew_serial_data), // output
         .user_clock(tx_user_clock), // input
         .user_clock_reset(tx_user_clock_reset), // input
         .tx_pll_locked          (pll_locked), // ATX PLL signal 
         .tx_serial_clk  ({LANES{serial_clk}}), // ATX PLL signal
         .crc_error_inject    (6'd0),
       .sync(tx_channel), // input
       .start_of_burst(tx_startofpacket), // input
       .end_of_burst(tx_endofpacket) // input
      );

      //
      // Sink Interlaken PHY IP management interface tie-offs
      //
      assign rx_phy_mgmt_clk        = mgmt_clk;
      assign rx_phy_mgmt_clk_reset  = rx_core_reset;
      assign rx_phy_mgmt_address    = 9'd0;
      assign rx_phy_mgmt_read       = 1'b0;
      assign rx_phy_mgmt_write      = 1'b0;
      assign rx_phy_mgmt_writedata  = 32'd0;

   if (ADVANCED_CLOCKING == 1) begin : acm
   //
   // Sink Core
   //
      altera_sl3_rx rx_inst (
         .phy_mgmt_address      (rx_phy_mgmt_address), // input
         .phy_mgmt_read         (rx_phy_mgmt_read), // input
         .phy_mgmt_readdata     (rx_phy_mgmt_readdata), // output
         .phy_mgmt_waitrequest  (rx_phy_mgmt_waitrequest), // output
         .phy_mgmt_write        (rx_phy_mgmt_write), // input
         .phy_mgmt_writedata    (rx_phy_mgmt_writedata), // input
         .phy_mgmt_clk          (rx_phy_mgmt_clk), // input
         .phy_mgmt_clk_reset    (rx_phy_mgmt_clk_reset), // input
         .data                  (rx_data), // output
         .valid                 (rx_valid),  // output
         .ready                 (tc_enable), // input
         .error                 (rx_error), // output
         .xcvr_pll_ref_clk      (rx_xcvr_pll_ref_clk), // input
         .err_interrupt         (rx_err_interrupt), // output
         .link_up               (rx_link_up), // output
         .rx_serial_data        (post_skew_serial_data), // input
         .sync                  (rx_channel), // output
         .start_of_burst        (rx_startofpacket), // output
         .end_of_burst          (rx_endofpacket), // output
       // ACM
          .interface_clock      (rxcore_clock), // output
          .interface_clock_reset(rxcore_clock_reset) // output
      );      
      
   end else begin :scm

   //
   // Sink Core
   //
      altera_sl3_rx rx_inst (
         .phy_mgmt_address      (rx_phy_mgmt_address), // input
         .phy_mgmt_read         (rx_phy_mgmt_read), // input
         .phy_mgmt_readdata     (rx_phy_mgmt_readdata), // output
         .phy_mgmt_waitrequest  (rx_phy_mgmt_waitrequest), // output
         .phy_mgmt_write        (rx_phy_mgmt_write), // input
         .phy_mgmt_writedata    (rx_phy_mgmt_writedata), // input
         .phy_mgmt_clk          (rx_phy_mgmt_clk), // input
         .phy_mgmt_clk_reset    (rx_phy_mgmt_clk_reset), // input
         .data                  (rx_data), // output
         .valid                 (rx_valid),  // output
         .ready                 (tc_enable), // input
         .error                 (rx_error), // output
         .xcvr_pll_ref_clk      (rx_xcvr_pll_ref_clk), // input
         .err_interrupt         (rx_err_interrupt), // output
         .link_up               (rx_link_up), // output
         .rx_serial_data        (post_skew_serial_data), // input
         .sync                  (rx_channel), // output
         .start_of_burst        (rx_startofpacket), // output
         .end_of_burst          (rx_endofpacket), // output
       // SCM
         .user_clock            (rx_user_clock), // input
         .user_clock_reset      (rx_user_clock_reset) // input
      );
   end

   end
   endgenerate

   //
   // Sink Traffic Checker
   traffic_check #
   (
      .LANES                    (LANES),
      .STREAM                   (STREAM)
   )
   traffic_check
   (
      // Clocks and reset
      .user_clock               (rx_user_clock),
      .user_clock_reset         (rx_user_clock_reset),

      // Traffic checker ports
      .burst_descr              (burst_descr),
      .burst_descr_read         (burst_descr_read),
      .burst_descr_ready        (burst_descr_ready),

      // Streaming data interface
      .data                     (rx_data),
      .sync                     (rx_channel),
      .empty                    (rx_empty),
      .valid                    (rx_valid),
      .start_of_burst           (rx_startofpacket),
      .end_of_burst             (rx_endofpacket),

      // Test control ports
      .tc_enable                (tc_enable),
      .tc_test_mode             (tg_test_mode),
      .tc_enable_stalls         (tg_enable_stalls),

      // Status ports
      .tc_burst_count           (tc_burst_count),
      .tc_words_received        (tc_words_transferred),

      // Status interface
      .tc_lane_swap_error       (tc_lane_swap_error),
      .tc_lane_sequence_error   (tc_lane_sequence_error),
      .tc_lane_alignment_error  (tc_lane_alignment_error)
   );

   testbench #
   (
      .USER_CLOCK_FREQUENCY     (USER_CLOCK_FREQUENCY),
      .LANES                    (LANES),
      .DIRECTION                (DIRECTION),
      .ADVANCED_CLOCKING        (ADVANCED_CLOCKING),
      .ECC_EN                   (ECC_EN),
      .LANE_SKEW_ENABLE         (SKEW_INSERTION_ENABLE),
      .TOTAL_SAMPLES_TO_TRANSFER(TOTAL_SAMPLES_TO_TRANSFER),
      .PLL_REF_FREQ             (PLL_REF_FREQ),
      .MGMT_CLK_PERIOD          (MGMT_CLK_PERIOD)
   )
   testbench
   (
      .mgmt_clk                 (mgmt_clk),
      .source_user_clock        (tx_user_clock),
      .source_user_clock_reset  (tx_user_clock_reset),
      .sink_user_clock          (tb_gen_rx_user_clock),
      .sink_user_clock_reset    (tb_gen_rx_user_clock_reset),
      .sink_pll_ref_clk         (rx_xcvr_pll_ref_clk),
      .sink_test_reset          (rx_core_reset),
      .source_pll_ref_clk       (tx_xcvr_pll_ref_clk),
      .source_test_reset        (tx_core_reset),
      .tc_enable                (tc_enable),
      .tg_enable                (tg_enable),
      .tg_test_mode             (tg_test_mode),
      .tg_enable_stalls         (tg_enable_stalls)
   );

endmodule
