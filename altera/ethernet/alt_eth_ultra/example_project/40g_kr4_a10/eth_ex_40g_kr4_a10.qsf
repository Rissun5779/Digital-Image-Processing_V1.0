
# ________________________________________________________________________________
# 	Header information
# ________________________________________________________________________________
set_global_assignment -name LAST_QUARTUS_VERSION 14.0
set_global_assignment -name TOP_LEVEL_ENTITY eth_ex_40g_kr4_a10
set_global_assignment -name VERILOG_FILE eth_ex_40g_kr4_a10.v

# ________________________________________________________________________________
# 	project settings
# ________________________________________________________________________________
source common/common_timing_settings.qsf

set_global_assignment -name QIP_FILE ../ENET_ENTITY_QMEGA_01312014/ENET_ENTITY_QMEGA_01312014.qip
set_global_assignment -name QSYS_FILE common/alt_aeuex_jtag_avalon.qsys
set_global_assignment -name QSYS_FILE common/alt_aeuex_iopll_a10.qsys
set_global_assignment -name SEARCH_PATH common/

set_global_assignment -name SDC_FILE common/common_timing_a10.sdc

set_instance_assignment -name GLOBAL_SIGNAL OFF -to "*e40_inst*twentynm_xcvr_native:g_xcvr_native_insts*inst_twentynm_hssi_rx_pld_pcs_interface|pld_pma_clkdiv_rx_user"
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "*e40_inst*twentynm_xcvr_native:g_xcvr_native_insts*inst_twentynm_hssi_rx_pld_pcs_interface|pld_pma_rx_clk_out"
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "*e40_inst*twentynm_xcvr_native:g_xcvr_native_insts*inst_twentynm_hssi_tx_pld_pcs_interface|pld_pma_tx_clk_out"

# ________________________________________________________________________________
# 	Trailer information
# ________________________________________________________________________________

set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top

