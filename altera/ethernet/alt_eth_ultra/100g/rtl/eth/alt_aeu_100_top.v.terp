  assign efc_out_rx_del_pkt = &efc_out_rx_ptp;


 wire reset_status_async;

aclr_filter reset_status_syncer_status_domain(
        .aclr     (reset_status | reset_async),         // global reset or status_reset, no domain
        .clk      (avmm_clk),     
        .aclr_sync(reset_status_async)   // reset_async and reset_status synced to clk_status 
);

  alt_aeu_100_efc_top #( 
       .SYNOPT_PREAMBLE_PASS    (SYNOPT_PREAMBLE_PASS),
       .SYNOPT_ALIGN_FCSEOP     (SYNOPT_ALIGN_FCSEOP),
       .SYNOPT_PAUSE_TYPE       (SYNOPT_PAUSE_TYPE),
       .BASE_TXFC               (BASE_TXFC),
       .BASE_RXFC               (BASE_RXFC),
       .REVID                   (REVID),
       .DWIDTH                  (DWIDTH),
       .TXDBGWIDTH              (TXDBGWIDTH),
       .RXDBGWIDTH              (RXDBGWIDTH),
       .WORDS                   (WORDS),
       .FCBITS                  (FCBITS),
       .RXERRWIDTH              (RXERRWIDTH),
       .RXSTATUSWIDTH           (RXSTATUSWIDTH),                         
       .TARGET_CHIP             (TARGET_CHIP),
       .EMPTYBITS               (6))
  efc100 (
        .clk_mm             (avmm_clk),
//        .reset_mm           (reset_status), //this input has not logic connect to it
	.reset_mm           (reset_status_async), // reset_async and reset_status synced to clk_status 
        .smm_slave_dout     (efc_s_dout),
        .smm_master_dout    (serif_m_dout),
                                         
        .clk_tx             (clk_tx_avalon),
        .reset_tx_n         (~reset_tx_avalon_r[0]),
        .tx_in_ready        (l8_tx_ready),
        .tx_in_valid        (l8_tx_valid),
        .tx_in_sop          (l8_tx_startofpacket),
        .tx_in_eop          (l8_tx_endofpacket),
        .tx_in_empty        (l8_tx_empty),
        .tx_in_data         ({tx_ptp_din,l8_tx_data}),
        .tx_in_error        (l8_tx_error),
        .tx_in_debug        (tx_in_debug),
                                         
        .tx_out_ready       (adp_in_tx_ready),
        .tx_out_valid       (efc_out_tx_valid),
        .tx_out_sop         (efc_out_tx_sop),
        .tx_out_eop         (efc_out_tx_eop),
        .tx_out_data        ({efc_out_txptp,efc_out_tx_data}),
        .tx_out_empty       (efc_out_tx_empty),
        .tx_out_error       (efc_out_tx_error),
        .tx_out_debug       (efc_out_tx_debug),
                                         
        .clk_rx             (clk_rx_avalon),
        .reset_rx_n         (~reset_rx_avalon_r[0]),
        .rx_in_ready        (adp_out_rx_ready),
        .rx_in_valid        (adp_out_rx_valid),
        .rx_in_sop          (adp_out_rx_sop),
        .rx_in_eop          (adp_out_rx_eop),
        .rx_in_data         (adp_out_rx_data),
        .rx_in_empty        (adp_out_rx_empty),
        .rx_in_error        (adp_out_rx_error),
        .rx_in_status       (adp_out_rx_status),
        .rx_in_error_valid  (adp_out_rx_error_valid),
        .rx_in_debug        (rx_in_debug),
                                         
        .rx_out_ready       (1'b1),
        .rx_out_valid       (efc_out_rx_valid),
        .rx_out_sop         (efc_out_rx_startofpacket),
        .rx_out_eop         (efc_out_rx_endofpacket),
        .rx_out_data        (efc_out_rx_data),
        .rx_out_empty       (efc_out_rx_empty),
        .rx_out_error       (efc_out_rx_fcs_error),
        .rx_out_status      (efc_out_rx_status),   
        .rx_out_error_valid (efc_out_rx_fcs_valid),
        .rx_out_debug       (efc_out_rx_ptp),
                                         
        .tx_in_pause        (tx_in_pause),
        .rx_out_pause       (rx_out_pause)
  );


   wire                ptp_v2;
   wire                ptp_s2;
   wire [31:0]         ext_lat;
//   wire [95:0]               tod_txmclk;
//   wire [95:0]               tod_rxmclk;
   wire [19:0]         txmclk_period;
   wire [18:0]             tx_asym_delay;
   wire [31:0]             tx_pma_delay;
   wire                            cust_mode;
   wire [19:0]         rxmclk_period;
   wire [31:0]             rx_pma_delay;
   
   
   defparam eck. TARGET_CHIP = TARGET_CHIP;
   defparam eck. SYNOPT_PTP = SYNOPT_PTP;
   defparam eck. CSRADDRSIZE = 8;
   defparam eck. BASE_TXPTP = BASE_TXPTP;
   defparam eck. BASE_RXPTP = BASE_RXPTP;
   defparam eck. REVID = REVID;
   
   alt_aeu_clks_100 eck 
     (
//      .reset_csr                (reset_status), 
      .reset_csr                (reset_status_async), // reset_async and reset_status synced to clk_status 
      .clk_csr                  (avmm_clk),
      .serif_master_din         (serif_m_dout),
      .serif_slave_out_ptp      (serif_slave_out_ptp),
      .rst_txmac(reset_tx_avalon_r[1]),
      .rst_rxmac(reset_rx_avalon_r[1]),

      .ptp_v2(ptp_v2),
      .ptp_s2(ptp_s2),
      .ext_lat(ext_lat),
      .txmclk_period(txmclk_period),
      .rxmclk_period(rxmclk_period),
          .tx_asym_delay(tx_asym_delay),
          .tx_pma_delay(tx_pma_delay),
          .cust_mode(cust_mode),
          .rx_pma_delay(rx_pma_delay),
      
      .clk_txmac(clk_txmac), // mac tx clk
      .clk_rxmac(clk_rxmac)  // mac rx clk
      );
   
   defparam ptr.TARGET_CHIP = TARGET_CHIP;
   defparam ptr.SYNOPT_PTP = SYNOPT_PTP;
   defparam ptr.WORDS = 8;
   defparam ptr.EMPTYBITS = 6;
   defparam ptr.SYNOPT_TOD_FMT = SYNOPT_TOD_FMT;

   wire [9:0]          dsk_av_depth;
   wire [199:0]        dsk_depths;

   alt_aeu_fifo_depth_100 fdp
  (
   .clk(clk_rxmac),
   .wpos(dsk_depths[199:0]),
   .en(20'b1110_0111_1111_1011_1101), 
   .av_depth(dsk_av_depth)
   );
   defparam fdp.SYNOPT_FULL_SKEW = SYNOPT_FULL_SKEW;


   alt_aeu_ptp_rx_100 ptr
     (
      .rst_rxmac(reset_rx_avalon_r[2]),
      .rxmclk_period(rxmclk_period),
          .rx_pma_delay(rx_pma_delay),
      .tod_rxmac_in(),
         .tod_96b_rxmac_in(rx_time_of_day_96b_data),
         .tod_64b_rxmac_in(rx_time_of_day_64b_data),
      .rxmac_sop_in(|rx_mii_start),
      .dsk_av_depth(dsk_av_depth),
//      .dsk_av_depth(5'd8),
      .din_valid(efc_out_rx_valid),
      .din(efc_out_rx_data),
      .din_sop(efc_out_rx_startofpacket),
      .din_eop(efc_out_rx_endofpacket),
      .din_empty(efc_out_rx_empty),
      .din_fcs_error(efc_out_rx_fcs_error),
      .din_rx_status(efc_out_rx_status),
      .din_fcs_valid(efc_out_rx_fcs_valid),
      .dbg_in(),
      .din_pkt_del(efc_out_rx_del_pkt),
      .dout_valid(l8_rx_valid),
      .dout(l8_rx_data),
      .dout_sop(l8_rx_startofpacket),
      .dout_eop(l8_rx_endofpacket),
      .dout_empty(l8_rx_empty),
      .dout_fcs_error(l8_rx_error),
      .dout_rx_status(l8_rx_status), 
      .dout_fcs_valid(l8_rx_fcs_valid),
      .dbg_out(),
      .rx_tod(rx_tod),
      .clk_rxmac(clk_rxmac)
      );
   
           defparam ptr.TARGET_CHIP = TARGET_CHIP;
           defparam ptr.SYNOPT_CAUI4 = SYNOPT_CAUI4;
           defparam ptr.SYNOPT_LINK_FAULT = SYNOPT_LINK_FAULT;
           defparam ptr.RXERRWIDTH = RXERRWIDTH;
 // _____________________________________________________________________________      
//      8word to 4word adapter interfacing the custom-st and 
//      the avalon-st interfaces on the two sides of this module
 // _____________________________________________________________________________      
  wire dout_valid_adp;

  wire [MACWORDS-1:0] dout_sop_adp;
  wire [MACWORDS-1:0] dout_eop_adp;
  wire [MACWORDS-1:0] dout_idle_adp;
  wire [MACWORDS*64-1:0] dout_d_adp;
  wire [MACWORDS*03-1:0] dout_eop_empty_adp;
  wire                din_req_adp;    

  wire [MACWORDS-1:0]    rsk_out_tx4l_idle_1,rsk_out_tx4l_idle_2;// bytes between EOP and SOP
  wire [MACWORDS-1:0]    rsk_out_tx4l_sop_1,rsk_out_tx4l_sop_2; // word contains first data (on leftmost byte)
  wire [MACWORDS-1:0]    rsk_out_tx4l_eop_1,rsk_out_tx4l_eop_2; // byte position of last data
  wire [MACWORDS-1:0]    rsk_out_tx4l_error_1,rsk_out_tx4l_error_2; 
  wire [MACWORDS*64-1:0] rsk_out_tx4l_data_1,rsk_out_tx4l_data_2;  // data, read left to right
  wire [MACWORDS*03-1:0] rsk_out_tx4l_eop_empty_1,rsk_out_tx4l_eop_empty_2;     // byte position of last data

  wire  rsk_out_tx4l_req_1,rsk_out_tx4l_req_2;
  wire [MACWORDS-1:0]    adp_out_tx4l_sop; // word contains first data (on leftmost byte)
  wire [MACWORDS-1:0]    adp_out_tx4l_eop; // byte position of last data
  wire [MACWORDS-1:0]    adp_out_tx4l_error;    
  wire [MACWORDS-1:0]    adp_out_tx4l_idle;// bytes between EOP and SOP
  wire [MACWORDS*64-1:0] adp_out_tx4l_data;// data, read left to right
  wire [MACWORDS*03-1:0] adp_out_tx4l_eop_empty;        // byte position of last data
  
generate
if (SYNOPT_AVALON) begin
  localparam ASKWIDTH = MACWORDS*(1+1+1+1+64+3);
  alt_aeu_100_ack_skid #(.WIDTH(ASKWIDTH))
  ask1 (
      .clk(clk_txmac_4),
      .ack_i(rsk_out_tx4l_req_2),       
      .dat_i({rsk_out_tx4l_idle_2, rsk_out_tx4l_eop_2, rsk_out_tx4l_error_2, rsk_out_tx4l_data_2, rsk_out_tx4l_eop_empty_2, rsk_out_tx4l_sop_2}),
      
      .ack_o(din_req_adp),
      .dat_o({rsk_out_tx4l_idle_1, rsk_out_tx4l_eop_1, rsk_out_tx4l_error_1, rsk_out_tx4l_data_1, rsk_out_tx4l_eop_empty_1, rsk_out_tx4l_sop_1})
      );
  alt_aeu_100_ack_skid #(.WIDTH(ASKWIDTH))
  ask2 (
      .clk(clk_txmac_4),
      .ack_i(rsk_out_tx4l_req_1),       
      .dat_i({adp_out_tx4l_idle, adp_out_tx4l_eop, adp_out_tx4l_error, adp_out_tx4l_data, adp_out_tx4l_eop_empty, adp_out_tx4l_sop}),
      
      .ack_o(rsk_out_tx4l_req_2),
      .dat_o({rsk_out_tx4l_idle_2, rsk_out_tx4l_eop_2, rsk_out_tx4l_error_2, rsk_out_tx4l_data_2, rsk_out_tx4l_eop_empty_2, rsk_out_tx4l_sop_2})
      );



  e100_adapter_4 ast_8w (
        .l8_tx_ready            (adp_in_tx_ready),
        .l8_tx_valid            (efc_out_tx_valid),
        .l8_tx_startofpacket    (efc_out_tx_sop),
        .l8_tx_endofpacket      (efc_out_tx_eop),
        .l8_tx_data             (efc_out_tx_data),
        .l8_tx_empty            (efc_out_tx_empty),
        .l8_tx_error            (efc_out_tx_error),

        .l8_rx_valid            (adp_out_rx_valid),
        .l8_rx_startofpacket    (adp_out_rx_sop),
        .l8_rx_endofpacket      (adp_out_rx_eop),
        .l8_rx_data             (adp_out_rx_data),
        .l8_rx_empty            (adp_out_rx_empty),
        .l8_rx_error            (adp_out_rx_error),
        .l8_rx_status           (adp_out_rx_status),
        .l8_rx_fcs_valid        (adp_out_rx_error_valid),
        .l8_rx_fcs_error        (),             // not to be used

        .clk_txmac              (clk_txmac_4),
        .tx_arst                (reset_tx|reset_async),
        .tx4l_ack               (rsk_out_tx4l_req_1),   // rsk backpressure
        .tx4l_idle              (adp_out_tx4l_idle),
        .tx4l_sop               (adp_out_tx4l_sop),
        .tx4l_eop               (adp_out_tx4l_eop),
        .tx4l_d                 (adp_out_tx4l_data),
        .tx4l_eop_empty         (adp_out_tx4l_eop_empty),
        .tx4l_error             (adp_out_tx4l_error),
        
        .clk_rxmac              (clk_rxmac_4),          // MAC + PCS clock - at least 312.5Mhz
        .rx_arst                (reset_async | reset_rx | ~rx_pcs_fully_aligned),
        .rx4l_d                 (dout_d_adp),           // 4 lane payload to send
        .rx4l_sop               (dout_sop_adp),         // 4 lane start position
        .rx4l_idle              (dout_idle_adp),        // 4 lane idle position
        .rx4l_eop               (dout_eop_adp),         // 4 lane end position any byte
        .rx4l_error             (mac_rx_error),         // 
        .rx4l_status            (mac_rx_status),        
        .rx4l_fcs_valid         (rx_fcs_valid),         // 
        .rx4l_valid             (dout_valid_adp),       // 
        .rx4l_eop_empty         (dout_eop_empty_adp)    // 4 lane # of empty bytes
  );
  defparam ast_8w.TARGET_CHIP = TARGET_CHIP;
  defparam ast_8w.SYNOPT_ALIGN_FCSEOP = SYNOPT_ALIGN_FCSEOP;
  defparam ast_8w.RXERRWIDTH = RXERRWIDTH;
  defparam ast_8w.RXSTATUSWIDTH = RXSTATUSWIDTH;

  
end

assign din_sop_w           = (SYNOPT_AVALON)  ? rsk_out_tx4l_sop_1         : din_sop;
assign din_eop_w           = (SYNOPT_AVALON)  ? rsk_out_tx4l_eop_1         : din_eop;   
assign din_error_w         = (SYNOPT_AVALON)  ? rsk_out_tx4l_error_1       : tx_error;   
assign din_idle_w          = (SYNOPT_AVALON)  ? rsk_out_tx4l_idle_1        : din_idle;  
assign din_eop_empty_w     = (SYNOPT_AVALON)  ? rsk_out_tx4l_eop_empty_1   : din_eop_empty;     
assign din_w               = (SYNOPT_AVALON)  ? rsk_out_tx4l_data_1        : din;
assign din_req_adp         = (SYNOPT_AVALON)  ? din_req_w                  : 1'b0;
assign dout_valid_adp      = (SYNOPT_AVALON)  ? dout_valid_w               : 1'b0;
assign dout_d_adp          = (SYNOPT_AVALON)  ? dout_d_w                   : 256'b0;
assign dout_sop_adp        = (SYNOPT_AVALON)  ? dout_sop_w                 : 4'b0;
assign dout_eop_adp        = (SYNOPT_AVALON)  ? dout_eop_w                 : 4'b0;
assign dout_eop_empty_adp  = (SYNOPT_AVALON)  ? dout_eop_empty_w           : 12'b0;
assign dout_idle_adp       = (SYNOPT_AVALON)  ? dout_idle_w                : 4'b0;
assign din_req             = (SYNOPT_AVALON == 0) ? din_req_w                  : 1'b0;
assign dout_valid          = (SYNOPT_AVALON == 0) ? dout_valid_w               : 1'b0;
assign dout_d              = (SYNOPT_AVALON == 0) ? dout_d_w                   : 256'b0;
assign dout_c              = (SYNOPT_AVALON == 0) ? dout_c_w                   : 32'b0;
assign dout_sop            = (SYNOPT_AVALON == 0) ? dout_sop_w                 : 4'b0;
assign dout_eop            = (SYNOPT_AVALON == 0) ? dout_eop_w                 : 4'b0;
assign dout_eop_empty      = (SYNOPT_AVALON == 0) ? dout_eop_empty_w           : 12'b0;
assign dout_idle           = (SYNOPT_AVALON == 0) ? dout_idle_w                : 4'b0;
assign rx_error            = (SYNOPT_AVALON == 0) ? mac_rx_error               : {RXERRWIDTH{1'b0}};
assign rx_status           = (SYNOPT_AVALON == 0) ? mac_rx_status              : {RXSTATUSWIDTH{1'b0}};   

endgenerate


//------------------------------------------------------------------------------         
//      100G Ethernet module including MAC and PHY submodules
//------------------------------------------------------------------------------         
   alt_aeu_100_eth_4 #( 
        .SYNOPT_CAUI4           (SYNOPT_CAUI4) 
       ,.SYNOPT_C4_RSFEC        (SYNOPT_C4_RSFEC)
       ,.REVID                  (REVID)
       ,.PHY_REFCLK             (PHY_REFCLK)
       ,.SYNOPT_FULL_SKEW       (SYNOPT_FULL_SKEW) 
       ,.SYNOPT_MAC_RXSTATS     (SYNOPT_MAC_RXSTATS) 
       ,.SYNOPT_MAC_TXSTATS     (SYNOPT_MAC_TXSTATS) 
       ,.SYNOPT_ALIGN_FCSEOP    (SYNOPT_ALIGN_FCSEOP) 
       ,.SYNOPT_PREAMBLE_PASS   (SYNOPT_PREAMBLE_PASS) 
       ,.BASE_PHY               (BASE_RXPHY) // not split in tx and rx yet
       ,.BASE_TXMAC             (BASE_TXMAC)
       ,.BASE_RXMAC             (BASE_RXMAC)
       ,.BASE_TXSTAT            (BASE_TXSTAT)
       ,.BASE_RXSTAT            (BASE_RXSTAT)
       ,.BASE_TXFEC             (BASE_TXFEC)
       ,.BASE_RXFEC             (BASE_RXFEC)
       ,.SYNOPT_AVG_IPG         (SYNOPT_AVG_IPG)
       ,.TIMING_MODE            (TIMING_MODE)
       ,.EXT_TX_PLL             (EXT_TX_PLL)
  )e100 (
        .clk_ref_r              (clk_ref),
        .etx_pin                (tx_serial),
        .erx_pin                (rx_serial),
        
        .TX_CORE_CLK(TX_CORE_CLK),
        .RX_CORE_CLK(RX_CORE_CLK),

        //Sync-E
        .clk_rx_recover         (clk_rx_recover), 
         
        // CSR access
        .avmm_clk               (avmm_clk),
        .avmm_reset             (reset_status | reset_async), //global reset, async, syncer in submodule 
	.reset_status_async	(reset_status_async),      // reset_async and reset_status synced to clk_status         
        .e100_slave_dout        (e100_slave_dout),
        .pcs_slave_din          (serif_m_dout),

        // no connect tx cgmii interface                
        .pcs_din_am             (),   
        .pcs_din_c              (),     
        .pcs_din_d              (),     
        .tx_lanes_stable        (tx_lanes_stable),

        // from the adapter                
        .srst_tx_main           (reset_tx),
        .clk_txmac_in           (clk_txmac_in),
        .clk_tx_main            (clk_txmac_4),          
        .din_sop                (din_sop_w),            
        .din_eop                (din_eop_w),    
        .din_idle               (din_idle_w),   
        .din_eop_empty          (din_eop_empty_w), 
        .din                    (din_w),                
        .din_req                (din_req_w),            
        .din_bus_error          (),
        .tx_error               (din_error_w),
                 
        .clk_rx_main            (clk_rxmac_4),
        .srst_rx_main           (reset_rx),
        .dout_valid             (dout_valid_w),
        .dout_d                 (dout_d_w),
        .dout_c                 (dout_c_w),
        .dout_sop               (dout_sop_w),
        .dout_eop               (dout_eop_w),
        .dout_eop_empty         (dout_eop_empty_w),
        .dout_idle              (dout_idle_w),
        .rx_fcs_error           (rx_fcs_error),  // referring to the non-zero last_data
        .rx_error               (mac_rx_error),
        .rx_status              (mac_rx_status),
        .rx_fcs_valid           (rx_fcs_valid),
        .rx_pcs_fully_aligned   (rx_pcs_fully_aligned),
        .unidirectional_en      (unidirectional_en),
        .link_fault_gen_en      (link_fault_gen_en),
        .remote_fault_status    (remote_fault_status),
        .local_fault_status     (local_fault_status),
        .rx_mii_start           (rx_mii_start),
        .tx_mii_start           (tx_mii_start),
        .dsk_depths             (dsk_depths),

//         .tod_96b_txmac_in(tod_txmac_in),
//         .tod_64b_txmac_in(tod_txmac_in[79:16]),
         .tod_96b_txmac_in(tx_time_of_day_96b_data),
         .tod_64b_txmac_in(tx_time_of_day_64b_data),
                 .txmclk_period(txmclk_period),
                 .tx_asym_delay(tx_asym_delay),
                 .tx_pma_delay(tx_pma_delay),
                 .cust_mode(cust_mode),
//        .ptp_v2                 (ptp_v2),
//        .ptp_s2                 (ptp_s2),
        .ext_lat                (ext_lat),
        .din_ptp_dbg_adp        (efc_out_tx_debug),
        .din_sop_adp            ((|efc_out_tx_sop) & adp_in_tx_ready & efc_out_tx_valid),
//        .din_ptp_adp            (efc_out_tx_ptp),
//        .din_overwrite_adp      (efc_out_tx_overwrite),
//        .din_offset_adp         (efc_out_tx_offset),
//        .din_zero_tcp_adp       (efc_out_tx_zero_tcp),
//        .din_zero_offset_adp    (efc_out_tx_tcp_offset),
                 .ts_offset_adp(ts_offset_adp),
                 .corr_offset_adp(corr_offset_adp),
                 .chk_sum_zero_offset_adp(chk_sum_zero_offset_adp),
                 .chk_sum_upd_offset_adp(chk_sum_upd_offset_adp),
        .ts_out_cust_asm        (ts_out_cust_asm),
        .tod_cust_in            (tod_cust_in),
        .tod_exit_cust          (tod_exit_cust),
        .ts_out_cust            (ts_out_cust),
 
                 .fp_out_req_adp(fp_out_req_adp),
                 .ts_out_req_adp(ts_out_req_adp),
                 .ing_ts_96_adp(ing_ts_96_adp),
                 .ing_ts_64_adp(ing_ts_64_adp),
                 .ins_ts_adp(ins_ts_adp),
                 .ins_ts_format_adp(ins_ts_format_adp),
                         .tx_asym_adp(tx_asym_adp),
                 .upd_corr_adp(upd_corr_adp),
                 .chk_sum_zero_adp(chk_sum_zero_adp),
                 .chk_sum_upd_adp(chk_sum_upd_adp),
                 .corr_format_adp(corr_format_adp),
         .din_ptp_asm_adp(efc_out_tx_ptp_asm),

                 .ts_exit(ts_exit),
                 .ts_exit_valid(ts_exit_valid),
                 .fp_out(fp_out),

         
        // no connect (pipelined rx cgmii signals)                
        .rx_data_out_valid      (),                     
        .rx_data_out            (),
        .rx_ctl_out             (),
        .rx_first_data          (),
        .rx_last_data           (),

        .out_tx_stats           (out_tx_stats),
        .out_rx_stats           (out_rx_stats),
        .tx_inc_octetsOK        (tx_inc_octetsOK),
        .tx_inc_octetsOK_valid  (tx_inc_octetsOK_valid),
        .rx_inc_octetsOK        (rx_inc_octetsOK ),
        .rx_inc_octetsOK_valid          (rx_inc_octetsOK_valid),
                
        .reconfig_clk           (reconfig_clk),                 //input  wire [0:0]   
        .reconfig_reset         (reconfig_reset),               //input  wire [0:0]   
        .reconfig_write         (reconfig_write),               //input  wire [0:0]   
        .reconfig_read          (reconfig_read),                //input  wire [0:0]   
        .reconfig_address       (reconfig_address),             //input  wire [11:0]  
        .reconfig_writedata     (reconfig_writedata),           //input  wire [31:0]  
        .reconfig_readdata      (reconfig_readdata),            //output wire [31:0]  
        .reconfig_waitrequest   (reconfig_waitrequest),         //output wire [0:0]   
        .tx_serial_clk          (tx_serial_clk),
        .tx_pll_locked          (tx_pll_locked),
        .reconfig_to_xcvr       (reconfig_to_xcvr),
        .reconfig_from_xcvr     (reconfig_from_xcvr),
        .reconfig_busy          (reconfig_busy)
                
                
  );
  defparam e100 .TARGET_CHIP = TARGET_CHIP;
  defparam e100 .SYNOPT_PTP = SYNOPT_PTP;
   defparam e100 .SYNOPT_TOD_FMT = SYNOPT_TOD_FMT;
  defparam e100 .SYNOPT_LINK_FAULT = SYNOPT_LINK_FAULT;
  defparam e100 .SYNOPT_TXCRC_INS = SYNOPT_TXCRC_INS;
  defparam e100 .SYNOPT_MAC_DIC = SYNOPT_MAC_DIC;
  defparam e100 .SIM_FAKE_JTAG = SIM_FAKE_JTAG;
  defparam e100 .AM_CNT_BITS = AM_CNT_BITS;  // 14 nom, 6 Ok for sim
  defparam e100 .RST_CNTR = RST_CNTR;   // nominal 16/20  or 6 for fast simulation of reset seq
  defparam e100 .CREATE_TX_SKEW = CREATE_TX_SKEW;
  defparam e100 .RXERRWIDTH = RXERRWIDTH;
  defparam e100 .RXSTATUSWIDTH = RXSTATUSWIDTH; 
  defparam e100.PTP_FP_WIDTH = PTP_FP_WIDTH;
//  defparam e100.PTP_TS_WIDTH = PTP_TS_WIDTH;
  defparam e100 .SYNOPT_STRICT_SOP = SYNOPT_STRICT_SOP;

assign l8_rx_fcs_error = l8_rx_error[1];


endmodule 


