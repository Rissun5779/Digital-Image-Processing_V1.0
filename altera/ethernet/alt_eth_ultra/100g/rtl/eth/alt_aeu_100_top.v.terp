                                                chk_sum_zero_offset,
                                                chk_sum_upd_offset,
                                                tx_in_ptp_asm
                                                };
   

  wire[TXDBGWIDTH-1:0] efc_out_tx_debug;
  wire[RXDBGWIDTH-1:0] rx_out_debug;
  wire[RXDBGWIDTH-1:0] efc_out_rx_ptp;
  wire[TXDBGWIDTH-1:0] tx_in_debug = {TXDBGWIDTH{1'b0}};
  wire[RXDBGWIDTH-1:0] rx_in_debug = {RXDBGWIDTH{1'b0}};

