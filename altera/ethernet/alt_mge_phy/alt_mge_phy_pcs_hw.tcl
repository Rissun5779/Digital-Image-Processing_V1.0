proc qsynth_proc { none } {
    
    # PCS RTL
    global pcs_rtl_files
    
    foreach {file_name filetype} $pcs_rtl_files {
        add_fileset_file $file_name $filetype PATH rtl/$file_name
    }
    
    # Standard Synchronizer
    set std_sync_path [file join .. .. primitives altera_std_synchronizer altera_std_synchronizer_nocut.v]
    add_fileset_file altera_std_synchronizer_nocut.v VERILOG PATH $std_sync_path
    
    # OCP
    add_fileset_file alt_mge_phy_pcs.ocp OTHER PATH rtl/alt_mge_phy_pcs.ocp
    
    # SDC
    if {[_is_gmii16b_pcs]} {
        add_fileset_file alt_mge_phy_gmii_pcs.sdc SDC PATH alt_mge_phy_gmii_pcs.sdc
    }
    
    if {[_is_xgmii64b_pcs]} {
        add_fileset_file alt_mge_phy_xgmii_pcs.sdc SDC PATH alt_mge_phy_xgmii_pcs.sdc
    }
    
    if {[_is_usxgmii32b_pcs]} {
        add_fileset_file alt_mge_phy_usxg32_pcs.sdc SDC PATH alt_mge_phy_usxg32_pcs.sdc
    }
    
    # SignalTap Debug
    add_fileset_file debug/stp/build_stp.tcl OTHER PATH debug/stp/build_stp.tcl
    add_fileset_file debug/stp/base_stp_1G2p5G10GPHY.xml OTHER PATH debug/stp/base_stp_1G2p5G10GPHY.xml.txt
}

