proc elaborate {} {
    set enable_ieee1588 [get_parameter_value ENABLE_IEEE1588]
    
    set_parameter_value IS_2P5G [_is_2p5g]
    set_parameter_value IS_1G_2P5G [_is_1g_2p5g]
    set_parameter_value IS_1G_10G [_is_1g_10g]
    set_parameter_value IS_MGBASE_T [_is_mgbaset]
    set_parameter_value IS_10G_USXGMII [_is_10g_usxgmii]
    
    if {[_is_2p5g] || [_is_1g_2p5g]} {
        add_interface_port avalon_mm_csr csr_readdata readdata Output 16
        add_interface_port avalon_mm_csr csr_writedata writedata Input 16
        add_interface_port avalon_mm_csr csr_address address Input 5
    } else {
        add_interface_port avalon_mm_csr csr_readdata readdata Output 32
        add_interface_port avalon_mm_csr csr_writedata writedata Input 32
        add_interface_port avalon_mm_csr csr_address address Input 11
    }
    add_interface_port avalon_mm_csr csr_waitrequest waitrequest Output 1
    add_interface_port avalon_mm_csr csr_read read Input 1
    add_interface_port avalon_mm_csr csr_write write Input 1
    
    if {[_is_gmii16b_pcs]} {
        set_interface_property tx_gmii16b_en ENABLED true
        set_interface_property tx_gmii16b_d ENABLED true
        set_interface_property tx_gmii16b_err ENABLED true
        
        set_interface_property rx_gmii16b_dv ENABLED true
        set_interface_property rx_gmii16b_d ENABLED true
        set_interface_property rx_gmii16b_err ENABLED true
        
        set_interface_property tx_basex_datak ENABLED true
        set_interface_property tx_basex_parallel_data ENABLED true
        
        set_interface_property rx_basex_datak ENABLED true
        set_interface_property rx_basex_parallel_data ENABLED true
        
        set_interface_property led_link ENABLED true
        set_interface_property led_char_err ENABLED true
        set_interface_property led_disp_err ENABLED true
        
        set_interface_property rx_syncstatus ENABLED true
        set_interface_property rx_runningdisp ENABLED true
        set_interface_property rx_disperr ENABLED true
        set_interface_property rx_errdetect ENABLED true
        set_interface_property rx_patterndetect ENABLED true
        set_interface_property rx_std_bitslipboundarysel ENABLED true
        
        if {($enable_ieee1588 == 1)} {
            set_interface_property latency_measure_clk ENABLED true
            set_interface_property tx_gmii16b_latency ENABLED true
            set_interface_property rx_gmii16b_latency ENABLED true
        } else {
            set_port_property latency_measure_clk TERMINATION 1
            set_port_property latency_measure_clk TERMINATION_VALUE 0
        }
    } else {
        set_port_property tx_gmii16b_en TERMINATION 1
        set_port_property tx_gmii16b_en TERMINATION_VALUE 0
        set_port_property tx_gmii16b_d TERMINATION 1
        set_port_property tx_gmii16b_d TERMINATION_VALUE 0
        set_port_property tx_gmii16b_err TERMINATION 1
        set_port_property tx_gmii16b_err TERMINATION_VALUE 0
        
        set_port_property rx_basex_datak TERMINATION 1
        set_port_property rx_basex_datak TERMINATION_VALUE 0
        set_port_property rx_basex_parallel_data TERMINATION 1
        set_port_property rx_basex_parallel_data TERMINATION_VALUE 0
        
        set_port_property rx_syncstatus TERMINATION 1
        set_port_property rx_syncstatus TERMINATION_VALUE 0
        set_port_property rx_runningdisp TERMINATION 1
        set_port_property rx_runningdisp TERMINATION_VALUE 0
        set_port_property rx_disperr TERMINATION 1
        set_port_property rx_disperr TERMINATION_VALUE 0
        set_port_property rx_errdetect TERMINATION 1
        set_port_property rx_errdetect TERMINATION_VALUE 0
        set_port_property rx_patterndetect TERMINATION 1
        set_port_property rx_patterndetect TERMINATION_VALUE 0
        set_port_property rx_std_bitslipboundarysel TERMINATION 1
        set_port_property rx_std_bitslipboundarysel TERMINATION_VALUE 0
    }
    
    if {[_is_1g_10g] || [_is_mgbaset] || [_is_10g_usxgmii]} {
        
        set_interface_property tx_xgmii_clk         ENABLED true
        set_interface_property rx_xgmii_clk         ENABLED true
        
        set_interface_property tx_xgmii_control_in  ENABLED true
        set_interface_property tx_xgmii_data_in     ENABLED true
        
        set_interface_property tx_xgmii_valid_out   ENABLED true
        set_interface_property tx_xgmii_control_out ENABLED true
        set_interface_property tx_xgmii_data_out    ENABLED true
        
        set_interface_property rx_xgmii_valid_in    ENABLED true
        set_interface_property rx_xgmii_control_in  ENABLED true
        set_interface_property rx_xgmii_data_in     ENABLED true
        
        set_interface_property rx_xgmii_control_out ENABLED true
        set_interface_property rx_xgmii_data_out    ENABLED true
        
        set_interface_property rx_block_lock_in     ENABLED true
        set_interface_property rx_block_lock_out    ENABLED true
        
        if {[_is_10g_usxgmii]} {
            set_interface_property tx_xgmii_valid_in    ENABLED true
            set_interface_property rx_xgmii_valid_out   ENABLED true
            
            set_port_property tx_xgmii_control_in WIDTH_EXPR 4
            set_port_property tx_xgmii_data_in WIDTH_EXPR 32
            
            set_port_property rx_xgmii_control_out WIDTH_EXPR 4
            set_port_property rx_xgmii_data_out WIDTH_EXPR 32
        } else {
            set_port_property tx_xgmii_valid_in TERMINATION 1
            set_port_property tx_xgmii_valid_in TERMINATION_VALUE 1
            
            set_port_property tx_xgmii_control_in WIDTH_EXPR 8
            set_port_property tx_xgmii_data_in WIDTH_EXPR 64
            
            set_port_property rx_xgmii_control_out WIDTH_EXPR 8
            set_port_property rx_xgmii_data_out WIDTH_EXPR 64
        }
        
        if {($enable_ieee1588 == 1)} {
            set_interface_property tx_xgmii_latency ENABLED true
            set_interface_property rx_xgmii_latency ENABLED true
        }
        
    } else {
        set_port_property tx_xgmii_clk TERMINATION 1
        set_port_property tx_xgmii_clk TERMINATION_VALUE 0
        
        set_port_property rx_xgmii_clk TERMINATION 1
        set_port_property rx_xgmii_clk TERMINATION_VALUE 0
        
        set_port_property tx_xgmii_valid_in TERMINATION 1
        set_port_property tx_xgmii_valid_in TERMINATION_VALUE 0
        set_port_property tx_xgmii_control_in TERMINATION 1
        set_port_property tx_xgmii_control_in TERMINATION_VALUE 0
        set_port_property tx_xgmii_data_in TERMINATION 1
        set_port_property tx_xgmii_data_in TERMINATION_VALUE 0
        
        set_port_property rx_xgmii_valid_in TERMINATION 1
        set_port_property rx_xgmii_valid_in TERMINATION_VALUE 0
        set_port_property rx_xgmii_control_in TERMINATION 1
        set_port_property rx_xgmii_control_in TERMINATION_VALUE 0
        set_port_property rx_xgmii_data_in TERMINATION 1
        set_port_property rx_xgmii_data_in TERMINATION_VALUE 0
        
        set_port_property rx_block_lock_in TERMINATION 1
        set_port_property rx_block_lock_in TERMINATION_VALUE 0
    }
    
}

# ################################################################################################
# Validate
# ################################################################################################
proc validate {} {
   validate_version
}

# ##################################################################################
# Called during validate callback to calculate the core_version 
# and dev_version value
# ##################################################################################
proc validate_version {} {

   set version_val [get_module_property VERSION]
   set version_items [split $version_val "."]
   set version_num [lindex $version_items 0]
   set version_dot_num [lindex $version_items 1]

   set version_number [expr [expr $version_num << 8] | [expr $version_dot_num << 0] ]
   
   set_parameter_value DEV_VERSION $version_number
}

