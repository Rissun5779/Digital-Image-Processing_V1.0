    add_interface_port rx_seriallpbken_out rx_seriallpbken_out rx_seriallpbken Output 1
    
    # Transceiver Mode from Reconfig
    add_interface xcvr_mode_in conduit end
    set_interface_property xcvr_mode_in ENABLED true
    add_interface_port xcvr_mode_in xcvr_mode_in export Input 2
    
    add_interface xcvr_mode_out conduit start
    set_interface_property xcvr_mode_out ENABLED true
    add_interface_port xcvr_mode_out xcvr_mode_out export Output 2
    
    if {[_is_2p5g] || [_is_1g_2p5g] || [_is_1g_10g] || [_is_mgbaset]} {
        # 2.5G
        # 1G/2.5G
        # 1G/10G
        # 1G/2.5G/5G/10G (MGBASE-T)
        set_interface_property xcvr_mode_in ENABLED true
    } else {
        set_interface_property xcvr_mode_in ENABLED false
        set_port_property xcvr_mode_in TERMINATION 1
        set_port_property xcvr_mode_in TERMINATION_VALUE 3
    }
    
    # TX BASE-X PCS Data Path
    add_interface tx_basex_datak conduit end
    set_interface_property tx_basex_datak ENABLED false
    add_interface_port tx_basex_datak tx_basex_datak tx_datak Input 2
    
    add_interface tx_basex_parallel_data conduit end
    set_interface_property tx_basex_parallel_data ENABLED false
    add_interface_port tx_basex_parallel_data tx_basex_parallel_data tx_parallel_data Input 16
    
    # RX BASE-X PCS Data Path
    add_interface rx_basex_datak conduit start
    set_interface_property rx_basex_datak ENABLED false
    add_interface_port rx_basex_datak rx_basex_datak rx_datak Output 2
    
    add_interface rx_basex_parallel_data conduit start
    set_interface_property rx_basex_parallel_data ENABLED false
    add_interface_port rx_basex_parallel_data rx_basex_parallel_data rx_parallel_data Output 16
    
    # RX BASE-X PCS Status
    add_interface rx_syncstatus_a10 conduit start
    set_interface_property rx_syncstatus_a10 ENABLED false
    add_interface_port rx_syncstatus_a10 rx_syncstatus_a10 rx_syncstatus Output 2
    
    add_interface rx_runningdisp_a10 conduit start
    set_interface_property rx_runningdisp_a10 ENABLED false
    add_interface_port rx_runningdisp_a10 rx_runningdisp_a10 rx_runningdisp Output 2
    
    add_interface rx_disperr_a10 conduit start
    set_interface_property rx_disperr_a10 ENABLED false
    add_interface_port rx_disperr_a10 rx_disperr_a10 rx_disperr Output 2
    
    add_interface rx_errdetect_a10 conduit start
    set_interface_property rx_errdetect_a10 ENABLED false
    add_interface_port rx_errdetect_a10 rx_errdetect_a10 rx_errdetect Output 2
    
    add_interface rx_patterndetect_a10 conduit start
    set_interface_property rx_patterndetect_a10 ENABLED false
    add_interface_port rx_patterndetect_a10 rx_patterndetect_a10 rx_patterndetect Output 2
    
    if {[_is_device_family "Arria 10"]} {
        if {[_is_gmii16b_pcs]} {
            set_interface_property tx_basex_datak ENABLED true
            set_interface_property tx_basex_parallel_data ENABLED true
            set_interface_property rx_basex_datak ENABLED true
            set_interface_property rx_basex_parallel_data ENABLED true
            
            set_interface_property rx_syncstatus_a10 ENABLED true
            set_interface_property rx_runningdisp_a10 ENABLED true
            set_interface_property rx_disperr_a10 ENABLED true
            set_interface_property rx_errdetect_a10 ENABLED true
            set_interface_property rx_patterndetect_a10 ENABLED true
        } else {
            set_interface_property tx_basex_datak ENABLED false
            set_interface_property tx_basex_parallel_data ENABLED false
            set_interface_property rx_basex_datak ENABLED false
            set_interface_property rx_basex_parallel_data ENABLED false
            
            set_interface_property rx_syncstatus_a10 ENABLED false
            set_interface_property rx_runningdisp_a10 ENABLED false
            set_interface_property rx_disperr_a10 ENABLED false
            set_interface_property rx_errdetect_a10 ENABLED false
            set_interface_property rx_patterndetect_a10 ENABLED false
        }
    }
    
    # TX BASE-R PCS Data Path
    add_interface tx_baser_control conduit end
    add_interface_port tx_baser_control tx_baser_control export Input 8
    
    add_interface tx_baser_parallel_data conduit end
    add_interface_port tx_baser_parallel_data tx_baser_parallel_data export Input 64
    
    add_interface tx_baser_data_valid conduit end
    add_interface_port tx_baser_data_valid tx_baser_data_valid export Input 1
    
    # RX BASE-R PCS Data Path
    add_interface rx_baser_control conduit start
    add_interface_port rx_baser_control rx_baser_control export Output 8
    
    add_interface rx_baser_control_fec conduit start
    add_interface_port rx_baser_control_fec rx_baser_control_fec export Output 2
    
    add_interface rx_baser_parallel_data conduit start
    add_interface_port rx_baser_parallel_data rx_baser_parallel_data export Output 64
    
    add_interface rx_baser_data_valid conduit start
    add_interface_port rx_baser_data_valid rx_baser_data_valid export Output 1
    
    # RX BASE-R PCS Status
    add_interface rx_enh_blk_lock_in conduit end
    add_interface_port rx_enh_blk_lock_in rx_enh_blk_lock_in rx_enh_blk_lock Input 1
    
    add_interface rx_enh_blk_lock_out conduit start
    add_interface_port rx_enh_blk_lock_out rx_enh_blk_lock_out rx_enh_blk_lock Output 1
    
    if {[_is_xgmii64b_pcs]} {
        set_interface_property tx_baser_control ENABLED true
        set_interface_property tx_baser_parallel_data ENABLED true
        set_interface_property rx_baser_control ENABLED true
        set_interface_property rx_baser_control_fec ENABLED false
        set_interface_property rx_baser_parallel_data ENABLED true
        set_interface_property rx_enh_blk_lock_in ENABLED true
        set_interface_property rx_enh_blk_lock_out ENABLED true
        
        if {$baser_reg_mode == 0} {
            set_interface_property tx_baser_data_valid ENABLED false
            set_interface_property rx_baser_data_valid ENABLED false
        } else {
            set_interface_property tx_baser_data_valid ENABLED true
            set_interface_property rx_baser_data_valid ENABLED true
        }
    } elseif {[_is_usxgmii32b_pcs]} {
        set_interface_property tx_baser_control ENABLED true
        set_interface_property tx_baser_parallel_data ENABLED true
        set_interface_property rx_baser_control ENABLED true
        set_interface_property rx_baser_control_fec ENABLED false
        set_interface_property rx_baser_parallel_data ENABLED true
        set_interface_property rx_enh_blk_lock_in ENABLED true
        set_interface_property rx_enh_blk_lock_out ENABLED true
        set_interface_property tx_baser_data_valid ENABLED true
        set_interface_property rx_baser_data_valid ENABLED true
    } else {
        set_interface_property tx_baser_control ENABLED false
        set_interface_property tx_baser_parallel_data ENABLED false
        set_interface_property tx_baser_data_valid ENABLED false
        set_interface_property rx_baser_control ENABLED false
        set_interface_property rx_baser_control_fec ENABLED false
        set_interface_property rx_baser_parallel_data ENABLED false
        set_interface_property rx_baser_data_valid ENABLED false
        set_interface_property rx_enh_blk_lock_in ENABLED false
        set_interface_property rx_enh_blk_lock_out ENABLED false
    }
    
    # 28nm: Unused Signals
    add_interface unused_tx_parallel_data_28nm conduit start
    set_interface_property unused_tx_parallel_data_28nm ENABLED false
    add_interface_port unused_tx_parallel_data_28nm unused_tx_parallel_data_28nm unused_tx_parallel_data Output 26
    
    add_interface unused_rx_parallel_data_28nm conduit end
    set_interface_property unused_rx_parallel_data_28nm ENABLED false
    add_interface_port unused_rx_parallel_data_28nm unused_rx_parallel_data_28nm unused_rx_parallel_data Input 36
    
    if {[_is_device_family "Arria V"]} {
        set_interface_property unused_tx_parallel_data_28nm ENABLED true
        set_interface_property unused_rx_parallel_data_28nm ENABLED true
    }
    
    # Arria 10: TX Data Path
    add_interface tx_control_a10 conduit start
    set_interface_property tx_control_a10 ENABLED false
    add_interface_port tx_control_a10 tx_control_a10 tx_control Output 18
    
    add_interface tx_parallel_data_a10 conduit start
    set_interface_property tx_parallel_data_a10 ENABLED false
    add_interface_port tx_parallel_data_a10 tx_parallel_data_a10 tx_parallel_data Output 128
    
    # Arria 10: RX Data Path
    add_interface rx_control_a10 conduit end
    set_interface_property rx_control_a10 ENABLED false
    add_interface_port rx_control_a10 rx_control_a10 rx_control Input 20
    
    add_interface rx_parallel_data_a10 conduit end
    set_interface_property rx_parallel_data_a10 ENABLED false
    add_interface_port rx_parallel_data_a10 rx_parallel_data_a10 rx_parallel_data Input 128
    
    # 28nm, Arria 10: BASE-R Data Path
    add_interface tx_enh_data_valid_out conduit start
    set_interface_property tx_enh_data_valid_out ENABLED false
    add_interface_port tx_enh_data_valid_out tx_enh_data_valid_out tx_enh_data_valid Output 1
    
    add_interface rx_enh_data_valid_in conduit end
    set_interface_property rx_enh_data_valid_in ENABLED false
    add_interface_port rx_enh_data_valid_in rx_enh_data_valid_in rx_enh_data_valid Input 1
    
    if {[_is_device_family "Arria 10"]} {
        set_interface_property tx_parallel_data_a10 ENABLED true
        set_interface_property rx_parallel_data_a10 ENABLED true
        
        if {[_is_xgmii64b_pcs]} {
            set_interface_property tx_control_a10 ENABLED true
            set_interface_property rx_control_a10 ENABLED true
            
            set_interface_property tx_enh_data_valid_out ENABLED true
            set_interface_property rx_enh_data_valid_in ENABLED true
        } elseif {[_is_usxgmii32b_pcs]} {
            set_interface_property tx_control_a10 ENABLED true
            set_interface_property rx_control_a10 ENABLED true
            
            set_interface_property tx_enh_data_valid_out ENABLED true
            set_interface_property rx_enh_data_valid_in ENABLED true
        } else {
            set_interface_property tx_control_a10 ENABLED false
            set_interface_property rx_control_a10 ENABLED false
            
            set_interface_property tx_enh_data_valid_out ENABLED false
            set_interface_property rx_enh_data_valid_in ENABLED false
        }
    }
    
    # 10GBASE-R BER Checker
    add_interface rx_enh_highber_in conduit end
    set_interface_property rx_enh_highber_in ENABLED false
    add_interface_port rx_enh_highber_in rx_enh_highber_in rx_enh_highber Input 1
    
    add_interface rx_enh_highber_clr_cnt_out conduit start
    set_interface_property rx_enh_highber_clr_cnt_out ENABLED false
    add_interface_port rx_enh_highber_clr_cnt_out rx_enh_highber_clr_cnt_out rx_enh_highber_clr_cnt Output 1
    
    add_interface rx_enh_clr_errblk_count_out conduit start
    set_interface_property rx_enh_clr_errblk_count_out ENABLED false
    add_interface_port rx_enh_clr_errblk_count_out rx_enh_clr_errblk_count_out rx_enh_clr_errblk_count Output 1
    
    if {[_is_xgmii64b_pcs]} {
        set_interface_property rx_enh_highber_in ENABLED true
        set_interface_property rx_enh_highber_clr_cnt_out ENABLED true
        set_interface_property rx_enh_clr_errblk_count_out ENABLED true
    } elseif {[_is_usxgmii32b_pcs]} {
        set_interface_property rx_enh_highber_in ENABLED true
        set_interface_property rx_enh_highber_clr_cnt_out ENABLED true
        set_interface_property rx_enh_clr_errblk_count_out ENABLED true
    } else {
        set_interface_property rx_enh_highber_in ENABLED false
        set_interface_property rx_enh_highber_clr_cnt_out ENABLED false
        set_interface_property rx_enh_clr_errblk_count_out ENABLED false
    }
    
}

# #############################
# Internal Procedures
# #############################

# Check for PHY configurations
proc _is_2p5g {} {
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    
    if {($speed_variant == 0) && ($ext_phy_mgbaset == 1)} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_1g_2p5g {} {
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    
    if {($speed_variant == 1) && ($ext_phy_mgbaset == 1)} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_1g_10g {} {
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    
    if {($speed_variant == 2) && ($ext_phy_mgbaset == 1)} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_mgbaset {} {
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    
    if {($speed_variant == 4) && ($ext_phy_mgbaset == 1)} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_10g_usxgmii {} {
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    
    if {($speed_variant == 4) && ($ext_phy_nbaset == 1)} {
        return 1;
    } else {
        return 0;
    }
}

# Check for PCS types
proc _is_gmii16b_pcs {} {
    
    if {[_is_2p5g] || [_is_1g_2p5g] || [_is_1g_10g] || [_is_mgbaset]} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_xgmii64b_pcs {} {
    if {[_is_1g_10g] || [_is_mgbaset]} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_usxgmii32b_pcs {} {
    if {[_is_10g_usxgmii]} {
        return 1;
    } else {
        return 0;
    }
}

proc _is_device_family {dev_family} {
    set device_family [get_parameter_value DEVICE_FAMILY]
    
    if {![string compare $device_family $dev_family]} {
        return 1;
    } else {
        return 0;
    }
}
