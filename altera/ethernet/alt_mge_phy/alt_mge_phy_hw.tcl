proc speed_variant_update {arg} {
    set speed_variant [get_parameter_value $arg]
    
    if {$speed_variant == 0} {
        # 2.5G
        set_parameter_value DEFAULT_MODE 1
        set_parameter_value EXT_PHY_MGBASET 1
        set_parameter_value EXT_PHY_NBASET 0
    } elseif {$speed_variant == 1} {
        # 1G/2.5G
        set_parameter_value DEFAULT_MODE 1
        set_parameter_value EXT_PHY_MGBASET 1
        set_parameter_value EXT_PHY_NBASET 0
    } elseif {$speed_variant == 2} {
        # 1G/10G
        set_parameter_value DEFAULT_MODE 3
        set_parameter_value ENABLE_IEEE1588 0
        set_parameter_value EXT_PHY_MGBASET 1
        set_parameter_value EXT_PHY_NBASET 0
    } elseif {$speed_variant == 4} {
        # 1G/2.5G/5G/10G (MGBASE-T)
        set_parameter_value DEFAULT_MODE 3
        set_parameter_value ENABLE_IEEE1588 0
        set_parameter_value EXT_PHY_MGBASET 1
        set_parameter_value EXT_PHY_NBASET 0
    }
}

proc ext_phy_mgbaset_update {arg} {
    set ext_phy_mgbaset [get_parameter_value $arg]
    set speed_variant [get_parameter_value SPEED_VARIANT]
    
    if {$speed_variant == 4} {
        # 1G/2.5G/5G/10G
        if {$ext_phy_mgbaset == 1} {
            set_parameter_value EXT_PHY_NBASET 0
        }
    }
	
	# Ensure at least one of the checkbox is checked
	set_parameter_value EXT_PHY_MGBASET 1
}

proc ext_phy_nbaset_update {arg} {
    set ext_phy_nbaset [get_parameter_value $arg]
    set speed_variant [get_parameter_value SPEED_VARIANT]
    
    if {$speed_variant == 4} {
        # 1G/2.5G/5G/10G
        if {$ext_phy_nbaset == 1} {
            set_parameter_value EXT_PHY_MGBASET 0
        }
    }
	
	# Ensure at least one of the checkbox is checked
	set_parameter_value EXT_PHY_NBASET 1
}

