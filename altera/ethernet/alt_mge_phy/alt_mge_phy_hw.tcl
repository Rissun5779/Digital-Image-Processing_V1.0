            add_connection xcvr_term.tx_serial_clk_out1_a10/${native_phy_instance}.tx_serial_clk1
            add_connection xcvr_term.tx_serial_clk_out2_a10/${native_phy_instance}.tx_serial_clk2
        } elseif {[_is_10g_usxgmii]} {
            # 1G/2.5G/5G/10G (USXGMII)
            add_connection xcvr_term.tx_serial_clk_out0_a10/${native_phy_instance}.tx_serial_clk0
        }
    }
    
    # RX CDR Refclk
    if {[_is_2p5g] || [_is_1g_2p5g] || [_is_1g_10g] || [_is_mgbaset]} {
        # 2.5G
        # 1G/2.5G
        # 1G/10G
        # 1G/2.5G/5G/10G (MGBASE-T)
        add_interface rx_cdr_refclk_0 clock end
        set_interface_property rx_cdr_refclk_0 EXPORT_OF xcvr_term.rx_cdr_refclk_in_0
        set_interface_property rx_cdr_refclk_0  PORT_NAME_MAP   {rx_cdr_refclk rx_cdr_refclk_in_0}
    }

    if {[_is_1g_10g] || [_is_mgbaset] || [_is_10g_usxgmii]} {
        # 1G/10G
        # 1G/2.5G/5G/10G (MGBASE-T)
        # 1G/2.5G/5G/10G (USXGMII)
        add_interface rx_cdr_refclk_1 clock end
        set_interface_property rx_cdr_refclk_1 EXPORT_OF xcvr_term.rx_cdr_refclk_in_1
        set_interface_property rx_cdr_refclk_1  PORT_NAME_MAP   {rx_cdr_refclk_1 rx_cdr_refclk_in_1}
    }
    
    if {[_is_device_family "Arria V"]} {
        add_connection xcvr_term.rx_cdr_refclk_out_28nm/${native_phy_instance}.rx_cdr_refclk
    }
    
    if {[_is_device_family "Arria 10"]} {
        if {[_is_2p5g]} {
            # 2.5G
            add_connection xcvr_term.rx_cdr_refclk_out0_a10/${native_phy_instance}.rx_cdr_refclk0
        } elseif {[_is_1g_2p5g]} {
            # 1G/2.5G
            add_connection xcvr_term.rx_cdr_refclk_out0_a10/${native_phy_instance}.rx_cdr_refclk0
        } elseif {[_is_1g_10g]} {
            # 1G/10G
            add_connection xcvr_term.rx_cdr_refclk_out0_a10/${native_phy_instance}.rx_cdr_refclk0
            add_connection xcvr_term.rx_cdr_refclk_out1_a10/${native_phy_instance}.rx_cdr_refclk1
        } elseif {[_is_mgbaset]} {
            # 1G/2.5G/5G/10G (MGBASE-T)
            add_connection xcvr_term.rx_cdr_refclk_out0_a10/${native_phy_instance}.rx_cdr_refclk0
            add_connection xcvr_term.rx_cdr_refclk_out1_a10/${native_phy_instance}.rx_cdr_refclk1
        } elseif {[_is_10g_usxgmii]} {
            # 1G/2.5G/5G/10G (USXGMII)
            add_connection xcvr_term.rx_cdr_refclk_out1_a10/${native_phy_instance}.rx_cdr_refclk0
        }
    }
    
    # TX/RX PCS Clock
    add_connection xcvr_term.tx_clkout_out_pcs/mge_pcs.tx_pma_clk
    add_connection xcvr_term.rx_clkout_out_pcs/mge_pcs.rx_pma_clk
    
    if {[_is_gmii16b_pcs]} {
        add_interface tx_clkout clock start
        set_interface_property tx_clkout EXPORT_OF xcvr_term.tx_clkout_out_mac
        set_interface_property tx_clkout  PORT_NAME_MAP   {tx_clkout tx_clkout_out_mac}
        
        add_interface rx_clkout clock start
        set_interface_property rx_clkout EXPORT_OF xcvr_term.rx_clkout_out_mac
        set_interface_property rx_clkout  PORT_NAME_MAP   {rx_clkout rx_clkout_out_mac}
    }
    
    if {[_is_device_family "Arria V"]} {
        add_connection ${native_phy_instance}.tx_std_clkout/xcvr_term.tx_clkout_in
        add_connection ${native_phy_instance}.rx_std_clkout/xcvr_term.rx_clkout_in
        
        add_connection xcvr_term.tx_coreclkin_out_xcvr/${native_phy_instance}.tx_std_coreclkin
        add_connection xcvr_term.rx_coreclkin_out_xcvr/${native_phy_instance}.rx_std_coreclkin
    }
    
    if {[_is_device_family "Arria 10"]} {
        add_connection ${native_phy_instance}.tx_clkout/xcvr_term.tx_clkout_in
        add_connection ${native_phy_instance}.rx_clkout/xcvr_term.rx_clkout_in
        
        add_connection xcvr_term.tx_coreclkin_out_xcvr/${native_phy_instance}.tx_coreclkin
        add_connection xcvr_term.rx_coreclkin_out_xcvr/${native_phy_instance}.rx_coreclkin
    }
    
    # RX PMA Clock (Sync-E)
    add_interface rx_pma_clkout clock start
    set_interface_property rx_pma_clkout EXPORT_OF xcvr_term.rx_pma_clkout_out
    set_interface_property rx_pma_clkout  PORT_NAME_MAP   {rx_pma_clkout rx_pma_clkout_out}	
    
    add_connection ${native_phy_instance}.rx_pma_clkout/xcvr_term.rx_pma_clkout_in
    
    # Serial Loopback
    add_connection mge_pcs.rx_seriallpbken/xcvr_term.rx_seriallpbken_in
    add_connection xcvr_term.rx_seriallpbken_out/${native_phy_instance}.rx_seriallpbken
    
    # Transceiver Mode from Reconfig
    if {[_is_2p5g] || [_is_1g_2p5g] || [_is_1g_10g] || [_is_mgbaset]} {
        # 2.5G
        # 1G/2.5G
        # 1G/10G
        # 1G/2.5G/5G/10G (MGBASE-T)
        add_interface xcvr_mode conduit end
        set_interface_property xcvr_mode EXPORT_OF xcvr_term.xcvr_mode_in
        set_interface_property xcvr_mode  PORT_NAME_MAP    {xcvr_mode xcvr_mode_in}
    }
    add_connection xcvr_term.xcvr_mode_out/mge_pcs.xcvr_mode
    
    # XGMII
    if {[_is_xgmii64b_pcs] || [_is_usxgmii32b_pcs]} {
        # 1G/2.5G/5G/10G (MGBASE-T)
        # 1G/2.5G/5G/10G (USXGMII)
        
        if {[_is_xgmii64b_pcs] && ($baser_reg_mode == 0)} {
            add_interface xgmii_tx_coreclkin clock end
            set_interface_property xgmii_tx_coreclkin EXPORT_OF xcvr_term.tx_xgmii_coreclkin
            set_interface_property xgmii_tx_coreclkin  PORT_NAME_MAP   {xgmii_tx_coreclkin tx_xgmii_coreclkin}
            
            add_interface xgmii_tx_control conduit end
            set_interface_property xgmii_tx_control EXPORT_OF xcvr_term.tx_baser_control
            set_interface_property xgmii_tx_control  PORT_NAME_MAP   {xgmii_tx_control tx_baser_control}
            
            add_interface xgmii_tx_data conduit end
            set_interface_property xgmii_tx_data EXPORT_OF xcvr_term.tx_baser_parallel_data
            set_interface_property xgmii_tx_data  PORT_NAME_MAP   {xgmii_tx_data tx_baser_parallel_data}
            
            add_interface xgmii_rx_coreclkin clock end
            set_interface_property xgmii_rx_coreclkin EXPORT_OF xcvr_term.rx_xgmii_coreclkin
            set_interface_property xgmii_rx_coreclkin  PORT_NAME_MAP   {xgmii_rx_coreclkin rx_xgmii_coreclkin}
            
            add_interface xgmii_rx_control conduit start
            set_interface_property xgmii_rx_control EXPORT_OF xcvr_term.rx_baser_control
            set_interface_property xgmii_rx_control  PORT_NAME_MAP   {xgmii_rx_control rx_baser_control}
            
            add_interface xgmii_rx_data conduit start
            set_interface_property xgmii_rx_data EXPORT_OF xcvr_term.rx_baser_parallel_data
            set_interface_property xgmii_rx_data  PORT_NAME_MAP   {xgmii_rx_data rx_baser_parallel_data}
            
        } else {
            add_interface xgmii_tx_coreclkin clock end
            set_interface_property xgmii_tx_coreclkin EXPORT_OF mge_pcs.tx_xgmii_clk
            set_interface_property xgmii_tx_coreclkin  PORT_NAME_MAP   {xgmii_tx_coreclkin tx_xgmii_clk}
            
            add_interface xgmii_tx_control conduit end
            set_interface_property xgmii_tx_control EXPORT_OF mge_pcs.tx_xgmii_control_in
            set_interface_property xgmii_tx_control  PORT_NAME_MAP   {xgmii_tx_control tx_xgmii_control_in}
            
            add_interface xgmii_tx_data conduit end
            set_interface_property xgmii_tx_data EXPORT_OF mge_pcs.tx_xgmii_data_in
            set_interface_property xgmii_tx_data  PORT_NAME_MAP   {xgmii_tx_data tx_xgmii_data_in}
            
            add_connection mge_pcs.tx_xgmii_valid_out/xcvr_term.tx_baser_data_valid
            add_connection mge_pcs.tx_xgmii_control_out/xcvr_term.tx_baser_control
            add_connection mge_pcs.tx_xgmii_data_out/xcvr_term.tx_baser_parallel_data
            
            add_interface xgmii_rx_coreclkin clock end
            set_interface_property xgmii_rx_coreclkin EXPORT_OF mge_pcs.rx_xgmii_clk
            set_interface_property xgmii_rx_coreclkin  PORT_NAME_MAP   {xgmii_rx_coreclkin rx_xgmii_clk}
            
            add_interface xgmii_rx_control conduit start
            set_interface_property xgmii_rx_control EXPORT_OF mge_pcs.rx_xgmii_control_out
            set_interface_property xgmii_rx_control  PORT_NAME_MAP   {xgmii_rx_control rx_xgmii_control_out}
            
            add_interface xgmii_rx_data conduit start
            set_interface_property xgmii_rx_data EXPORT_OF mge_pcs.rx_xgmii_data_out
            set_interface_property xgmii_rx_data  PORT_NAME_MAP   {xgmii_rx_data rx_xgmii_data_out}
            
            add_connection xcvr_term.rx_baser_data_valid/mge_pcs.rx_xgmii_valid_in
            add_connection xcvr_term.rx_baser_control/mge_pcs.rx_xgmii_control_in
            add_connection xcvr_term.rx_baser_parallel_data/mge_pcs.rx_xgmii_data_in
            
            if {[_is_usxgmii32b_pcs]} {
                add_interface xgmii_tx_valid conduit end
                set_interface_property xgmii_tx_valid EXPORT_OF mge_pcs.tx_xgmii_valid_in
                set_interface_property xgmii_tx_valid  PORT_NAME_MAP   {xgmii_tx_valid tx_xgmii_valid_in}
                
                add_interface xgmii_rx_valid conduit start
                set_interface_property xgmii_rx_valid EXPORT_OF mge_pcs.rx_xgmii_valid_out
                set_interface_property xgmii_rx_valid  PORT_NAME_MAP   {xgmii_rx_valid rx_xgmii_valid_out}
            }
            
        }
        
        # 1588
        if {$enable_ieee1588 == 1} {
            add_interface xgmii_tx_latency conduit start
            set_interface_property xgmii_tx_latency EXPORT_OF mge_pcs.tx_xgmii_latency
            set_interface_property xgmii_tx_latency  PORT_NAME_MAP    {xgmii_tx_latency tx_xgmii_latency}
            
            add_interface xgmii_rx_latency conduit start
            set_interface_property xgmii_rx_latency EXPORT_OF mge_pcs.rx_xgmii_latency
            set_interface_property xgmii_rx_latency  PORT_NAME_MAP    {xgmii_rx_latency rx_xgmii_latency}
        }
        
        add_interface rx_block_lock conduit start
        set_interface_property rx_block_lock EXPORT_OF mge_pcs.rx_block_lock_out
        set_interface_property rx_block_lock  PORT_NAME_MAP   {rx_block_lock rx_block_lock_out}
        
        add_connection ${native_phy_instance}.rx_enh_blk_lock/xcvr_term.rx_enh_blk_lock_in
        add_connection xcvr_term.rx_enh_blk_lock_out/mge_pcs.rx_block_lock_in
    }
    
    # Device Independent Data Path
    if {[_is_gmii16b_pcs]} {
        add_connection ${native_phy_instance}.rx_std_bitslipboundarysel/mge_pcs.rx_std_bitslipboundarysel
    }
    
    # Device Dependent Data Path
    if {[_is_device_family "Arria V"]} {
        add_connection mge_pcs.tx_basex_datak/${native_phy_instance}.tx_datak
        add_connection mge_pcs.tx_basex_parallel_data/${native_phy_instance}.tx_parallel_data
        
        add_connection ${native_phy_instance}.rx_datak/mge_pcs.rx_basex_datak
        add_connection ${native_phy_instance}.rx_parallel_data/mge_pcs.rx_basex_parallel_data
        
        add_connection ${native_phy_instance}.rx_syncstatus/mge_pcs.rx_syncstatus
        add_connection ${native_phy_instance}.rx_runningdisp/mge_pcs.rx_runningdisp   
        add_connection ${native_phy_instance}.rx_disperr/mge_pcs.rx_disperr
        add_connection ${native_phy_instance}.rx_errdetect/mge_pcs.rx_errdetect
        add_connection ${native_phy_instance}.rx_patterndetect/mge_pcs.rx_patterndetect
        
        add_connection xcvr_term.unused_tx_parallel_data_28nm/${native_phy_instance}.unused_tx_parallel_data
        add_connection ${native_phy_instance}.unused_rx_parallel_data/xcvr_term.unused_rx_parallel_data_28nm
    }
    
    if {[_is_device_family "Arria 10"]} {
        
        if {[_is_gmii16b_pcs]} {
            add_connection mge_pcs.tx_basex_datak/xcvr_term.tx_basex_datak
            add_connection mge_pcs.tx_basex_parallel_data/xcvr_term.tx_basex_parallel_data
            
            add_connection xcvr_term.rx_basex_datak/mge_pcs.rx_basex_datak
            add_connection xcvr_term.rx_basex_parallel_data/mge_pcs.rx_basex_parallel_data
            
            add_connection xcvr_term.rx_syncstatus_a10/mge_pcs.rx_syncstatus
            add_connection xcvr_term.rx_runningdisp_a10/mge_pcs.rx_runningdisp   
            add_connection xcvr_term.rx_disperr_a10/mge_pcs.rx_disperr
            add_connection xcvr_term.rx_errdetect_a10/mge_pcs.rx_errdetect
            add_connection xcvr_term.rx_patterndetect_a10/mge_pcs.rx_patterndetect
        }
        
        add_connection xcvr_term.tx_parallel_data_a10/${native_phy_instance}.tx_parallel_data
        add_connection ${native_phy_instance}.rx_parallel_data/xcvr_term.rx_parallel_data_a10
        
        if {[_is_xgmii64b_pcs] || [_is_usxgmii32b_pcs]} {
            add_connection xcvr_term.tx_control_a10/${native_phy_instance}.tx_control
            add_connection ${native_phy_instance}.rx_control/xcvr_term.rx_control_a10
            
            add_connection ${native_phy_instance}.rx_enh_data_valid/xcvr_term.rx_enh_data_valid_in
            add_connection xcvr_term.tx_enh_data_valid_out/${native_phy_instance}.tx_enh_data_valid
            
            add_connection ${native_phy_instance}.rx_enh_highber/xcvr_term.rx_enh_highber_in
            add_connection xcvr_term.rx_enh_highber_clr_cnt_out/${native_phy_instance}.rx_enh_highber_clr_cnt
            add_connection xcvr_term.rx_enh_clr_errblk_count_out/${native_phy_instance}.rx_enh_clr_errblk_count
        }
    }
    
    # +-----------------------------------
    # | Native PHY
    # +-----------------------------------
    add_interface tx_serial_data conduit start
    set_interface_property tx_serial_data EXPORT_OF ${native_phy_instance}.tx_serial_data
    set_interface_property tx_serial_data  PORT_NAME_MAP   {tx_serial_data tx_serial_data}
    
    add_interface rx_serial_data conduit end
    set_interface_property rx_serial_data EXPORT_OF ${native_phy_instance}.rx_serial_data
    set_interface_property rx_serial_data  PORT_NAME_MAP   {rx_serial_data rx_serial_data}
    
    add_interface tx_analogreset conduit end
    set_interface_property tx_analogreset EXPORT_OF ${native_phy_instance}.tx_analogreset
    set_interface_property tx_analogreset  PORT_NAME_MAP   {tx_analogreset tx_analogreset}
    
    add_interface rx_analogreset conduit end
    set_interface_property rx_analogreset EXPORT_OF ${native_phy_instance}.rx_analogreset
    set_interface_property rx_analogreset  PORT_NAME_MAP   {rx_analogreset rx_analogreset}
    
    add_interface tx_cal_busy conduit end
    set_interface_property tx_cal_busy EXPORT_OF ${native_phy_instance}.tx_cal_busy
    set_interface_property tx_cal_busy  PORT_NAME_MAP   {tx_cal_busy tx_cal_busy}
    
    add_interface rx_cal_busy conduit end
    set_interface_property rx_cal_busy EXPORT_OF ${native_phy_instance}.rx_cal_busy
    set_interface_property rx_cal_busy  PORT_NAME_MAP   {rx_cal_busy rx_cal_busy}
    
    add_interface rx_is_lockedtodata conduit end
    set_interface_property rx_is_lockedtodata EXPORT_OF ${native_phy_instance}.rx_is_lockedtodata
    set_interface_property rx_is_lockedtodata  PORT_NAME_MAP   {rx_is_lockedtodata rx_is_lockedtodata}
    
    # Reset connection
    add_connection mge_pcs.tx_digitalreset_to_xcvr/xcvr_term.tx_digitalreset_to_xcvr_in
    add_connection mge_pcs.rx_digitalreset_to_xcvr/xcvr_term.rx_digitalreset_to_xcvr_in
    
    add_connection xcvr_term.tx_digitalreset_to_xcvr_out/${native_phy_instance}.tx_digitalreset
    add_connection xcvr_term.rx_digitalreset_to_xcvr_out/${native_phy_instance}.rx_digitalreset
    
    # Device Dependent Sideband
    if {[_is_device_family "Arria V"]} {
        # Reconfiguration
        add_interface reconfig_to_xcvr conduit end
        set_interface_property reconfig_to_xcvr EXPORT_OF ${native_phy_instance}.reconfig_to_xcvr
        set_interface_property reconfig_to_xcvr  PORT_NAME_MAP   {reconfig_to_xcvr reconfig_to_xcvr}
        
        add_interface reconfig_from_xcvr conduit start
        set_interface_property reconfig_from_xcvr EXPORT_OF ${native_phy_instance}.reconfig_from_xcvr
        set_interface_property reconfig_from_xcvr  PORT_NAME_MAP   {reconfig_from_xcvr reconfig_from_xcvr}
        
        # PLL Powerdown
        add_interface pll_powerdown conduit end
        set_interface_property pll_powerdown EXPORT_OF ${native_phy_instance}.pll_powerdown
        set_interface_property pll_powerdown  PORT_NAME_MAP   {pll_powerdown pll_powerdown}
    }
    
    if {[_is_device_family "Arria 10"]} {
        # Reconfiguration
        add_interface reconfig_clk clock end
        set_interface_property reconfig_clk EXPORT_OF ${native_phy_instance}.reconfig_clk
        set_interface_property reconfig_clk PORT_NAME_MAP   {reconfig_clk reconfig_clk}
        
        add_interface reconfig_reset reset end
        set_interface_property reconfig_reset EXPORT_OF ${native_phy_instance}.reconfig_reset
        set_interface_property reconfig_reset PORT_NAME_MAP   {reconfig_reset reconfig_reset}
        
        add_interface reconfig_avmm avalon end
        set_interface_property reconfig_avmm EXPORT_OF ${native_phy_instance}.reconfig_avmm
        set_interface_property reconfig_avmm PORT_NAME_MAP   {reconfig_write reconfig_write reconfig_read reconfig_read reconfig_address reconfig_address reconfig_writedata reconfig_writedata reconfig_readdata reconfig_readdata reconfig_waitrequest reconfig_waitrequest}
    }
    
}

proc validate {} {
    
    set show_hidden_options [get_parameter_value SHOW_HIDDEN_OPTIONS]
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]   
    
    set xcvr_set_capability_reg_enable [get_parameter_value XCVR_SET_CAPABILITY_REG_ENABLE]
    
    if {$show_hidden_options == 1} {
        set_parameter_property DEFAULT_MODE VISIBLE true
    } else {
        set_parameter_property DEFAULT_MODE VISIBLE false
    }
    
    if {[_is_2p5g]} {
        # 2.5G
        set_parameter_property DEFAULT_MODE ALLOWED_RANGES {
            "1:2.5GbE"
        }
        
        set_parameter_property PHY_IDENTIFIER ENABLED true
        set_parameter_property REFCLK_FREQ_BASER ENABLED false
        set_parameter_property ENABLE_IEEE1588 ENABLED true
        set_parameter_property EXT_PHY_MGBASET ENABLED false
        set_parameter_property EXT_PHY_NBASET ENABLED false
    } elseif {[_is_1g_2p5g]} {
        # 1G/2.5G
        set_parameter_property DEFAULT_MODE ALLOWED_RANGES {
            "0:1GbE"
            "1:2.5GbE"
        }
        
        set_parameter_property PHY_IDENTIFIER ENABLED true
        set_parameter_property REFCLK_FREQ_BASER ENABLED false
        set_parameter_property ENABLE_IEEE1588 ENABLED true
        set_parameter_property EXT_PHY_MGBASET ENABLED false
        set_parameter_property EXT_PHY_NBASET ENABLED false
    } elseif {[_is_1g_10g]} {
        # 1G/10G
        set_parameter_property DEFAULT_MODE ALLOWED_RANGES {
            "0:1GbE"
            "3:10GbE"
        }
        
        set_parameter_property PHY_IDENTIFIER ENABLED true
        set_parameter_property REFCLK_FREQ_BASER ENABLED true
        set_parameter_property ENABLE_IEEE1588 ENABLED false
        set_parameter_property EXT_PHY_MGBASET ENABLED false
        set_parameter_property EXT_PHY_NBASET ENABLED false
    } elseif {[_is_mgbaset]} {
        # 1G/2.5G/5G/10G (MGBASE-T)
        set_parameter_property DEFAULT_MODE ALLOWED_RANGES {
            "0:1GbE"
            "1:2.5GbE"
            "2:5GbE"
            "3:10GbE"
        }
        
        set_parameter_property PHY_IDENTIFIER ENABLED true
        set_parameter_property REFCLK_FREQ_BASER ENABLED true
        set_parameter_property ENABLE_IEEE1588 ENABLED false
        set_parameter_property EXT_PHY_MGBASET ENABLED true
        set_parameter_property EXT_PHY_NBASET ENABLED true
    } elseif {[_is_10g_usxgmii]} {
        # 1G/2.5G/5G/10G (USXGMII)
        set_parameter_property DEFAULT_MODE ALLOWED_RANGES {
            "3:10GbE"
        }
        
        set_parameter_property PHY_IDENTIFIER ENABLED false
        set_parameter_property REFCLK_FREQ_BASER ENABLED true
        set_parameter_property ENABLE_IEEE1588 ENABLED false
        set_parameter_property EXT_PHY_MGBASET ENABLED true
        set_parameter_property EXT_PHY_NBASET ENABLED true
    }
    
    if {[_is_device_family "Arria V"]} {
        set_parameter_property SPEED_VARIANT ALLOWED_RANGES {
           "0:2.5G"
           "1:1G/2.5G"
        }
        
        set_parameter_property TX_PLL_CLOCK_NETWORK_2P5G ENABLED true
        
        set_parameter_property TX_PMA_CLK_DIV_1G ENABLED false
        set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED false
        
        set_parameter_property TX_PMA_CLK_DIV_1G ALLOWED_RANGES {
            "1" "2" "4" "8"
        }
        
        set_parameter_property TX_PMA_CLK_DIV_2P5G ALLOWED_RANGES {
            "1" "2"
        }
        
        # Disable 1G options for 2.5G only variant
        if {[_is_2p5g]} {
            set_parameter_property TX_PLL_CLOCK_NETWORK_1G ENABLED false
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED false
        } else {
            set_parameter_property TX_PLL_CLOCK_NETWORK_1G ENABLED true
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED false
        }
        
        # Arria 10 Transceiver Debug
        set_parameter_property XCVR_RCFG_JTAG_ENABLE ENABLED false
        set_parameter_property XCVR_SET_CAPABILITY_REG_ENABLE ENABLED false
        set_parameter_property XCVR_SET_USER_IDENTIFIER ENABLED false
        set_parameter_property XCVR_SET_CSR_SOFT_LOGIC_ENABLE ENABLED false
        set_parameter_property XCVR_SET_PRBS_SOFT_LOGIC_ENABLE ENABLED false
        set_parameter_property XCVR_SET_ODI_SOFT_LOGIC_ENABLE ENABLED false
    }
    
    if {[_is_device_family "Arria 10"]} {
        if {$ext_phy_mgbaset == 1} {
            set_parameter_property SPEED_VARIANT ALLOWED_RANGES {
               "0:2.5G"
               "1:1G/2.5G"
               "4:1G/2.5G/10G"
            }
        
            if {$show_hidden_options == 1} {
                set_parameter_property SPEED_VARIANT ALLOWED_RANGES {
                   "0:2.5G"
                   "1:1G/2.5G"
                   "2:1G/10G"
                   "4:1G/2.5G/10G"
                }
            }
        }
        if {$ext_phy_nbaset == 1} {
            set_parameter_property SPEED_VARIANT ALLOWED_RANGES {
               "4:10M/100M/1G/2.5G/5G/10G"
            }
        }
        
        set_parameter_property TX_PLL_CLOCK_NETWORK_1G ENABLED false
        set_parameter_property TX_PLL_CLOCK_NETWORK_2P5G ENABLED false
        
        set_parameter_property TX_PMA_CLK_DIV_1G ALLOWED_RANGES {
            "1" "2" "4" "8"
        }
        
        set_parameter_property TX_PMA_CLK_DIV_2P5G ALLOWED_RANGES {
            "1" "2"
        }
        
        if {[_is_2p5g]} {
            # 2.5G
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED false
            set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED true
        } elseif {[_is_1g_2p5g]} {
            # 1G/2.5G
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED true
            set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED true
        } elseif {[_is_1g_10g]} {
            # 1G/10G
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED true
            set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED false
        } elseif {[_is_mgbaset]} {
            # 1G/2.5G/5G/10G (MGBASE-T)
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED true
            set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED true
        } elseif {[_is_10g_usxgmii]} {
            # 1G/2.5G/5G/10G (USXGMII)
            set_parameter_property TX_PMA_CLK_DIV_1G ENABLED false
            set_parameter_property TX_PMA_CLK_DIV_2P5G ENABLED false
        }
        
        # Arria 10 Transceiver Debug
        set_parameter_property XCVR_RCFG_JTAG_ENABLE ENABLED true
        set_parameter_property XCVR_SET_CAPABILITY_REG_ENABLE ENABLED true
        set_parameter_property XCVR_SET_USER_IDENTIFIER ENABLED true
        set_parameter_property XCVR_SET_CSR_SOFT_LOGIC_ENABLE ENABLED true
        set_parameter_property XCVR_SET_PRBS_SOFT_LOGIC_ENABLE ENABLED true
        set_parameter_property XCVR_SET_ODI_SOFT_LOGIC_ENABLE ENABLED true
        
        if {$xcvr_set_capability_reg_enable == 0} {
            set_parameter_property XCVR_SET_USER_IDENTIFIER ENABLED false
        } else {
            set_parameter_property XCVR_SET_USER_IDENTIFIER ENABLED true
        }
    }
    
}

