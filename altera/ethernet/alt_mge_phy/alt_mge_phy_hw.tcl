proc compose {} {

    set phy_identifier [get_parameter_value PHY_IDENTIFIER]
    set tx_pll_clock_network_1g [get_parameter_value TX_PLL_CLOCK_NETWORK_1G]
    set tx_pll_clock_network_2p5g [get_parameter_value TX_PLL_CLOCK_NETWORK_2P5G]
    set tx_pma_clk_div_1g [get_parameter_value TX_PMA_CLK_DIV_1G]
    set tx_pma_clk_div_2p5g [get_parameter_value TX_PMA_CLK_DIV_2P5G]
    set refclk_freq_baser [get_parameter_value REFCLK_FREQ_BASER]
    set tx_pma_clk_div_5g 1
    set tx_pma_clk_div_10g 1
    set speed_variant [get_parameter_value SPEED_VARIANT]
    set ext_phy_mgbaset [get_parameter_value EXT_PHY_MGBASET]
    set ext_phy_nbaset [get_parameter_value EXT_PHY_NBASET]
    set default_mode [get_parameter_value DEFAULT_MODE]
    set enable_ieee1588 [get_parameter_value ENABLE_IEEE1588]
    set device_family [get_parameter_value DEVICE_FAMILY]
    
    set xcvr_rcfg_jtag_enable [get_parameter_value XCVR_RCFG_JTAG_ENABLE]
    set xcvr_set_capability_reg_enable [get_parameter_value XCVR_SET_CAPABILITY_REG_ENABLE]
    set xcvr_set_user_identifier [get_parameter_value XCVR_SET_USER_IDENTIFIER]
    set xcvr_set_csr_soft_logic_enable [get_parameter_value XCVR_SET_CSR_SOFT_LOGIC_ENABLE]
    set xcvr_set_prbs_soft_logic_enable [get_parameter_value XCVR_SET_PRBS_SOFT_LOGIC_ENABLE]
    set xcvr_set_odi_soft_logic_enable [get_parameter_value XCVR_SET_ODI_SOFT_LOGIC_ENABLE]
    
    set set_cdr_refclk_freq_1g2p5g_28nm "125.0 MHz"
    set set_cdr_refclk_freq_1g2p5g_a10 "125.000"
    set set_cdr_refclk_freq_5g10g_a10 "644.53125"
    set enh_pcs_pma_width 32
    
    set baser_reg_mode 1
    set protocol_mode_basex "basic_std"
    set protocol_mode_baser "teng_baser_mode"
    
    set analog_voltage "1_0V"
    
    if {$refclk_freq_baser == 1} {
        set set_cdr_refclk_freq_5g10g_a10 "322.265625"
    } else {
        set set_cdr_refclk_freq_5g10g_a10 "644.53125"
    }
    
    # Instantiation of PCS
    add_instance mge_pcs alt_mge_phy_pcs
    set_instance_parameter mge_pcs DEVICE_FAMILY $device_family
    set_instance_parameter mge_pcs PHY_IDENTIFIER $phy_identifier
    set_instance_parameter mge_pcs ENABLE_IEEE1588 $enable_ieee1588
    set_instance_parameter mge_pcs SPEED_VARIANT $speed_variant
    set_instance_parameter mge_pcs EXT_PHY_MGBASET $ext_phy_mgbaset
    set_instance_parameter mge_pcs EXT_PHY_NBASET $ext_phy_nbaset
    
    # Transceiver Ports Termination
    add_instance xcvr_term alt_mge_phy_xcvr_term
    set_instance_parameter xcvr_term SPEED_VARIANT $speed_variant
    set_instance_parameter xcvr_term EXT_PHY_MGBASET $ext_phy_mgbaset
    set_instance_parameter xcvr_term EXT_PHY_NBASET $ext_phy_nbaset
    set_instance_parameter xcvr_term BASER_REG_MODE $baser_reg_mode
    
    # Arria V support
    # The sequence of the parameters follow the sequence of Native PHY GUI from top to bottom, left to right
    if {[_is_device_family "Arria V"]} {
        set native_phy_instance alt_mge_xcvr_native
        add_instance $native_phy_instance  altera_xcvr_native_av
        
        # Datapath Options
        set_instance_parameter $native_phy_instance  tx_enable 1
        set_instance_parameter $native_phy_instance  rx_enable 1
        set_instance_parameter $native_phy_instance  enable_std 1
        set_instance_parameter $native_phy_instance  set_data_path_select "standard"
        set_instance_parameter $native_phy_instance  channels "1"
        set_instance_parameter $native_phy_instance  bonded_mode "non_bonded"
        set_instance_parameter $native_phy_instance  enable_simple_interface 1
        
        # PMA
        if {$default_mode == 0} {
            # 1GbE
            set_instance_parameter $native_phy_instance  set_data_rate "1250"
            set_instance_parameter $native_phy_instance  tx_pma_clk_div 1
            #set_instance_parameter $native_phy_instance  tx_pma_clk_div $tx_pma_clk_div_1g
        } else {
            # 2.5GbE
            set_instance_parameter $native_phy_instance  set_data_rate "3125"
            set_instance_parameter $native_phy_instance  tx_pma_clk_div 1
            #set_instance_parameter $native_phy_instance  tx_pma_clk_div $tx_pma_clk_div_2p5g
        }
        
        # TX PMA
        set_instance_parameter $native_phy_instance  pll_reconfig_enable 0
        set_instance_parameter $native_phy_instance  pll_external_enable 1
        
        if {$speed_variant == 0} {
            # 2.5G
            set_instance_parameter $native_phy_instance  plls "1"
        } else {
            # 1G/2.5G
            set_instance_parameter $native_phy_instance  plls "2"
        }
        
        if {$default_mode == 0} {
            # 1GbE
            set_instance_parameter $native_phy_instance  pll_select "1"
        } else {
            # 2.5GbE
            set_instance_parameter $native_phy_instance  pll_select "0"
        }
        set_instance_parameter $native_phy_instance  pll_refclk_cnt "1"
        
        # Tx PLL 0
        set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll0_pll_type "CMU"
        set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll0_data_rate "3125 Mbps"
        set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll0_refclk_freq "125.0 MHz"
        set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll0_refclk_sel "0"
        set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll0_clk_network $tx_pll_clock_network_2p5g
        
        # Tx PLL 1
        if {$speed_variant == 0} {
            # 2.5G
        } else {
            # 1G/2.5G
            set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll1_pll_type "CMU"
            set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll1_data_rate "1250 Mbps"
            set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll1_refclk_freq "125.0 MHz"
            set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll1_refclk_sel "0"
            set_instance_parameter $native_phy_instance  gui_pll_reconfig_pll1_clk_network $tx_pll_clock_network_1g
        }
        
        # RX PMA
        set_instance_parameter $native_phy_instance  cdr_reconfig_enable 1
        set_instance_parameter $native_phy_instance  cdr_refclk_cnt "1"
        set_instance_parameter $native_phy_instance  cdr_refclk_select "0"
        set_instance_parameter $native_phy_instance  set_cdr_refclk_freq $set_cdr_refclk_freq_1g2p5g_28nm
        set_instance_parameter $native_phy_instance  rx_ppm_detect_threshold "100"
        
        # RX PMA Optional Ports
        set_instance_parameter $native_phy_instance  enable_port_rx_pma_clkout 1
        set_instance_parameter $native_phy_instance  enable_port_rx_is_lockedtodata 1
        set_instance_parameter $native_phy_instance  enable_port_rx_is_lockedtoref 0
        set_instance_parameter $native_phy_instance  enable_ports_rx_manual_cdr_mode 0
        set_instance_parameter $native_phy_instance  rx_clkslip_enable 0
        set_instance_parameter $native_phy_instance  enable_port_rx_seriallpbken 1
        
        # Standard PCS
        set_instance_parameter $native_phy_instance  std_protocol_hint "gige"
        set_instance_parameter $native_phy_instance  std_pcs_pma_width "10"
        set_instance_parameter $native_phy_instance  std_low_latency_bypass_enable 0
        
        # Phase Compensation FIFO
        set_instance_parameter $native_phy_instance  std_tx_pcfifo_mode "low_latency"
        set_instance_parameter $native_phy_instance  std_rx_pcfifo_mode "low_latency"
        
        # Byte Ordering
        set_instance_parameter $native_phy_instance  std_rx_byte_order_enable 0
        
        # Byte Serializer and Deserializer
        set_instance_parameter $native_phy_instance  std_tx_byte_ser_enable 1
        set_instance_parameter $native_phy_instance  std_rx_byte_deser_enable 1
        
        # 8B/10B Encoder and Decoder
        set_instance_parameter $native_phy_instance  std_tx_8b10b_enable 1
