set_global_assignment -name PBIP_FILE rtl/pll_atxpll/nf_xcvr_10g_pll.ip
set_global_assignment -name PBIP_FILE rtl/pll_fpll/nf_xcvr_1g_pll.ip
set_global_assignment -name PBIP_FILE rtl/pll_mpll/io_pll.ip
set_global_assignment -name PBIP_FILE rtl/pll_mpll/pll_2.ip
