set_global_assignment -name FAMILY "Arria 10"
set_global_assignment -name DEVICE $DEVICE
set_global_assignment -name ORIGINAL_QUARTUS_VERSION "12.1 SP1"
set_global_assignment -name PROJECT_CREATION_TIME_DATE "09:07:18  JANUARY 08, 2013"
set_global_assignment -name LAST_QUARTUS_VERSION 15.1.0
set_global_assignment -name TOP_LEVEL_ENTITY altera_eth_top

set_global_assignment -name FITTER_EFFORT "STANDARD FIT"
set_global_assignment -name OPTIMIZE_HOLD_TIMING "ALL PATHS"
set_global_assignment -name OPTIMIZE_MULTI_CORNER_TIMING ON
set_global_assignment -tag dse_compilation -name SEED 10
set_global_assignment -name TIMEQUEST_DO_REPORT_TIMING ON
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files

@@ if { $virtual == 0 } {
# =================================================================
# Pin & Location Assignments
# =================================================================
# PLEASE ADD LOCATION ASSIGNMENT FOR YOUR BOARD HERE !!
@@ }

@@ if { $virtual == 0 } {
$VIRTUAL_PIN -to mm_clk
$VIRTUAL_PIN -to ref_clk_1g
$VIRTUAL_PIN -to ref_clk_10g
@@ }

# SFP
$VIRTUAL_PIN -to sfpa_mod1_scl
$VIRTUAL_PIN -to sfpa_mod2_sda
$VIRTUAL_PIN -to sfp_txdisable
$VIRTUAL_PIN -to SFPP_TX_FAULT
$VIRTUAL_PIN -to SFPP_RX_LOS

@@ if { $virtual == 0 } {
    @@ for {set lane 0} {$lane < $CHANNEL} {incr lane} {
# Channel ${lane}
$VIRTUAL_PIN -to tx_serial_data[${lane}]
$VIRTUAL_PIN -to rx_serial_data[${lane}]
    @@ }
@@ }

$VIRTUAL_PIN -to master_reset_n

@@ for {set lane 0} {$lane < $CHANNEL} {incr lane} {
$VIRTUAL_PIN -to channel_reset_n[${lane}]
@@ }

@@ for {set lane 0} {$lane < $CHANNEL} {incr lane} {
$VIRTUAL_PIN -to channel_ready_n[${lane}]
@@ }

@@ if { $virtual == 0 } {
# =================================================================
@@ }

# MDIO - Unused
set_instance_assignment -name VIRTUAL_PIN ON -to mdio_mdc[*]
set_instance_assignment -name VIRTUAL_PIN ON -to mdio_in[*]
set_instance_assignment -name VIRTUAL_PIN ON -to mdio_out[*]
set_instance_assignment -name VIRTUAL_PIN ON -to mdio_oen[*]

set_instance_assignment -name VIRTUAL_PIN ON -to xfp_txdisable


# IO Standard
set_instance_assignment -name IO_STANDARD LVDS -to mm_clk
set_instance_assignment -name IO_STANDARD LVDS -to ref_clk_1g
set_instance_assignment -name IO_STANDARD LVDS -to ref_clk_10g
set_instance_assignment -name IO_STANDARD "HSSI DIFFERENTIAL I/O" -to tx_serial_data[*]
set_instance_assignment -name IO_STANDARD "CURRENT MODE LOGIC (CML)" -to rx_serial_data[*]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to tx_serial_data[*]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to rx_serial_data[*]
set_instance_assignment -name IO_STANDARD "1.8 V" -to channel_ready_n[*]
set_instance_assignment -name IO_STANDARD "1.8 V" -to sfpa_mod1_scl
set_instance_assignment -name IO_STANDARD "1.8 V" -to sfpa_mod2_sda
set_instance_assignment -name IO_STANDARD "1.8 V" -to sfp_txdisable

set_global_assignment -name PRESERVE_UNUSED_XCVR_CHANNEL ON

# Clock termination setting
set_instance_assignment -name XCVR_REFCLK_PIN_TERMINATION AC_COUPLING -to ref_clk_1g
set_instance_assignment -name XCVR_REFCLK_PIN_TERMINATION AC_COUPLING -to ref_clk_10g
set_instance_assignment -name INPUT_TERMINATION DIFFERENTIAL -to mm_clk


###########################################################################

set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top

set_global_assignment -name OPTIMIZATION_TECHNIQUE BALANCED
set_global_assignment -name POWER_PRESET_COOLING_SOLUTION "23 MM HEAT SINK WITH 200 LFPM AIRFLOW"
set_global_assignment -name POWER_BOARD_THERMAL_MODEL "NONE (CONSERVATIVE)"
#set_global_assignment -name EDA_SIMULATION_TOOL "ModelSim-Altera (Verilog)"
#set_global_assignment -name EDA_OUTPUT_DATA_FORMAT "VERILOG HDL" -section_id eda_simulation
set_global_assignment -name STRATIX_DEVICE_IO_STANDARD "1.8 V"

# Use PCLK for TX
set_instance_assignment -name GLOBAL_SIGNAL "PERIPHERY CLOCK" -to "*|altera_xcvr_10gkr_a10:xcvr_10gkr_a10_0|ultra_chnl:CHANNEL|*1588*|altera_xcvr_native_a10:native_10g_1588_644|twentynm_xcvr_native:g_xcvr_native_insts[0].twentynm_xcvr_native_inst|twentynm_pcs:inst_twentynm_pcs|twentynm_pcs_ch:ch[0].inst_twentynm_pcs_ch|twentynm_hssi_tx_pld_pcs_interface_rbc:gen_twentynm_hssi_tx_pld_pcs_interface.inst_twentynm_hssi_tx_pld_pcs_interface|pld_pcs_tx_clk_out"

# Use PCLK for RX
set_instance_assignment -name GLOBAL_SIGNAL "PERIPHERY CLOCK" -to "*|altera_xcvr_10gkr_a10:xcvr_10gkr_a10_0|ultra_chnl:CHANNEL|*1588*|altera_xcvr_native_a10:native_10g_1588_644|twentynm_xcvr_native:g_xcvr_native_insts[0].twentynm_xcvr_native_inst|twentynm_pcs:inst_twentynm_pcs|twentynm_pcs_ch:ch[0].inst_twentynm_pcs_ch|twentynm_hssi_rx_pld_pcs_interface_rbc:gen_twentynm_hssi_rx_pld_pcs_interface.inst_twentynm_hssi_rx_pld_pcs_interface|pld_pcs_rx_clk_out"

set_global_assignment -name SYNTH_TIMING_DRIVEN_SYNTHESIS ON

# Use local routing for reset signal
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "*|altera_eth_10g_mac:mac|alt_em10g32:alt_em10g32_0|alt_em10g32_clk_rst:clk_rst_inst|alt_em10g32_rst_cnt:tx_reset_count_inst|rst_n_out"
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "altera_eth_multi_channel_1588:altera_eth_multi_channel_1588_inst|altera_reset_controller:CHANNEL[*].reset_sync_312_5_clk|altera_reset_synchronizer:alt_rst_sync_uq1|altera_reset_synchronizer_int_chain_out*"

set_global_assignment -name SDC_FILE altera_eth_top.sdc

set_global_assignment -name SYSTEMVERILOG_FILE altera_eth_top.sv
set_global_assignment -name SYSTEMVERILOG_FILE rtl/altera_eth_multi_channel_1588.sv
set_global_assignment -name VERILOG_FILE rtl/altera_eth_channel_1588.v
set_global_assignment -name VERILOG_FILE rtl/reset_sync/altera_reset_synchronizer.v
set_global_assignment -name VERILOG_FILE rtl/reset_ctrl/altera_reset_controller.v
set_global_assignment -name VERILOG_FILE rtl/reset_csr/reset_csr.v
@@ if { $qsys_pro == 0 } {
set_global_assignment -name QSYS_FILE rtl/mac/altera_eth_10g_mac.qsys
set_global_assignment -name QSYS_FILE rtl/phy/altera_eth_10gkr_phy.qsys
set_global_assignment -name QSYS_FILE rtl/xcvr_reset_controller/altera_xcvr_reset_controller.qsys
set_global_assignment -name QSYS_FILE rtl/pll_atxpll/nf_xcvr_10g_pll.qsys
