set_global_assignment -name QSYS_FILE rtl/altera_eth_1588_tod_sync/altera_eth_1588_tod_sync_64b_1g.qsys
set_global_assignment -name QSYS_FILE rtl/altera_eth_1588_tod_sync/altera_eth_1588_tod_sync_64b_10g.qsys
set_global_assignment -name QSYS_FILE rtl/altera_eth_1588_tod_sync/altera_eth_1588_tod_sync_96b_1g.qsys
set_global_assignment -name QSYS_FILE rtl/altera_eth_1588_tod_sync/altera_eth_1588_tod_sync_96b_10g.qsys
