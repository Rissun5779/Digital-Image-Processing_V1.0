   .SCL_FREQ (50000),   // for two_wire - note : using >400K may have legal implications
   .CLK_FREQ (100000000), 
   .MDIO_FREQ (50000)
    ) optics_control_inst (
    .clk_status                 (mm_clk)    ,
   .reset                       (~top_mm_clk_reset_n),
