// license agreement, including, without limitation, that your use is for the 
// sole purpose of programming logic devices manufactured by Intel and sold by 
// Intel or its authorized distributors.  Please refer to the applicable 
// agreement for further details.


module altera_eth_top # (

        parameter TSTAMP_FP_WIDTH = 4,
        parameter NUM_CHANNELS = ${NUM_CHANNELS}

 )(

        input       wire                                        mm_clk,
        
        input       wire                                        ref_clk_1g,
        input       wire                                        ref_clk_10g,

        inout       wire                                        sfpa_mod1_scl,
        inout       wire                                        sfpa_mod2_sda,

        output      wire                                        sfp_txdisable,
        output      wire                                        xfp_txdisable,

        input       wire                                        SFPP_TX_FAULT,
        input       wire                                        SFPP_RX_LOS,


        input       wire        [NUM_CHANNELS-1:0]              rx_serial_data,
        output      wire        [NUM_CHANNELS-1:0]              tx_serial_data,

        output      wire        [NUM_CHANNELS-1:0]              channel_ready_n,
        input       wire        [NUM_CHANNELS-1:0]              channel_reset_n,
        input       wire                                        master_reset_n,


        output      wire        [NUM_CHANNELS-1:0]              mdio_mdc,
        input       wire        [NUM_CHANNELS-1:0]              mdio_in,
        output      wire        [NUM_CHANNELS-1:0]              mdio_out,
        output      wire        [NUM_CHANNELS-1:0]              mdio_oen


);
    localparam MAX_NUM_CHANNELS         = 12;

    localparam ORDINARY_CLOCK           = 2'h0;
    localparam BOUNDARY_CLOCK           = 2'h1;
    localparam E2E_TRANSPARENT_CLOCK    = 2'h2;
    localparam P2P_TRANSPARENT_CLOCK    = 2'h3;

    localparam ODD_NUM_CHANNEL = (NUM_CHANNELS % 2 > 0) ? 1 : 0;
    localparam LAST_TRAFIIC_CTRL_PAIR = (divceil(NUM_CHANNELS, 2) - 1);

    wire    [NUM_CHANNELS-1:0]      rx_recovered_clk;

    wire    [NUM_CHANNELS-1:0]      led_an;
    wire    [NUM_CHANNELS-1:0]      led_char_err;
    wire    [NUM_CHANNELS-1:0]      led_disp_err;

//    wire    [NUM_CHANNELS-1:0]      channel_reset_n;
//    wire                            master_reset_n;

    wire                            xgmii_clk;

    wire    [31:0]                  jtag_if_address;
    wire                            jtag_if_read;
    wire    [31:0]                  jtag_if_readdata;
    wire                            jtag_if_write;
    wire    [31:0]                  jtag_if_writedata;
    wire                            jtag_if_waitrequest;
    wire                            jtag_if_readdatavalid;

    wire    [19:0]                  multi_channel_address;
    wire                            multi_channel_read;
    wire    [31:0]                  multi_channel_readdata;
    wire                            multi_channel_write;
    wire    [31:0]                  multi_channel_writedata;
    wire                            multi_channel_waitrequest;
 

    wire    [MAX_NUM_CHANNELS/2-1:0]            error_n;

    wire    [MAX_NUM_CHANNELS/2-1:0]        traffic_controller_write;
    wire    [MAX_NUM_CHANNELS/2-1:0]        traffic_controller_read;
    wire    [MAX_NUM_CHANNELS/2-1:0][13:0]  traffic_controller_address;
    wire    [MAX_NUM_CHANNELS/2-1:0][31:0]  traffic_controller_writedata;
    wire    [MAX_NUM_CHANNELS/2-1:0][31:0]  traffic_controller_readdata;
    wire    [MAX_NUM_CHANNELS/2-1:0]        traffic_controller_waitrequest;

    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_startofpacket;
    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_endofpacket;
    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_valid;
    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_ready;
    wire    [NUM_CHANNELS-1:0][63:0]        avalon_st_tx_data;
    wire    [NUM_CHANNELS-1:0][2:0]         avalon_st_tx_empty;
    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_error;

    wire    [NUM_CHANNELS-1:0]              avalon_st_rx_startofpacket;
    wire    [NUM_CHANNELS-1:0]              avalon_st_rx_endofpacket;
    wire    [NUM_CHANNELS-1:0]              avalon_st_rx_valid;
    wire    [NUM_CHANNELS-1:0]              avalon_st_rx_ready;
    wire    [NUM_CHANNELS-1:0][63:0]        avalon_st_rx_data;
    wire    [NUM_CHANNELS-1:0][2:0]         avalon_st_rx_empty;
    wire    [NUM_CHANNELS-1:0][5:0]         avalon_st_rx_error;

    wire    [NUM_CHANNELS-1:0]              avalon_st_tx_status_valid;          
    wire    [NUM_CHANNELS-1:0][39:0]        avalon_st_tx_status_data;           
    wire    [NUM_CHANNELS-1:0][6:0]         avalon_st_tx_status_error;              
    wire    [NUM_CHANNELS-1:0]              avalon_st_rx_status_valid;           
    wire    [NUM_CHANNELS-1:0][39:0]        avalon_st_rx_status_data;            
    wire    [NUM_CHANNELS-1:0][6:0]         avalon_st_rx_status_error; 


    
     // Timestamp request
    wire    [NUM_CHANNELS-1:0]                              tx_egress_timestamp_request_valid;
    wire    [NUM_CHANNELS-1:0][TSTAMP_FP_WIDTH - 1:0]       tx_egress_timestamp_request_fingerprint;
    
    // TX Ingress Timestamp correction - temporary not use
    wire    [NUM_CHANNELS-1:0]                              tx_ingress_timestamp_valid      = 'h0;
    wire    [NUM_CHANNELS-1:0][95:0]                        tx_ingress_timestamp_96b_data   = 'h0;
    wire    [NUM_CHANNELS-1:0][63:0]                        tx_ingress_timestamp_64b_data   = 'h0;
    wire    [NUM_CHANNELS-1:0]                              tx_ingress_timestamp_format     = 'h0;
    

    // output RX timestamp 
    wire    [NUM_CHANNELS-1:0]                              rx_ingress_timestamp_96b_valid;
    wire    [NUM_CHANNELS-1:0][95:0]                        rx_ingress_timestamp_96b_data;
    
    wire    [NUM_CHANNELS-1:0]                              rx_ingress_timestamp_64b_valid;
    wire    [NUM_CHANNELS-1:0][63:0]                        rx_ingress_timestamp_64b_data;
     

    // output TX timestamp and fingerprint
    wire    [NUM_CHANNELS-1:0]                              tx_egress_timestamp_96b_valid;
    wire    [NUM_CHANNELS-1:0][95:0]                        tx_egress_timestamp_96b_data;
    wire    [NUM_CHANNELS-1:0][TSTAMP_FP_WIDTH - 1:0]       tx_egress_timestamp_96b_fingerprint;
    
    wire    [NUM_CHANNELS-1:0]                              tx_egress_timestamp_64b_valid;
    wire    [NUM_CHANNELS-1:0][63:0]                        tx_egress_timestamp_64b_data;
    wire    [NUM_CHANNELS-1:0][TSTAMP_FP_WIDTH - 1:0]       tx_egress_timestamp_64b_fingerprint;

    wire    [NUM_CHANNELS-1:0]                              start_tod_sync;

    wire                                                    master_pulse_per_second;  
    wire    [NUM_CHANNELS-1:0]                              pps_10g;
    wire    [NUM_CHANNELS-1:0]                              pps_1g;
        
    
    wire    [NUM_CHANNELS-1:0]                              channel_ready;
    
    wire                                                    xgmii_clk_reset_n;
    wire                                                    top_mm_clk_reset_n;

    wire    scl_in;
    wire    scl_out;
    wire    scl_oe_h;
    wire    sda_in;
    wire    sda_out;
    wire    sda_oe_h;
    
    wire [17:0]     two_wire_controller_csr_address;
    wire            two_wire_controller_csr_read;
    wire            two_wire_controller_csr_write;
    wire [31:0]     two_wire_controller_csr_writedata;
    wire [31:0]     two_wire_controller_csr_readdata;
    wire            two_wire_controller_csr_waitrequest;
    wire            two_wire_controller_csr_readdata_valid;
    
    
    assign sfp_txdisable = 1'b0;
    assign xfp_txdisable= 1'b0; 
    
    assign channel_ready_n = ~ channel_ready;   
   
//==============================Async Reset synchronization================================     
    
    //AVMM Clock Reset Sync
    altera_std_synchronizer #(2) sync_u0 (
        .clk        (mm_clk),
        .reset_n    (master_reset_n),
        .din        (1'b1),
        .dout       (top_mm_clk_reset_n)
    );  
        
    //XGMII Clock Reset Sync
    altera_std_synchronizer #(2) sync_u1 (
        .clk        (xgmii_clk),
        .reset_n    (master_reset_n),
        .din        (1'b1),
        .dout       (xgmii_clk_reset_n)
    );  
    
//==============================Multi Channel MAC and PHY================================   
    altera_eth_multi_channel_1588 #(
        .NUM_CHANNELS(NUM_CHANNELS),                    // range from 1-12
        .TSTAMP_FP_WIDTH (TSTAMP_FP_WIDTH),             // Time Stamp Fingerprint data width, must follow MAC Megacore "TSTAMP_FP_WIDTH"
        .SV_RCN_BUNDLE_MODE (2),                        // mode0-10GBaseKR, mode1-1G10G without 1588, mode2 -1G10G with 1588  
        .MDIO_MDC_CLOCK_DIVISOR (32),                   // MDIO Clock Divider
        .SHARED_REFCLK_EN (1)
    ) altera_eth_multi_channel_1588_inst (
        .mm_clk                                         (mm_clk),
        .xgmii_clk                                      (xgmii_clk),
      
        .master_reset_n                                 (master_reset_n),
        .channel_reset_n                                (channel_reset_n),
    

        .pll_ref_clk_1g                                 (ref_clk_1g),
        .pll_ref_clk_10g                                (ref_clk_10g),

        .cdr_ref_clk_10g                                (ref_clk_10g),            
        .cdr_ref_clk_1g                                 (ref_clk_1g),                                            

        .rx_recovered_clk                               (rx_recovered_clk),             
 
        .rx_serial_data                                 (rx_serial_data),
        .tx_serial_data                                 (tx_serial_data),
   
        .avalon_st_tx_startofpacket                     (avalon_st_tx_startofpacket),
        .avalon_st_tx_endofpacket                       (avalon_st_tx_endofpacket),
        .avalon_st_tx_valid                             (avalon_st_tx_valid),
        .avalon_st_tx_ready                             (avalon_st_tx_ready),
        .avalon_st_tx_data                              (avalon_st_tx_data),
        .avalon_st_tx_empty                             (avalon_st_tx_empty),
        .avalon_st_tx_error                             (avalon_st_tx_error),

        .avalon_st_rx_startofpacket                     (avalon_st_rx_startofpacket),
        .avalon_st_rx_endofpacket                       (avalon_st_rx_endofpacket),
        .avalon_st_rx_valid                             (avalon_st_rx_valid),
        .avalon_st_rx_ready                             (avalon_st_rx_ready),
        .avalon_st_rx_data                              (avalon_st_rx_data),
        .avalon_st_rx_empty                             (avalon_st_rx_empty),
        .avalon_st_rx_error                             (avalon_st_rx_error),

        .avalon_st_tx_status_valid                      (avalon_st_tx_status_valid),                      
        .avalon_st_tx_status_data                       (avalon_st_tx_status_data),                       
        .avalon_st_tx_status_error                      (avalon_st_tx_status_error),                        
        .avalon_st_rx_status_valid                      (avalon_st_rx_status_valid),                       
        .avalon_st_rx_status_data                       (avalon_st_rx_status_data),                        
        .avalon_st_rx_status_error                      (avalon_st_rx_status_error), 
        
        .avalon_st_pause_data                           ({NUM_CHANNELS{2'h0}}), 
                                                    
        .address                                        (multi_channel_address),
        .waitrequest                                    (multi_channel_waitrequest),
        .read                                           (multi_channel_read),       
        .readdata                                       (multi_channel_readdata),   
        .write                                          (multi_channel_write),      
        .writedata                                      (multi_channel_writedata),
        
        .channel_ready                                  (channel_ready),
        .ethernet_1g_an                                 (led_an), 
        .ethernet_1g_char_err                           (led_char_err), 
        .ethernet_1g_disp_err                           (led_disp_err),       
        
        .mdio_mdc                                       (mdio_mdc),                       
        .mdio_in                                        (mdio_in),                   
        .mdio_out                                       (mdio_out),                   
        .mdio_oen                                       (mdio_oen),

        .tx_egress_timestamp_request_in_valid           (tx_egress_timestamp_request_valid),
        .tx_egress_timestamp_request_in_fingerprint     (tx_egress_timestamp_request_fingerprint),
    
        .tx_ingress_timestamp_valid                     (tx_ingress_timestamp_valid),
        .tx_ingress_timestamp_96b_data                  (tx_ingress_timestamp_96b_data),
        .tx_ingress_timestamp_64b_data                  (tx_ingress_timestamp_64b_data),
        .tx_ingress_timestamp_format                    (tx_ingress_timestamp_format),
                                                        
        .tx_egress_timestamp_96b_valid                  (tx_egress_timestamp_96b_valid),
        .tx_egress_timestamp_96b_data                   (tx_egress_timestamp_96b_data),
        .tx_egress_timestamp_96b_fingerprint            (tx_egress_timestamp_96b_fingerprint),
                                                        
        .tx_egress_timestamp_64b_valid                  (tx_egress_timestamp_64b_valid),
        .tx_egress_timestamp_64b_data                   (tx_egress_timestamp_64b_data),
        .tx_egress_timestamp_64b_fingerprint            (tx_egress_timestamp_64b_fingerprint),
                                                        
        .rx_ingress_timestamp_96b_valid                 (rx_ingress_timestamp_96b_valid),
        .rx_ingress_timestamp_96b_data                  (rx_ingress_timestamp_96b_data),
                                                        
        .rx_ingress_timestamp_64b_valid                 (rx_ingress_timestamp_64b_valid),
        .rx_ingress_timestamp_64b_data                  (rx_ingress_timestamp_64b_data),
    
        .start_tod_sync                                 (start_tod_sync),
        .master_pulse_per_second                        (master_pulse_per_second),
        .pulse_per_second_10g                           (pps_10g),
        .pulse_per_second_1g                            (pps_1g),
    
 
        // Configuration
        .clock_operation_mode_mode                      ({NUM_CHANNELS{ORDINARY_CLOCK}}),
        .pkt_with_crc_mode                              ({NUM_CHANNELS{1'b0}})    
    );
      
//==============================TRAFFIC_CTRL================================ 

//number of channel must set to 2 and fingerprint width must set to 4
    genvar portid;
    generate
  
    for (portid =0; portid <(divceil(NUM_CHANNELS, 2)); portid = portid+1)
    begin: ETH_TRAFFIC_CTRL_PAIR_CHANNEL

        if((ODD_NUM_CHANNEL == 1) && (portid == LAST_TRAFIIC_CTRL_PAIR)) begin

            eth_traffic_controller_top  #(2,4) eth_traffic_controller_top_u0 (
                .clk                                                (xgmii_clk),
                .reset_n                                            (xgmii_clk_reset_n),
            
                .avl_mm_read                                        (traffic_controller_read[portid]),
                .avl_mm_write                                       (traffic_controller_write[portid]),
                .avl_mm_waitrequest                                 (traffic_controller_waitrequest[portid]),
                .avl_mm_baddress                                    (traffic_controller_address[portid]),
                .avl_mm_readdata                                    (traffic_controller_readdata[portid]),
                .avl_mm_writedata                                   (traffic_controller_writedata[portid]),
                
                .avl_st_tx_data                                     ({       avalon_st_tx_data                       [2*portid] }),
                .avl_st_tx_empty                                    ({       avalon_st_tx_empty                      [2*portid] }),
                .avl_st_tx_eop                                      ({       avalon_st_tx_endofpacket                [2*portid] }),                                   
                .avl_st_tx_error                                    ({       avalon_st_tx_error                      [2*portid] }),
                .avl_st_tx_ready                                    ({ 1'b0, avalon_st_tx_ready                      [2*portid] }),
                .avl_st_tx_sop                                      ({       avalon_st_tx_startofpacket              [2*portid] }),                                     
                .avl_st_tx_val                                      ({       avalon_st_tx_valid                      [2*portid] }),                                                 
                                                                    
                .avl_st_rx_data                                     ({64'h0, avalon_st_rx_data                       [2*portid] }),                                  
                .avl_st_rx_empty                                    ({ 3'h0, avalon_st_rx_empty                      [2*portid] }),
                .avl_st_rx_eop                                      ({ 1'b0, avalon_st_rx_endofpacket                [2*portid] }),                                   
                .avl_st_rx_error                                    ({ 6'h0, avalon_st_rx_error                      [2*portid] }),
                .avl_st_rx_ready                                    ({       avalon_st_rx_ready                      [2*portid] }),
                .avl_st_rx_sop                                      ({ 1'b0, avalon_st_rx_startofpacket              [2*portid] }),
                .avl_st_rx_val                                      ({ 1'b0, avalon_st_rx_valid                      [2*portid] }),
            
                .avl_st_tx_status_valid                             ({ 1'b0, avalon_st_tx_status_valid               [2*portid] }),
                .avl_st_tx_status_data                              ({40'h0, avalon_st_tx_status_data                [2*portid] }),                               
                .avl_st_tx_status_error                             ({ 7'h0, avalon_st_tx_status_error               [2*portid] }),
                                                                    
                .avl_st_rx_status_valid                             ({ 1'b0, avalon_st_rx_status_valid               [2*portid] }),
                .avl_st_rx_status_data                              ({40'h0, avalon_st_rx_status_data                [2*portid] }),                               
                .avl_st_rx_status_error                             ({ 7'h0, avalon_st_rx_status_error               [2*portid] }),
            
                .tx_egress_timestamp_96b_valid                      ({ 1'b0, tx_egress_timestamp_96b_valid           [2*portid] }), 
                .tx_egress_timestamp_96b_data                       ({96'h0, tx_egress_timestamp_96b_data            [2*portid] }), 
                .tx_egress_timestamp_96b_fingerprint                ({{TSTAMP_FP_WIDTH{1'b0}}, tx_egress_timestamp_96b_fingerprint[2*portid] }), 
        
                .tx_egress_timestamp_request_fingerprint            ({       tx_egress_timestamp_request_fingerprint [2*portid] }), 
                .tx_egress_timestamp_request_valid                  ({       tx_egress_timestamp_request_valid       [2*portid] }),
        
                .rx_ingress_timestamp_96b_valid                     ({ 1'b0, rx_ingress_timestamp_96b_valid          [2*portid] }), 
                .rx_ingress_timestamp_96b_data                      ({96'h0, rx_ingress_timestamp_96b_data           [2*portid] }),
            
                .eth_std_stop_mon                                   (2'b00),
                .eth_std_mon_active                                 (),
                .eth_std_mon_done                                   (),
                .eth_std_mon_error                                  (),
                
                .eth_1588_wait_limit                                (1'b1),
                .eth_1588_start_tod_sync                            ({       start_tod_sync                          [2*portid] }),
                .eth_1588_channel_ready                             ({ 1'b0, channel_ready                           [2*portid] }),
                .eth_1588_traffic_controller_error_n                (error_n[portid])
            );    

        end
        else begin

            eth_traffic_controller_top  #(2,4) eth_traffic_controller_top_u0 (
                .clk                                                (xgmii_clk),
                .reset_n                                            (xgmii_clk_reset_n),
            
                .avl_mm_read                                        (traffic_controller_read[portid]),
                .avl_mm_write                                       (traffic_controller_write[portid]),
                .avl_mm_waitrequest                                 (traffic_controller_waitrequest[portid]),
                .avl_mm_baddress                                    (traffic_controller_address[portid]),
                .avl_mm_readdata                                    (traffic_controller_readdata[portid]),
                .avl_mm_writedata                                   (traffic_controller_writedata[portid]),
                
                .avl_st_tx_data                                     (avalon_st_tx_data                       [2*(portid+1)-1: 2*portid]),
                .avl_st_tx_empty                                    (avalon_st_tx_empty                      [2*(portid+1)-1: 2*portid]),
                .avl_st_tx_eop                                      (avalon_st_tx_endofpacket                [2*(portid+1)-1: 2*portid]),                                   
                .avl_st_tx_error                                    (avalon_st_tx_error                      [2*(portid+1)-1: 2*portid]),
                .avl_st_tx_ready                                    (avalon_st_tx_ready                      [2*(portid+1)-1: 2*portid]),
                .avl_st_tx_sop                                      (avalon_st_tx_startofpacket              [2*(portid+1)-1: 2*portid]),                                     
                .avl_st_tx_val                                      (avalon_st_tx_valid                      [2*(portid+1)-1: 2*portid]),                                                 
                                                                    
                .avl_st_rx_data                                     (avalon_st_rx_data                       [2*(portid+1)-1: 2*portid]),                                  
                .avl_st_rx_empty                                    (avalon_st_rx_empty                      [2*(portid+1)-1: 2*portid]),
                .avl_st_rx_eop                                      (avalon_st_rx_endofpacket                [2*(portid+1)-1: 2*portid]),                                   
                .avl_st_rx_error                                    (avalon_st_rx_error                      [2*(portid+1)-1: 2*portid]),
                .avl_st_rx_ready                                    (avalon_st_rx_ready                      [2*(portid+1)-1: 2*portid]),
                .avl_st_rx_sop                                      (avalon_st_rx_startofpacket              [2*(portid+1)-1: 2*portid]),
                .avl_st_rx_val                                      (avalon_st_rx_valid                      [2*(portid+1)-1: 2*portid]),
            
                .avl_st_tx_status_valid                             (avalon_st_tx_status_valid               [2*(portid+1)-1: 2*portid]),
                .avl_st_tx_status_data                              (avalon_st_tx_status_data                [2*(portid+1)-1: 2*portid]),                               
                .avl_st_tx_status_error                             (avalon_st_tx_status_error               [2*(portid+1)-1: 2*portid]),
                                                                    
                .avl_st_rx_status_valid                             (avalon_st_rx_status_valid               [2*(portid+1)-1: 2*portid]),
                .avl_st_rx_status_data                              (avalon_st_rx_status_data                [2*(portid+1)-1: 2*portid]),                               
                .avl_st_rx_status_error                             (avalon_st_rx_status_error               [2*(portid+1)-1: 2*portid]),
            
                .tx_egress_timestamp_96b_valid                      (tx_egress_timestamp_96b_valid           [2*(portid+1)-1: 2*portid]), 
                .tx_egress_timestamp_96b_data                       (tx_egress_timestamp_96b_data            [2*(portid+1)-1: 2*portid]), 
                .tx_egress_timestamp_96b_fingerprint                (tx_egress_timestamp_96b_fingerprint     [2*(portid+1)-1: 2*portid]), 
        
                .tx_egress_timestamp_request_fingerprint            (tx_egress_timestamp_request_fingerprint [2*(portid+1)-1: 2*portid]), 
                .tx_egress_timestamp_request_valid                  (tx_egress_timestamp_request_valid       [2*(portid+1)-1: 2*portid]),
        
                .rx_ingress_timestamp_96b_valid                     (rx_ingress_timestamp_96b_valid          [2*(portid+1)-1: 2*portid]), 
                .rx_ingress_timestamp_96b_data                      (rx_ingress_timestamp_96b_data           [2*(portid+1)-1: 2*portid]),
            
                .eth_std_stop_mon                                   (2'b00),
                .eth_std_mon_active                                 (),
                .eth_std_mon_done                                   (),
                .eth_std_mon_error                                  (),
                
                .eth_1588_wait_limit                                (1'b1),
                .eth_1588_start_tod_sync                            (start_tod_sync                          [2*(portid+1)-1: 2*portid]),
                .eth_1588_channel_ready                             (channel_ready                           [2*(portid+1)-1: 2*portid]),
                .eth_1588_traffic_controller_error_n                (error_n[portid])
            );   

        end
    end
endgenerate 
 
//==============================JTAG MASTER================================     
    altera_jtag_avalon_master JTAG_MASTER (
        .master_0_clk_clk                           (mm_clk),                                   
        .master_0_clk_reset_reset                   (~top_mm_clk_reset_n),                  
        .master_0_master_address                    (jtag_if_address),          
        .master_0_master_readdata                   (jtag_if_readdata),         
        .master_0_master_read                       (jtag_if_read),                     
        .master_0_master_write                      (jtag_if_write),            
