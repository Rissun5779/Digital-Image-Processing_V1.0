set_global_assignment -name PBIP_FILE rtl/altera_eth_1588_tod/alt_mge_1588_tod_sync_96b_2p5g.ip
set_global_assignment -name PBIP_FILE rtl/altera_eth_packet_classifier/alt_mge_packet_classifier.ip
@@ }
set_global_assignment -name QIP_FILE rtl/ethernet_traffic_controller/eth_traffic_controller_top.qip
set_global_assignment -name PRESERVE_UNUSED_XCVR_CHANNEL ON
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "alt_mge_rd:DUT|alt_mge_channel:CHANNEL_GEN[*].u_channel|alt_mge_reset_synchronizer:u_rst_sync_gmii16b_tx_clk|alt_mge_reset_synchronizer_int_chain_out*"
set_instance_assignment -name GLOBAL_SIGNAL OFF -to "alt_mge_rd:DUT|alt_mge_channel:CHANNEL_GEN[*].u_channel|alt_mge_mac:mac|alt_em10g32:alt_em10g32_0|alt_em10g32_clk_rst:clk_rst_inst|alt_em10g32_rst_cnt:tx_reset_count_inst|rst_n_out"
set_instance_assignment -name PARTITION_HIERARCHY root_partition -to | -section_id Top
