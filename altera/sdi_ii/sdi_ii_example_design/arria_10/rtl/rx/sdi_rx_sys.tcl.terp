add_instance rx_phy_rst_ctrl altera_xcvr_reset_control
set_instance_parameter_value rx_phy_rst_ctrl {SYS_CLK_IN_MHZ} {100}
set_instance_parameter_value rx_phy_rst_ctrl {SYNCHRONIZE_RESET} {0}
set_instance_parameter_value rx_phy_rst_ctrl {TX_PLL_ENABLE} {0}
set_instance_parameter_value rx_phy_rst_ctrl {TX_ENABLE} {0}
set_instance_parameter_value rx_phy_rst_ctrl {RX_ENABLE} {1}
set_instance_parameter_value rx_phy_rst_ctrl {RX_PER_CHANNEL} {1}
set_instance_parameter_value rx_phy_rst_ctrl {gui_rx_auto_reset} {2}
set_instance_parameter_value rx_phy_rst_ctrl {T_RX_ANALOGRESET} {70000}
set_instance_parameter_value rx_phy_rst_ctrl {T_RX_DIGITALRESET} {4000}

add_instance rx_sdi sdi_ii
set_instance_parameter_value rx_sdi {VIDEO_STANDARD} {$vid_std}
set_instance_parameter_value rx_sdi {DIRECTION} {rx}
set_instance_parameter_value rx_sdi {SD_BIT_WIDTH} {$sd_bitw}
set_instance_parameter_value rx_sdi {RX_CRC_ERROR_OUTPUT} {$rx_crc}
set_instance_parameter_value rx_sdi {RX_INC_ERR_TOLERANCE} {$err_tol}
@@ if { $vid_std == "hd" } {
set_instance_parameter_value rx_sdi {RX_EN_VPID_EXTRACT} {$pid_xtrct}
@@ } else {
set_instance_parameter_value rx_sdi {RX_EN_VPID_EXTRACT} {1}
@@ }
set_instance_parameter_value rx_sdi {ED_TXPLL_TYPE} {$ed_txpll}
set_instance_parameter_value rx_sdi {ED_TXPLL_SWITCH} {0}
set_instance_parameter_value rx_sdi {SELECT_SUPPORTED_VARIANT} {1}
set_instance_parameter_value rx_sdi {ENABLE_ED_FILESET_SYNTHESIS} {1}
set_instance_parameter_value rx_sdi {ENABLE_ED_FILESET_SIM} {1}
set_instance_parameter_value rx_sdi {SELECT_ED_FILESET} {VERILOG}
set_instance_parameter_value rx_sdi {SELECT_TARGETED_BOARD} {1}
set_instance_parameter_value rx_sdi {SELECT_CUSTOM_DEVICE} {0}

# connections and connection parameters
@@ if { $vid_std == "tr" || $vid_std == "mr" } {
add_connection reconfig_rst.out_reset rx_phy.reconfig_reset
add_connection reconfig_clk.out_clk rx_phy.reconfig_clk
@@ }
add_connection rx_cdr_refclk.out_clk rx_phy.rx_cdr_refclk0
add_connection rx_coreclk.out_clk rx_sdi.rx_coreclk
add_connection rx_rst.out_reset rx_sdi.rx_rst
add_connection rx_phy_rst_ctrl_clk.out_clk rx_phy_reset.clk
add_connection rx_phy_rst_ctrl_clk.out_clk rx_phy_rst_ctrl.clock
add_connection rx_sdi.trig_rst_ctrl rx_phy_reset.in_reset
add_connection rx_phy_reset.out_reset rx_phy_rst_ctrl.reset
@@ if { $vid_std == "mr" } {
add_connection rx_phy.rx_pma_div_clkout rx_sdi_clkout.in_clk
add_connection rx_phy.rx_pma_div_clkout rx_phy.rx_coreclkin
add_connection rx_phy.rx_pma_div_clkout rx_sdi.xcvr_rxclk
@@ } else {
add_connection rx_phy.rx_clkout rx_sdi_clkout.in_clk
add_connection rx_phy.rx_clkout rx_phy.rx_coreclkin
add_connection rx_phy.rx_clkout rx_sdi.xcvr_rxclk

add_connection rx_sdi.rx_datain rx_phy.rx_parallel_data
set_connection_parameter_value rx_sdi.rx_datain/rx_phy.rx_parallel_data endPort {}
set_connection_parameter_value rx_sdi.rx_datain/rx_phy.rx_parallel_data endPortLSB {0}
set_connection_parameter_value rx_sdi.rx_datain/rx_phy.rx_parallel_data startPort {}
set_connection_parameter_value rx_sdi.rx_datain/rx_phy.rx_parallel_data startPortLSB {0}
set_connection_parameter_value rx_sdi.rx_datain/rx_phy.rx_parallel_data width {0}
@@ }

add_connection rx_phy_rst_ctrl.rx_analogreset rx_phy.rx_analogreset
set_connection_parameter_value rx_phy_rst_ctrl.rx_analogreset/rx_phy.rx_analogreset endPort {}
set_connection_parameter_value rx_phy_rst_ctrl.rx_analogreset/rx_phy.rx_analogreset endPortLSB {0}
set_connection_parameter_value rx_phy_rst_ctrl.rx_analogreset/rx_phy.rx_analogreset startPort {}
set_connection_parameter_value rx_phy_rst_ctrl.rx_analogreset/rx_phy.rx_analogreset startPortLSB {0}
set_connection_parameter_value rx_phy_rst_ctrl.rx_analogreset/rx_phy.rx_analogreset width {0}

add_connection rx_phy_rst_ctrl.rx_digitalreset rx_phy.rx_digitalreset
set_connection_parameter_value rx_phy_rst_ctrl.rx_digitalreset/rx_phy.rx_digitalreset endPort {}
set_connection_parameter_value rx_phy_rst_ctrl.rx_digitalreset/rx_phy.rx_digitalreset endPortLSB {0}
set_connection_parameter_value rx_phy_rst_ctrl.rx_digitalreset/rx_phy.rx_digitalreset startPort {}
set_connection_parameter_value rx_phy_rst_ctrl.rx_digitalreset/rx_phy.rx_digitalreset startPortLSB {0}
set_connection_parameter_value rx_phy_rst_ctrl.rx_digitalreset/rx_phy.rx_digitalreset width {0}

add_connection rx_phy.rx_set_locktodata rx_sdi.gxb_ltd
set_connection_parameter_value rx_phy.rx_set_locktodata/rx_sdi.gxb_ltd endPort {}
set_connection_parameter_value rx_phy.rx_set_locktodata/rx_sdi.gxb_ltd endPortLSB {0}
set_connection_parameter_value rx_phy.rx_set_locktodata/rx_sdi.gxb_ltd startPort {}
set_connection_parameter_value rx_phy.rx_set_locktodata/rx_sdi.gxb_ltd startPortLSB {0}
set_connection_parameter_value rx_phy.rx_set_locktodata/rx_sdi.gxb_ltd width {0}

@@ if { $vid_std == "tr" || $vid_std == "mr" } {
set_instance_property reconfig_rst AUTO_EXPORT {true}
set_instance_property reconfig_clk AUTO_EXPORT {true}
@@ }
set_instance_property rx_phy_rst_ctrl AUTO_EXPORT {true}
set_instance_property rx_phy AUTO_EXPORT {true}
set_instance_property rx_rst AUTO_EXPORT {true}
set_instance_property rx_sdi AUTO_EXPORT {true}
set_instance_property rx_phy_rst_ctrl_clk AUTO_EXPORT {true}
set_instance_property rx_phy_rst_ctrl_clk_0 AUTO_EXPORT {true}
set_instance_property rx_coreclk AUTO_EXPORT {true}
set_instance_property rx_cdr_refclk AUTO_EXPORT {true}
set_instance_property rx_sdi_clkout AUTO_EXPORT {true}

# interconnect requirements
set_interconnect_requirement {\$system} {qsys_mm.clockCrossingAdapter} {HANDSHAKE}
set_interconnect_requirement {\$system} {qsys_mm.maxAdditionalLatency} {1}
set_interconnect_requirement {\$system} {qsys_mm.enableEccProtection} {FALSE}
set_interconnect_requirement {\$system} {qsys_mm.insertDefaultSlave} {FALSE}

save_system {sdi_rx_sys.qsys}
