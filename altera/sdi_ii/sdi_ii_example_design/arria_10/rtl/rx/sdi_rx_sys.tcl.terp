@@ set device_part  $param0
@@ set vid_std      $param1
@@ set ed_variant   $param2
@@ set ed_txpll     $param3
@@ set rx_crc       $param4
@@ set err_tol      $param5
@@ set pid_xtrct    $param6
@@ set pid_ins      $param7
@@ set sd_bitw      $param8
@@ if { $vid_std == "mr" | $ed_variant != 1 } {
@@      set cdr_refclk_freq 148.500000
@@ } else {
@@      set cdr_refclk_freq 270.000000
@@ }

# qsys scripting (.tcl) file for sdi_rx_sys
package require -exact qsys 16.0

create_system {sdi_rx_sys}

set_project_property DEVICE_FAMILY {Arria 10}
set_project_property DEVICE {$device_part}
set_project_property HIDE_FROM_IP_CATALOG {false}

# Instances and instance parameters
# (disabled instances are intentionally culled)
add_instance rx_rst altera_reset_bridge
set_instance_parameter_value rx_rst {SYNCHRONOUS_EDGES} {none}
@@ if { $vid_std == "tr" || $vid_std == "mr" } {
add_instance reconfig_rst altera_reset_bridge
set_instance_parameter_value reconfig_rst {SYNCHRONOUS_EDGES} {none}

add_instance reconfig_clk altera_clock_bridge
set_instance_parameter_value reconfig_clk {EXPLICIT_CLOCK_RATE} {100000000.0}
@@ }

add_instance rx_coreclk altera_clock_bridge
set_instance_parameter_value rx_coreclk {EXPLICIT_CLOCK_RATE} {148500000.0}
@@ # Reset input to PHY Reset controller doesn't have any clock domain assigned.
@@ # Hence, an extra altera_reset_bridge has to be created.
add_instance rx_phy_reset altera_reset_bridge
set_instance_parameter_value rx_phy_reset {SYNCHRONOUS_EDGES} {deassert}

add_instance rx_phy_rst_ctrl_clk altera_clock_bridge
set_instance_parameter_value rx_phy_rst_ctrl_clk {EXPLICIT_CLOCK_RATE} {100000000.0}
add_instance rx_cdr_refclk altera_clock_bridge
@@ if { $vid_std == "mr" | $ed_variant != 1 } {
set_instance_parameter_value rx_cdr_refclk {EXPLICIT_CLOCK_RATE} {148500000.0}
@@ } else {
set_instance_parameter_value rx_cdr_refclk {EXPLICIT_CLOCK_RATE} {270000000.0}
@@ }
add_instance rx_sdi_clkout altera_clock_bridge
@@ if { $vid_std == "hd" } {
set_instance_parameter_value rx_sdi_clkout {EXPLICIT_CLOCK_RATE} {74250000.0}
@@ } else {
set_instance_parameter_value rx_sdi_clkout {EXPLICIT_CLOCK_RATE} {148500000.0}
@@ }

add_instance rx_phy altera_xcvr_native_a10
set_instance_parameter_value rx_phy {duplex_mode} {rx}
set_instance_parameter_value rx_phy {set_cdr_refclk_freq} {$cdr_refclk_freq}
set_instance_parameter_value rx_phy {enable_ports_rx_manual_cdr_mode} {1}
@@ if { $vid_std == "tr" || $vid_std == "mr" } {
set_instance_parameter_value rx_phy {enable_port_rx_analog_reset_ack} {1}
set_instance_parameter_value rx_phy {rcfg_enable} {1}
set_instance_parameter_value rx_phy {rcfg_sv_file_enable} {1}
set_instance_parameter_value rx_phy {rcfg_multi_enable} {1}
set_instance_parameter_value rx_phy {rcfg_reduced_files_enable} {1}
set_instance_parameter_value rx_phy {rcfg_profile_select} {0}
@@ }
@@ if { $vid_std == "mr" } {
set_instance_parameter_value rx_phy {anlg_voltage} {1_0V}
set_instance_parameter_value rx_phy {protocol_mode} {basic_enh}
set_instance_parameter_value rx_phy {set_data_rate} {11880}
set_instance_parameter_value rx_phy {rcfg_iface_enable} {1}
set_instance_parameter_value rx_phy {enable_port_rx_pma_div_clkout} {1}
set_instance_parameter_value rx_phy {rx_pma_div_clkout_divider} {2}
