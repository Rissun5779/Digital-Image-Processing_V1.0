@@ set fileset_lang $param0
@@ set vid_std      $param1
@@ set ed_variant   $param2
@@ set acds_ver     $param3
@@ set direction    $param4
@@ set txclk_sw     $param5
@@ set split_array [split $acds_ver "."]
@@ set qii_ver [concat [lindex $split_array 0][lindex $split_array 1]]
source ./ncsim_setup.sh SKIP_ELAB=1 SKIP_SIM=1 USER_DEFINED_VERILOG_COMPILE_OPTIONS="+define+USE_ICD_CDR_MODEL+SDI_SIM"

@@ if { $direction == "du"  } {
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/du_top.v"
@@      if { $vid_std == "tr" || $vid_std == "mr" } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG0.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG1.sv"
@@          if { $vid_std == "mr" } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG2.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG3.sv"
@@          }
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/rcfg_sdi_cdr.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_ii_rx_rcfg_a10.sv"
@@      }
@@      if { $txclk_sw != 0 } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/rcfg_pll_sw.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/rcfg_refclk_sw.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/du/sdi_ii_tx_rcfg_a10.sv"
@@      }
@@ } else {
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS      "\$QSYS_SIMDIR/../rtl/rx/rx_top.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS      "\$QSYS_SIMDIR/../rtl/tx/tx_top.v"
@@      if { $vid_std == "tr" || $vid_std == "mr" } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/rx/rcfg_sdi_cdr.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/rx/sdi_ii_rx_rcfg_a10.sv"
@@      }
@@      if { $txclk_sw != 0 } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/tx/rcfg_pll_sw.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/tx/rcfg_refclk_sw.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/tx/sdi_ii_tx_rcfg_a10.sv"
@@      }
@@ }
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/edge_detector.sv"
@@ if { $vid_std == "tr" || $vid_std == "mr" || $txclk_sw == 1 } {
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/a10_reconfig_arbiter.sv"
@@ }
@@ if { $ed_variant == 3 } {
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/vid_pattgen/sdi_ii_colorbar_gen.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/vid_pattgen/sdi_ii_ed_vid_pattgen.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/vid_pattgen/sdi_ii_makeframe.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/../rtl/vid_pattgen/sdi_ii_patho_gen.v"
@@ } else {
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/vid_pattgen/sdi_ii_colorbar_gen.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/vid_pattgen/sdi_ii_ed_vid_pattgen.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/vid_pattgen/sdi_ii_makeframe.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/vid_pattgen/sdi_ii_patho_gen.v"
@@ }
@@ # Require incdir switch as tb_control has a line of include tb_tasks
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  +incdir+\$QSYS_SIMDIR/testbench/tb_control/ "\$QSYS_SIMDIR/testbench/tb_control/sdi_ii_tb_control.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tb_control/tb_clk_rst.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tb_control/tb_data_delay.v"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tb_control/tb_serial_delay.sv"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tx_checker/sdi_ii_tb_tx_checker.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tx_checker/tb_serial_check_counter.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tx_checker/tb_serial_descrambler.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tx_checker/tb_tx_clkout_check.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/sdi_ii_tb_rx_checker.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_data_compare.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_dual_link_sync.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_fifo_line_test.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_rxsample_test.v"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_vpid_check.v"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_frame_locked_test.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_trs_locked_test.sv"
ncvlog -sv \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/rx_checker/tb_txpll_test.sv"
ncvlog \$USER_DEFINED_VERILOG_COMPILE_OPTIONS  "\$QSYS_SIMDIR/testbench/tb_top.v"

source ./ncsim_setup.sh SKIP_FILE_COPY=1 SKIP_DEV_COM=1 SKIP_COM=1 TOP_LEVEL_NAME="tb_top" USER_DEFINED_ELAB_OPTIONS="\\"-timescale 1ns/1fs\\"" USER_DEFINED_SIM_OPTIONS=""
