@@ set fileset_lang $param0
@@ set vid_std      $param1
@@ set ed_variant   $param2
@@ set acds_ver     $param3
@@ set direction    $param4
@@ set txclk_sw     $param5
@@ set split_array [split $acds_ver "."]
@@ set qii_ver [concat [lindex $split_array 0][lindex $split_array 1]]
+systemverilogext+.sv
@@ if { $direction == "du"  } {
../../../rtl/du/du_top.v
@@      if { $vid_std == "tr" || $vid_std == "mr" } {
../../../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG0.sv
../../../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG1.sv
@@          if { $vid_std == "mr" } {
../../../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG2.sv
../../../rtl/du/sdi_rx_phy/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG3.sv
@@          }
../../../rtl/du/rcfg_sdi_cdr.sv
../../../rtl/du/sdi_ii_rx_rcfg_a10.sv
@@      }
@@      if { $txclk_sw != 0 } {
../../../rtl/du/rcfg_pll_sw.sv
../../../rtl/du/rcfg_refclk_sw.sv
../../../rtl/du/sdi_ii_tx_rcfg_a10.sv
@@      }
@@ } else {
../../../rtl/rx/rx_top.v
../../../rtl/tx/tx_top.v
@@      if { $vid_std == "tr" || $vid_std == "mr" } {
../../../rtl/rx/sdi_rx_sys/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG0.sv
../../../rtl/rx/sdi_rx_sys/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG1.sv
@@          if { $vid_std == "mr" } {
../../../rtl/rx/sdi_rx_sys/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG2.sv
../../../rtl/rx/sdi_rx_sys/altera_xcvr_native_a10_$qii_ver/sim/reconfig/altera_xcvr_native_a10_reconfig_parameters_CFG3.sv
@@          }
../../../rtl/rx/rcfg_sdi_cdr.sv
../../../rtl/rx/sdi_ii_rx_rcfg_a10.sv
@@      }
@@      if { $txclk_sw != 0 } {
../../../rtl/tx/rcfg_pll_sw.sv
../../../rtl/tx/rcfg_refclk_sw.sv
../../../rtl/tx/sdi_ii_tx_rcfg_a10.sv
@@      }
@@ }
../../../rtl/edge_detector.sv
@@ if { $vid_std == "tr" || $vid_std == "mr" || $txclk_sw == 1 } {
../../../rtl/a10_reconfig_arbiter.sv
@@ }
@@ if { $ed_variant == 3 } {
../../../rtl/vid_pattgen/sdi_ii_colorbar_gen.v
../../../rtl/vid_pattgen/sdi_ii_ed_vid_pattgen.v
../../../rtl/vid_pattgen/sdi_ii_makeframe.v
../../../rtl/vid_pattgen/sdi_ii_patho_gen.v
@@ } else {
../../testbench/vid_pattgen/sdi_ii_colorbar_gen.v
../../testbench/vid_pattgen/sdi_ii_ed_vid_pattgen.v
../../testbench/vid_pattgen/sdi_ii_makeframe.v
../../testbench/vid_pattgen/sdi_ii_patho_gen.v
@@ }
