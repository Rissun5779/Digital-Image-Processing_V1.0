wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte1_b;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte2;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte2_b;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte3;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte3_b;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte4;
wire [NUM_STREAMS*8-1:0]    sdi_rx_vpid_byte4_b;
wire [NUM_STREAMS-1:0]      sdi_rx_vpid_checksum_error;
wire [NUM_STREAMS-1:0]      sdi_rx_vpid_checksum_error_b;
wire [NUM_STREAMS-1:0]      sdi_rx_vpid_valid;
wire [NUM_STREAMS-1:0]      sdi_rx_vpid_valid_b;
wire                        sdi_rx_frame_locked;
wire                        sdi_rx_dataout_valid;
wire                        tb_test_control_pattgen_dl_mapping;
wire    [3:0]               tb_test_control_pattgen_tx_format;
wire    [3:0]               tb_test_control_rx_chk_tx_format;
wire                        tb_test_control_tx_status;
wire                        tb_test_control_tx_enable_crc;
wire                        tb_test_control_tx_enable_ln;
wire                        sdi_tx_clkout;
wire                        sdi_rx_clkout;
wire                        sdi_tx_dataout_valid;
wire                        cdr_reconfig_busy;
wire                        tx_reconfig_busy;
wire                        tb_test_control_rx_chk_dl_mapping;
wire [NUM_STREAMS*20-1:0]   pattgen_dout;
