@@ set vid_std      $param0
@@ set direction    $param1
@@ set ed_variant   $param2
@@ set rx_crc       $param3
@@ set err_tol      $param4
@@ # Manually overwrite Payload ID Extraction when Direction = Tx
@@ if { $vid_std != "hd" && $direction == "tx" } {
@@ set pid_xtrct            1
@@ } else {
@@ set pid_xtrct            $param5
@@ }
@@ set pid_ins              $param6
@@ set sd_bitw              $param7
@@ set txclk_sw             $param8
@@ set internal_test        $param9
@@ # Test param
@@ set test_ln_output       $param10
@@ set test_sync_output     $param11
@@ set test_reconfig_seq    $param12
@@ set test_disturb_serial  $param13
@@ set test_dl_sync         $param14
@@ set test_data_compare    $param15
@@ set test_trs_locked      $param16
@@ set test_frame_locked    $param17
@@ set test_vpid_overwrite  $param18
@@ set test_multi_recon     $param19
@@ set test_serial_delay    $param20
@@ set test_reset_seq       $param21
@@ set test_reset_recon     $param22
@@ set test_rst_pre_ow      $param23
@@ set test_rxsample_chk    $param24
@@ set test_gen_anc         $param25
@@ set test_gen_vpid        $param26
@@ set test_vpid_pkt_count  $param27
@@ set test_err_vpid        $param28
//internal testing
`timescale 1 ps / 1 ps
module tb_top (

);

@@ if { $vid_std == "mr" } {
localparam NUM_STREAMS = 4;
@@ } else {
localparam NUM_STREAMS = 1;
@@ }

wire    [2:0]               tb_test_control_tx_std;
wire    [2:0]               tb_test_control_pattgen_tx_std;
wire    [2:0]               sdi_rx_std;
wire                        tb_test_control_tx_xcvr_refclk;
wire                        tb_test_control_rx_xcvr_refclk;
wire                        tb_test_control_rx_coreclk;
wire                        tb_test_control_tx_chk_refclk;
wire                        tb_test_control_rx_chk_refclk;
wire                        tb_test_control_reconfig_clk;
