wire    [1:0]               tb_test_control_tx_chk_start_chk;
wire    [1:0]               tb_test_control_rx_chk_start_chk;
wire                        tb_test_control_tx_pll_select;
wire                        tb_test_control_tx_clkout_match;
wire                        rx_rcfg_write;
wire                        rx_rcfg_read;
wire    [9:0]               rx_rcfg_address;
wire    [31:0]              rx_rcfg_writedata;
wire    [31:0]              rx_rcfg_readdata;
wire                        rx_rcfg_waitrequest;
wire                        tx_rcfg_write;
wire                        tx_rcfg_read;
