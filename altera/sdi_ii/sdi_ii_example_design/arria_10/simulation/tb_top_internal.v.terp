wire    [1:0]               tb_rx_checker_rxcheck_done;
wire                        tb_rx_checker_chk_completed;
wire                        tb_rx_checker_rx_check_posedge;
@@ if { $direction == "du" } {
wire    [31:0]              gxb_du_rcfg_readdata;
wire                        gxb_du_rcfg_waitrequest;
@@ } else {
wire    [31:0]              gxb_rx_rcfg_readdata;
wire                        gxb_rx_rcfg_waitrequest;
wire    [31:0]              gxb_tx_rcfg_readdata;
wire                        gxb_tx_rcfg_waitrequest;
@@ }
wire                        gxb_rcfg_write;
wire                        gxb_rcfg_read;
wire    [9:0]               gxb_rcfg_address;
wire    [31:0]              gxb_rcfg_writedata;

sdi_ii_tb_control #(
    .FAMILY               ("Arria 10"),
    .VIDEO_STANDARD       ("$vid_std"),
    .DIRECTION            ("$direction"),
    .RX_INC_ERR_TOLERANCE ($err_tol),
    .RX_CRC_ERROR_OUTPUT  ($rx_crc),
    .RX_EN_A2B_CONV       (0),
    .RX_EN_B2A_CONV       (0),
    .ED_TXPLL_SWITCH      ($txclk_sw),
    .TEST_LN_OUTPUT       ($test_ln_output),
    .TEST_SYNC_OUTPUT     ($test_sync_output),
    .TEST_RECONFIG_SEQ    ("$test_reconfig_seq"),
    .TEST_DISTURB_SERIAL  ($test_disturb_serial),
    .TEST_DL_SYNC         ($test_dl_sync),
    .TEST_TRS_LOCKED      ($test_trs_locked),
    .TEST_FRAME_LOCKED    ($test_frame_locked),
    .TEST_VPID_OVERWRITE  ($test_vpid_overwrite),
    .TEST_MULTI_RECON     ($test_multi_recon),
    .TEST_SERIAL_DELAY    ($test_serial_delay),
    .TEST_RESET_SEQ       ($test_reset_seq),
    .TEST_RESET_RECON     ($test_reset_recon),
    .TEST_RST_PRE_OW      ($test_rst_pre_ow),
    .TEST_RXSAMPLE_CHK    ($test_rxsample_chk),
@@ if { $vid_std != "mr" && $ed_variant == 1 } {
    .DEVKIT_A10_CDR_270M  (1),
    .VCXOLESS_TXPLL_100M  (0)
@@ } elseif { $ed_variant == 2 } {
    .DEVKIT_A10_CDR_270M  (0),
    .VCXOLESS_TXPLL_100M  (1)
@@ } else {
    .DEVKIT_A10_CDR_270M  (0),
    .VCXOLESS_TXPLL_100M  (0)
@@ }
) tb_test_control (
    // Clocks and resets
    .tx_xcvr_refclk               (tb_test_control_tx_xcvr_refclk),
    .rx_xcvr_refclk               (tb_test_control_rx_xcvr_refclk),
    .rx_coreclk                   (tb_test_control_rx_coreclk),
    .tx_chk_refclk                (tb_test_control_tx_chk_refclk),
    .rx_chk_refclk                (tb_test_control_rx_chk_refclk),
    .reconfig_clk                 (tb_test_control_reconfig_clk),
    .tx_rst                       (tb_test_control_tx_rst),
    .rx_rst                       (tb_test_control_rx_rst),
    .rx_chk_rst                   (tb_test_control_rx_chk_rst),
    .reconfig_rst                 (tb_test_control_reconfig_rst),
@@ if { $txclk_sw != 0 } {
    .tx_xcvr_refclk_alt           (tb_test_control_tx_xcvr_refclk_alt),
@@ } else {
    .tx_xcvr_refclk_alt           (),
@@ }
    .tx_coreclk                   (),
    .tx_rst_ch0                   (),
    .rx_rst_ch0                   (),
    .tx_xcvr_refclk_smpte372      (),
    .rx_xcvr_refclk_smpte372      (),
    .tx_coreclk_smpte372          (),
    .rx_coreclk_smpte372          (),
    .tx_rst_smpte372              (),
    .rx_rst_smpte372              (),
    .tx_phy_mgmt_clk_rst          (),
    .rx_phy_mgmt_clk_rst          (),
    .phy_mgmt_clk                 (),
    .phy_mgmt_clk_smpte372        (),
    .clk_fpga                     (),
    .sdi_gxb_powerdown            (),

    // Inputs
    .tx_sdi_serial                (sdi_tx_p),
    .tx_pll_locked                (pll_locked),
@@ if { $txclk_sw == 1 } {
    .tx_pll_locked_alt            (pll_locked_alt),
@@ } else {
    .tx_pll_locked_alt            (1'b0),
@@ }
    .tx_ready                     (tx_ready),
@@ if { $txclk_sw != 0 } {
    .tx_clkout_match              (tb_test_control_tx_clkout_match),
    .rx_check_posedge             (tb_rx_checker_rx_check_posedge),
@@ } else {
    .tx_clkout_match              (1'b0),
    .rx_check_posedge             (1'b0),
@@ }
    .rx_chk_done                  (tb_rx_checker_rxcheck_done),
    .rx_chk_completed             (tb_rx_checker_chk_completed),
    .pattgen_dout                 (20'd0),
    .pattgen_dvalid               (1'b0),
    .pattgen_dout_b               (20'd0),
    .pattgen_dvalid_b             (1'b0),
    .pattgen_trs                  (1'b0),
    .pattgen_trs_b                (1'b0),
    .tx_sdi_serial_ch1_smpte372   (1'b0),
    .tx_sdi_serial_ch1_smpte372_b (1'b0),
    .tx_sdi_serial_b              (1'b0),
    .rx_rst_proto                 (1'b0),
    .rx_sdi_start_reconfig        (1'b0),
    .rx_reconfig_busy             (1'b0),
    .rx_chk_done_ch0              (2'b00),
    .rx_chk_completed_ch0         (1'b0),

    // Outputs
    .pattgen_dl_mapping           (tb_test_control_pattgen_dl_mapping),
    .pattgen_tx_std               (tb_test_control_pattgen_tx_std),
    .pattgen_tx_format            (tb_test_control_pattgen_tx_format),
    .tx_std                       (tb_test_control_tx_std),
    .tx_status                    (tb_test_control_tx_status),
    .rx_sdi_serial                (sdi_rx_p),
    .tx_chk_tx_std                (tb_test_control_tx_chk_tx_std),
    .tx_chk_start_chk             (tb_test_control_tx_chk_start_chk),
    .rx_chk_start_chk             (tb_test_control_rx_chk_start_chk),
    .rx_chk_dl_mapping            (tb_test_control_rx_chk_dl_mapping),
    .rx_chk_tx_format             (tb_test_control_rx_chk_tx_format),
@@ if { $txclk_sw != 0 } {
    .tx_sdi_start_reconfig        (tx_sdi_start_reconfig),
    .tx_sdi_pll_sel               (tb_test_control_tx_pll_select),
@@ } else {
    .tx_sdi_start_reconfig        (),
    .tx_sdi_pll_sel               (),
@@ }
    .tx_enable_crc                (tb_test_control_tx_enable_crc),
    .tx_enable_ln                 (tb_test_control_tx_enable_ln),
    .tx_vpid_overwrite            (),
    .pattgen_bar_100_75n          (),
    .pattgen_patho                (),
    .pattgen_blank                (),
    .pattgen_no_color             (),
    .pattgen_sgmt_frame           (),
    .pattgen_ntsc_paln            (),
    .tx_dout                      (),
    .tx_dvalid                    (),
    .tx_trs                       (),
    .tx_dout_b                    (),
    .tx_dvalid_b                  (),
    .tx_trs_b                     (),
    .rx_sdi_serial_ch0            (),
    .rx_chk_start_chk_ch0         (),
    .rx_sdi_serial_ch1_smpte372   (),
    .rx_sdi_serial_ch1_smpte372_b (),
    .rx_sdi_serial_b              ()
);

reset_sync #(
    .NUM_RESET_INPUTS          (1),
    .RESET_REQ_WAIT_TIME       (1),
    .MIN_RST_ASSERTION_TIME    (3),
    .RESET_REQ_EARLY_DSRT_TIME (1)
) test_control_tx_rst_sync_inst (
// Input Clock and reset
    .reset_in0      (tb_test_control_tx_rst),
    .clk            (sdi_tx_clkout),
// Outputs
    .reset_out      (tb_test_control_tx_rst_sync)
);

reset_sync #(
    .NUM_RESET_INPUTS          (1),
    .RESET_REQ_WAIT_TIME       (1),
    .MIN_RST_ASSERTION_TIME    (3),
    .RESET_REQ_EARLY_DSRT_TIME (1)
) tx_readyn_sync_inst (
// Input Clock and reset
    .reset_in0      (~tx_ready),
    .clk            (sdi_tx_clkout),
// Outputs
    .reset_out      (tx_readyn_sync)
);

sdi_ii_ed_vid_pattgen #(
    .OUTW_MULTP          (NUM_STREAMS),
    .SD_BIT_WIDTH        ($sd_bitw),
@@ if { $pid_xtrct & !$pid_ins } {
    .TEST_GEN_ANC        (1),
    .TEST_GEN_VPID       (1),
@@ } else {
    .TEST_GEN_ANC        ($test_gen_anc),
    .TEST_GEN_VPID       ($test_gen_vpid),
@@ }
    .TEST_VPID_PKT_COUNT ($test_vpid_pkt_count),
    .TEST_ERR_VPID       ($test_err_vpid),
    .TEST_VPID_OVERWRITE ($test_vpid_overwrite)
) pattgen (
    // Clocks and resets
    .clk          (sdi_tx_clkout),
    .rst          (tb_test_control_tx_rst_sync | tx_readyn_sync),

    // Inputs
    .enable       (sdi_tx_dataout_valid),
    .tx_std       (tb_test_control_pattgen_tx_std),
    .tx_format    (tb_test_control_pattgen_tx_format),
    .dl_mapping   (tb_test_control_pattgen_dl_mapping),
    .bar_100_75n  (1'b1),
    .patho        (1'b0),
    .blank        (1'b0),
    .no_color     (1'b0),
    .sgmt_frame   (1'b0),
    .ntsc_paln    (1'b0),

    // Outputs
    .dout_valid   (pattgen_dout_valid),
    .trs          (pattgen_trs),
    .dout         (pattgen_dout),
    .ln           (pattgen_ln),
    .ln_b         (pattgen_ln_b),
    .line_f0      (pattgen_line_f0),
    .line_f1      (pattgen_line_f1),
    .vpid_byte1   (pattgen_pid_byte1),
    .vpid_byte2   (pattgen_pid_byte2),
    .vpid_byte3   (pattgen_pid_byte3),
    .vpid_byte4   (pattgen_pid_byte4),
    .vpid_byte1_b (pattgen_pid_byte1_b),
    .vpid_byte2_b (pattgen_pid_byte2_b),
    .vpid_byte3_b (pattgen_pid_byte3_b),
    .vpid_byte4_b (pattgen_pid_byte4_b),
    .dout_b       (),
    .dout_valid_b (),
    .trs_b        ()
);

@@ if { $direction == "du" } {
du_top #(
    .NUM_STREAMS                    (NUM_STREAMS)
) du_inst (
// Clock and reset
    .rx_resetn                      (~tb_test_control_rx_rst),
    .tx_resetn                      (~tb_test_control_tx_rst),
    .rx_cdr_refclk                  (tb_test_control_rx_xcvr_refclk),
    .rx_core_refclk                 (tb_test_control_rx_coreclk),
    .tx_pll_refclk                  (tb_test_control_tx_xcvr_refclk),
@@ if { $txclk_sw != 0 } {
    .tx_pll_refclk_alt              (tb_test_control_tx_xcvr_refclk_alt),
@@ }
    .tx_rcfg_mgmt_resetn            (~tb_test_control_reconfig_rst),
    .tx_rcfg_mgmt_clk               (tb_test_control_reconfig_clk),
    .rx_rcfg_mgmt_resetn            (~tb_test_control_reconfig_rst),
    .rx_rcfg_mgmt_clk               (tb_test_control_reconfig_clk),

// Inputs
    .sdi_rx_coreclk_is_ntsc_paln    (1'b0),
    .gxb_rx_serial_data             (sdi_rx_p),
@@      if { $vid_std == "tr" || $vid_std == "mr" } {
    .rx_rcfg_readdata               (rx_rcfg_readdata),
    .rx_rcfg_waitrequest            (rx_rcfg_waitrequest),
@@      }
@@      if { $vid_std == "tr" || $vid_std == "mr" || $txclk_sw == 1 } {
    .rx_rcfg_cal_busy               (rx_rcfg_cal_busy),
    .gxb_du_rcfg_write              (gxb_rcfg_write),
    .gxb_du_rcfg_read               (gxb_rcfg_read),
    .gxb_du_rcfg_address            (gxb_rcfg_address),
    .gxb_du_rcfg_writedata          (gxb_rcfg_writedata),
    .tx_rcfg_cal_busy               (tx_rcfg_cal_busy),
@@      }
@@      if { $txclk_sw == 1 } {
    .tx_rcfg_readdata               (tx_rcfg_readdata),
    .tx_rcfg_waitrequest            (tx_rcfg_waitrequest),
@@      }
@@      if { $txclk_sw != 0 } {
    .tx_pll_refclk_sel              (tb_test_control_tx_pll_select),
@@      }
    .tx_vid_data                    (pattgen_dout),
    .tx_vid_datavalid               (pattgen_dout_valid),
@@      if { $vid_std != "hd" } {
    .tx_vid_std                     (tb_test_control_tx_std),
@@      }
    .tx_vid_trs                     (pattgen_trs),
    .sdi_tx_enable_crc              (tb_test_control_tx_enable_crc),
    .sdi_tx_enable_ln               (tb_test_control_tx_enable_ln),
    .sdi_tx_ln                      (pattgen_ln),
@@      if { $vid_std != "hd" } {
    .sdi_tx_ln_b                    (pattgen_ln_b),
@@      }
@@      if { $pid_ins } {
    .sdi_tx_vpid_overwrite          (1'b1),
    .sdi_tx_line_f0                 (pattgen_line_f0),
    .sdi_tx_line_f1                 (pattgen_line_f1),
    .sdi_tx_vpid_byte1              (pattgen_pid_byte1),
    .sdi_tx_vpid_byte2              (pattgen_pid_byte2),
    .sdi_tx_vpid_byte3              (pattgen_pid_byte3),
    .sdi_tx_vpid_byte4              (pattgen_pid_byte4),
@@          if { $vid_std != "hd" } {
    .sdi_tx_vpid_byte1_b            (pattgen_pid_byte1_b),
    .sdi_tx_vpid_byte2_b            (pattgen_pid_byte2_b),
    .sdi_tx_vpid_byte3_b            (pattgen_pid_byte3_b),
    .sdi_tx_vpid_byte4_b            (pattgen_pid_byte4_b),
@@          }
@@      }
@@      if { $ed_variant == 2 } {
    // Testbench is not simulating any reconfig on PLL here
    .tx_fpll_rcfg_write             (1'b0),
    .tx_fpll_rcfg_read              (1'b0),
    .tx_fpll_rcfg_writedata         (32'd0),
    .tx_fpll_rcfg_address           (10'd0),

// Outputs
    .tx_fpll_rcfg_readdata          (),
    .tx_fpll_rcfg_waitrequest       (),
@@      } else {

// Outputs
@@      }
    .rx_vid_clkout                  (sdi_rx_clkout),
    .rx_vid_data                    (sdi_rx_dataout),
    .rx_vid_datavalid               (sdi_rx_dataout_valid),
@@      if { $vid_std != "hd" } {
    .rx_vid_std                     (sdi_rx_std),
@@      }
    .rx_vid_locked                  (sdi_rx_frame_locked),
    .rx_vid_hsync                   (sdi_rx_h),
    .rx_vid_vsync                   (sdi_rx_v),
    .rx_vid_f                       (sdi_rx_f),
    .rx_vid_trs                     (sdi_rx_trs),
    .sdi_rx_rst_proto_out           (),
    .sdi_rx_align_locked            (sdi_rx_align_locked),
    .sdi_rx_trs_locked              (sdi_rx_trs_locked),
    .sdi_rx_clkout_is_ntsc_paln     (),
    .sdi_rx_format                  (sdi_rx_format),
    .sdi_rx_ap                      (sdi_rx_ap),
