wire                        tb_test_control_tx_rst;
wire                        tb_test_control_tx_rst_sync;
wire                        tb_test_control_rx_rst;
wire                        tb_test_control_rx_chk_rst;
wire                        tb_test_control_reconfig_rst;
wire                        sdi_tx_p;
wire                        sdi_rx_p;
wire                        pll_locked;
wire                        pll_locked_alt;
wire                        tx_ready;
wire                        tx_readyn_sync;
wire                        rx_rcfg_cal_busy;
wire                        gxb_rx_cal_busy;
wire                        tx_rcfg_cal_busy;
wire                        gxb_tx_cal_busy;
wire                        sdi_rx_align_locked;
wire [NUM_STREAMS-1:0]      sdi_rx_trs_locked;
wire [NUM_STREAMS-1:0]      sdi_rx_trs;
wire [NUM_STREAMS-1:0]      sdi_rx_ap;
wire [NUM_STREAMS-1:0]      sdi_rx_eav;
wire [NUM_STREAMS-1:0]      sdi_rx_h;
wire [NUM_STREAMS-1:0]      sdi_rx_v;
wire [NUM_STREAMS-1:0]      sdi_rx_f;
wire [NUM_STREAMS*20-1:0]   sdi_rx_dataout;
wire [NUM_STREAMS*4-1:0]    sdi_rx_format;
wire [NUM_STREAMS*11-1:0]   sdi_rx_ln;
wire [NUM_STREAMS*11-1:0]   sdi_rx_ln_b;
wire [NUM_STREAMS-1:0]      sdi_rx_crc_error_c;
wire [NUM_STREAMS-1:0]      sdi_rx_crc_error_c_b;
wire [NUM_STREAMS-1:0]      sdi_rx_crc_error_y;
wire [NUM_STREAMS-1:0]      sdi_rx_crc_error_y_b;
wire [NUM_STREAMS*11-1:0]   sdi_rx_line_f0;
wire [NUM_STREAMS*11-1:0]   sdi_rx_line_f1;
