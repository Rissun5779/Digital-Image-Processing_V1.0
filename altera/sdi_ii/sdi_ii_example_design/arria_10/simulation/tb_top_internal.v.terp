@@      }
@@ } else {
    .rx_vpid_byte1            ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte2            ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte3            ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte4            ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_valid            ({NUM_STREAMS{1'b0}}),
    .rx_vpid_checksum_error   ({NUM_STREAMS{1'b0}}),
    .rx_line_f0               ({11*NUM_STREAMS{1'b0}}),
    .rx_line_f1               ({11*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte1_b          ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte2_b          ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte3_b          ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_byte4_b          ({8*NUM_STREAMS{1'b0}}),
    .rx_vpid_valid_b          ({NUM_STREAMS{1'b0}}),
    .rx_vpid_checksum_error_b ({NUM_STREAMS{1'b0}}),
@@ }
    .align_locked_b           (1'b0),
    .trs_locked_b             (1'b0),
    .dl_locked                (1'b0),
    .frame_locked_b           (1'b0),
    .rxdata_b                 (20'd0),
    .rxdata_valid_b           (1'b0),
    .rx_format                (sdi_rx_format),
@@ if { $test_data_compare } {
    .txdata                   (pattgen_dout),
    .txdata_valid             (pattgen_dout_valid),
@@ } else {
    .txdata                   ({20*NUM_STREAMS{1'b0}}),
    .txdata_valid             (1'b0),
@@ }
    .txdata_b                 (20'd0),
    .txdata_valid_b           (1'b0),
@@ if { $test_trs_locked || $test_frame_locked } {
    .rx_trs                   (sdi_rx_trs),
    .rx_eav                   (sdi_rx_eav),
@@ } else {
    .rx_trs                   ({NUM_STREAMS{1'b0}}),
    .rx_eav                   ({NUM_STREAMS{1'b0}}),
@@ }
@@ if { $rx_crc } {
    .rx_crc_error_c           (sdi_rx_crc_error_c),
    .rx_crc_error_y           (sdi_rx_crc_error_y),
@@      if { $vid_std != "hd" } {
    .rx_crc_error_c_b         (sdi_rx_crc_error_c_b),
    .rx_crc_error_y_b         (sdi_rx_crc_error_y_b),
@@      } else {
    .rx_crc_error_c_b         ({NUM_STREAMS{1'b0}}),
    .rx_crc_error_y_b         ({NUM_STREAMS{1'b0}}),
@@      }
@@ } else {
    .rx_crc_error_c           ({NUM_STREAMS{1'b0}}),
    .rx_crc_error_y           ({NUM_STREAMS{1'b0}}),
    .rx_crc_error_c_b         ({NUM_STREAMS{1'b0}}),
    .rx_crc_error_y_b         ({NUM_STREAMS{1'b0}}),
@@ }

    // Outputs
    .rxcheck_done             (tb_rx_checker_rxcheck_done),
    .chk_completed            (tb_rx_checker_chk_completed),
@@ if { $txclk_sw != 0 } {
    .rx_check_posedge         (tb_rx_checker_rx_check_posedge)
@@ } else {
    .rx_check_posedge         ()
@@ }
);

endmodule
