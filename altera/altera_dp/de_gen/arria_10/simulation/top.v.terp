// -------------------------------
// DP - CVI II Interface Signals
// -------------------------------
// CVI II Hsync and Vsync are derived from delayed versions of DP RX eol and eof signals
reg [(RX_PIXELS_PER_CLOCK-1):0]     vid_h_sync;
reg [(RX_PIXELS_PER_CLOCK-1):0]     vid_v_sync;
reg                                 h_blanking;
genvar i;
generate
    for (i=0; i<RX_PIXELS_PER_CLOCK; i=i+1) begin: CVI_SYNC
        always @(posedge dp_rx_vid_clk) 
            begin
                vid_h_sync[i] <= dp_rx_vid_eol;
                vid_v_sync[i] <= dp_rx_vid_eof;
            end
    end
endgenerate

// CVI II vid_datavalid 
always @(negedge dp_rx_resetn or posedge dp_rx_vid_clk)
begin
    if (~dp_rx_resetn)
        h_blanking <= 1'b0;
    else
        h_blanking <= dp_rx_vid_eol? 1'b1 :
                      dp_rx_vid_sol? 1'b0 :
                      h_blanking;
end

assign dp_rx_resetn = ~reset;
assign rx_cvi_h_sync = vid_h_sync;
assign rx_cvi_v_sync = vid_v_sync;
assign rx_cvi_data = dp_rx_vid_data;
assign rx_cvi_de = dp_rx_vid_valid;
assign rx_cvi_datavalid = (|dp_rx_vid_valid) | h_blanking; 
assign rx_cvi_locked = dp_rx_vid_locked;
assign rx_cvi_f = dp_rx_vid_field;


// -------------------------------------------------------------------------
// Transmitter IP Top Level
// -------------------------------------------------------------------------
tx_phy_top
#(
    .TX_SYMBOLS_PER_CLOCK           (TX_SYMBOLS_PER_CLOCK),
    .TX_MAX_LANE_COUNT              (TX_MAX_LANE_COUNT)
)
tx_phy_top_i
(
    // TX Reference Clock
    .tx_pll_refclk                  (xcvr_refclk),
    .dp_tx_clk_cal                  (dp_tx_clk_cal),
    // TX Reference Reset
    .tx_pll_resetn                  (~reset),
    .video_pll_locked               (video_pll_locked),
    // DP TX FMC Interface
    .tx_cad                         (),
    // TX Link Rate (8bits)
    .dp_tx_link_rate_8bits          (dp_tx_link_rate_8bits),
    // TX Transceiver Reconfiguration Interface (To Arbiter or Altera Reconfig module)
    .tx_rcfg_mgmt_reset             (reset),
    .tx_rcfg_mgmt_clk               (clk),
    .tx_rcfg_en                     (tx_rcfg_en),
    .tx_rcfg_write                  (tx_rcfg_write),
    .tx_rcfg_read                   (tx_rcfg_read),
    .tx_rcfg_address                (tx_rcfg_address),
    .tx_rcfg_writedata              (tx_rcfg_writedata),
    .tx_rcfg_readdata               (tx_rcfg_readdata),
    .tx_rcfg_waitrequest            (tx_rcfg_waitrequest),
    .tx_rcfg_cal_busy               (tx_rcfg_cal_busy),
    // TX Transceiver Interface
    .gxb_tx_clkout                  (gxb_tx_clkout),
    .gxb_tx_serial_data             (tx_serial_data),
    .gxb_tx_rcfg_write              (gxb_rcfg_write),
    .gxb_tx_rcfg_read               (gxb_rcfg_read),
    .gxb_tx_rcfg_address            (gxb_rcfg_address),
    .gxb_tx_rcfg_writedata          (gxb_rcfg_writedata),
    .gxb_tx_rcfg_readdata           (gxb_tx_rcfg_readdata),
    .gxb_tx_rcfg_waitrequest        (gxb_tx_rcfg_waitrequest),
    .gxb_tx_rcfg_cal_busy           (gxb_tx_rcfg_cal_busy),
    // To DP TX Core Sub-System 
    @@ if { $tx_support_analog_reconfig } {
    .dp_tx_rcfg_req                 (dp_tx_rcfg_req),
    .dp_tx_rcfg_ack                 (dp_tx_rcfg_ack),
    .dp_tx_rcfg_vod                 (dp_tx_rcfg_vod),
    .dp_tx_rcfg_emp                 (dp_tx_rcfg_emp),
    @@ }
    .dp_txpll_rcfg_req              (dp_txpll_rcfg_req),
    .dp_txpll_rcfg_ack              (dp_txpll_rcfg_ack),
    .dp_tx_rcfg_busy                (dp_tx_rcfg_busy),
    .dp_tx_parallel_data            (dp_tx_parallel_data),
    .dp_txpll_powerdown             (dp_txpll_powerdown),
    .dp_tx_cal_busy                 (dp_tx_cal_busy),
    .dp_txpll_locked                (dp_txpll_locked)
);

// -------------------------------------------------------------------------
// Transceiver Reconfiguration Arbtier
// -------------------------------------------------------------------------
a10_reconfig_arbiter 
#(
    .LANES                          (RX_MAX_LANE_COUNT),
    .DPRIO_ADDRESS_WIDTH            ((DPRIO_ADDRESS_WIDTH-2)),
    .DPRIO_DATA_WIDTH               (DPRIO_DATA_WIDTH),
    .EXPIRED_COUNTER                (70000000)  // 700ms
)
a10_reconfig_arbiter_i
(
    .clk                            (clk),
    .reset                          (reset),

    .rx_rcfg_en                     (rx_rcfg_en),
    .rx_rcfg_ch                     (rx_rcfg_address[11:10]),
    .rx_reconfig_mgmt_write         (rx_rcfg_write),
    .rx_reconfig_mgmt_read          (rx_rcfg_read),
    .rx_reconfig_mgmt_address       (rx_rcfg_address[9:0]),
    .rx_reconfig_mgmt_writedata     (rx_rcfg_writedata),
    .rx_reconfig_mgmt_readdata      (rx_rcfg_readdata),
    .rx_reconfig_mgmt_waitrequest   (rx_rcfg_waitrequest),
    .rx_reconfig_cal_busy           (rx_rcfg_cal_busy),

    .tx_rcfg_en                     (tx_rcfg_en),
    .tx_rcfg_ch                     (tx_rcfg_address[11:10]),
    .tx_reconfig_mgmt_write         (tx_rcfg_write),
    .tx_reconfig_mgmt_read          (tx_rcfg_read),
    .tx_reconfig_mgmt_address       (tx_rcfg_address[9:0]),
    .tx_reconfig_mgmt_writedata     (tx_rcfg_writedata),
    .tx_reconfig_mgmt_readdata      (tx_rcfg_readdata),
    .tx_reconfig_mgmt_waitrequest   (tx_rcfg_waitrequest),
    .tx_reconfig_cal_busy           (tx_rcfg_cal_busy),

    .reconfig_write                 (gxb_rcfg_write),
    .reconfig_read                  (gxb_rcfg_read),
    .reconfig_address               (gxb_rcfg_address),
    .reconfig_writedata             (gxb_rcfg_writedata),
    .rx_reconfig_readdata           (gxb_rx_rcfg_readdata),
    .rx_reconfig_waitrequest        (gxb_rx_rcfg_waitrequest),
    .tx_reconfig_readdata           (gxb_tx_rcfg_readdata),
    .tx_reconfig_waitrequest        (gxb_tx_rcfg_waitrequest),
    .rx_cal_busy                    (gxb_rx_rcfg_cal_busy),
    .tx_cal_busy                    (gxb_tx_rcfg_cal_busy)
);

endmodule
