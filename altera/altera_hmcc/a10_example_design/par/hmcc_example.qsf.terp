set_instance_assignment -name XCVR_A10_RX_EQ_DC_GAIN_TRIM STG1_GAIN7 -to hmc_lxrx[13]
set_instance_assignment -name XCVR_A10_RX_EQ_DC_GAIN_TRIM STG1_GAIN7 -to hmc_lxrx[14]
set_instance_assignment -name XCVR_A10_RX_EQ_DC_GAIN_TRIM STG1_GAIN7 -to hmc_lxrx[15]

set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[8]
set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[9]
set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[10]
set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[11]
