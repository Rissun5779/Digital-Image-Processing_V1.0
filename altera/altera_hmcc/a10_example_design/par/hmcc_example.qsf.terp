set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[13]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[14]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[15]
@@   } else {
# The recommended value for line rates between 11.3Gbps and 17.4Gbps is 1.03V but the Arria 10 dev. kit board is set to 1.0V
# **** Adjust to reflect the voltage on your board. ****
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[8]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[9]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[10]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[11]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[12]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[13]
