set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[14]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[15]

set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[8]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[9]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxtx[10]
