set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[13]
set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[14]
set_instance_assignment -name XCVR_A10_TX_COMPENSATION_EN ENABLE -to hmc_lxtx[15]

@@   if {$data_rate == 10} {
# The recommended value for line rates below 11.3Gbps is 0.9V but the Arria 10 dev. kit board is set to 1.0V
# **** Adjust to reflect the voltage on your board. ****
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[8]
set_instance_assignment -name XCVR_VCCR_VCCT_VOLTAGE 1_0V -to hmc_lxrx[9]
