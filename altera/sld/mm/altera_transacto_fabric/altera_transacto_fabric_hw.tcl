add_interface clk clock end

add_interface reset reset end

add_interface h2t avalon_streaming end

add_interface t2h avalon_streaming start
set_interface_assignment h2t debug.interfaceGroup {associatedT2h t2h}
# | 
# +-----------------------------------

proc compose {} {
	add_instance clock altera_clock_bridge
	set_interface_property clk export_of clock.in_clk

	add_instance debug_reset altera_reset_bridge
	set_interface_property reset export_of debug_reset.in_reset
	add_connection clock.out_clk debug_reset.clk

	add_instance transacto altera_avalon_packets_to_master
	set_instance_parameter_value transacto FAST_VER 0
	#set_instance_parameter_value transacto DATA_WIDTH 32
	add_connection clock.out_clk transacto.clk
	add_connection debug_reset.out_reset transacto.clk_reset
	set_interface_property h2t export_of transacto.in_stream
	set_interface_property t2h export_of transacto.out_stream

	add_instance rom altera_trace_rom
	set_instance_parameter rom DATA_WIDTH 32
	set_instance_parameter rom DEBUG_TYPE_NAME "slave_config.rom"
	set_instance_parameter_value rom REG_VALUE_STRING 00000000
	add_connection clock.out_clk rom.clk
	add_connection debug_reset.out_reset rom.reset
	add_connection transacto.avalon_master rom.rom
	set_connection_parameter_value transacto.avalon_master/rom.rom baseAddress 0
	set_connection_parameter_value transacto.avalon_master/rom.rom defaultConnection 1

	set settings [get_parameter_value SETTINGS]
#send_message {info text} "Settings: $settings"

	# Work out the maximum width of any slave
	set n [llength $settings]
	set max_addr_width 10
	for { set i 0 } { $i < $n } { incr i } {
		set setting [lindex $settings $i]

		array set conf {data_width 8 addr_width 10 has_rdv 1}
		catch {array set conf $setting}
		
		if {$max_addr_width < $conf(addr_width)} {
			set max_addr_width $conf(addr_width)
		}
	}

	set transacto_data_width 32
	set transacto_addr_width [expr {$max_addr_width * [log2ceil [expr {$n+1}]]}]
#	set_instance_parameter_value transacto ADDR_WIDTH $transacto_addr_width

	set slot_size [expr {(1 << $max_addr_width) * ($transacto_data_width / 8)}]
	set base $slot_size
	set rom_data {}

	for { set i 0 } { $i < $n } { incr i } {
		set setting [lindex $settings $i]

		array set conf {data_width 8 addr_width 10 has_rdv 1 slave_map {} }
		catch {array set conf $setting} 

#send_message {info text} "$i: [array get conf]"

		add_interface master_$i avalon start
		set_interface_property master_$i export_of bridge_$i.ext_master
		
		add_interface reset_$i reset end
		add_instance sys_reset_$i altera_reset_bridge
		set_interface_property reset_$i export_of sys_reset_$i.in_reset
		add_connection clock.out_clk sys_reset_$i.clk

		# Currently we ignore resets from the slaves
		# TODO: Insert a MM reset domain crosser here  

		add_instance bridge_$i altera_debug_master_endpoint_bridge
		add_connection clock.out_clk bridge_$i.clk
		add_connection sys_reset_$i.out_reset bridge_$i.reset

		set_instance_parameter_value bridge_$i ADDR_WIDTH $conf(addr_width)
		set_instance_parameter_value bridge_$i DATA_WIDTH $conf(data_width)
		set_instance_parameter_value bridge_$i HAS_RDV    $conf(has_rdv)

		add_connection transacto.avalon_master bridge_$i.int_master
		set_connection_parameter_value transacto.avalon_master/bridge_$i.int_master baseAddress $base
		
		# If there is a slave map then tell it about 
		set slave_map $conf(slave_map)
		
		set debug "<debug>"
		
		set j 1
		foreach slave $slave_map {
		
			array set sc {address -1 mfr_code 0 type_code 0}
			catch {array set sc $slave} 

#send_message {info text} "$i.$j: [array get sc]"
		
			set address $sc(address)
			set mfr_code $sc(mfr_code)
			set type_code $sc(type_code)
			if {$address >= 0 && $address < $slot_size && $mfr_code > 0 && $mfr_code < 0x1000 && $type_code > 0 && $type_code < 0x1000} {
				set offset [expr {$base + $address}]
				set span [expr {4<<$conf(addr_width) - $address}]
				append debug "<agent base='$offset' span='$span' type_id='$mfr_code:$type_code'/>"
			}
		
			incr j
		}

		incr base $slot_size		
	}

	append debug "</debug>"

	#send_message {debug text} "ROM XML: $debug"

	set tcl [call_helper encodeAndCompress [list $debug cs]]
	eval $tcl

	#send_message {debug text} "ROM contents: $bytes"

	set_instance_parameter_value rom REG_VALUE_STRING $bytes
	set regs [expr {[string length $bytes] / 8}]
	set_instance_parameter_value rom NUM_REGS $regs
	if {$regs > 1} {
		set_instance_parameter_value rom ADDR_WIDTH [log2ceil $regs]
	}
	# Request additional pipelining, for increased setup slack (at
	# the expense of resources and latency).
	set_interconnect_requirement {$system} qsys_mm.maxAdditionalLatency 3
}

proc log2ceil x "expr {int(ceil(log(\$x)/[expr log(2)]))}"
