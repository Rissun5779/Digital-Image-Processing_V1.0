proc elaboration {} {
	set CHANNEL_SUPPORT           [ get_parameter_value CHANNEL_SUPPORT ]
    set MAX_VW_COUNT_SUPPORTED    [ get_parameter_value MAX_VW_COUNT_SUPPORTED ]
    set MAX_PC_PAYLOAD_SIZE_RANGE [ get_parameter_value MAX_PC_PAYLOAD_SIZE_RANGE ]
    set MAX_PC_READREQ_SIZE_RANGE [ get_parameter_value MAX_PC_READREQ_SIZE_RANGE ]
	set pc_port_enable_list       [ get_parameter_value pc_port_enable_list ]
	set pc_port_output_list       [ get_parameter_value pc_port_output_list ]
	set pc_port_dwidth_list       [ get_parameter_value pc_port_dwidth_list ]
	set IO_MODE_RANGE             [ get_parameter_value IO_MODE_RANGE ]
    set PC_PORT00_EN              [ get_parameter_value PC_PORT00_EN ]
    set PC_PORT10_EN              [ get_parameter_value PC_PORT10_EN ]
    set PC_PORT20_EN              [ get_parameter_value PC_PORT20_EN ]
    set PC_PORT30_EN              [ get_parameter_value PC_PORT30_EN ]
    set PC_PORT40_EN              [ get_parameter_value PC_PORT40_EN ]
    set PC_PORT50_EN              [ get_parameter_value PC_PORT50_EN ]
    set PC_PORT60_EN              [ get_parameter_value PC_PORT60_EN ]
    set PC_PORT70_EN              [ get_parameter_value PC_PORT70_EN ]
    set PC_PORT80_EN              [ get_parameter_value PC_PORT80_EN ]
    set PC_PORT90_EN              [ get_parameter_value PC_PORT90_EN ]
    set PC_PORTA0_EN              [ get_parameter_value PC_PORTA0_EN ]
    set PC_PORT00_OUTPUT          [ get_parameter_value PC_PORT00_OUTPUT ]
	set PC_PORT10_OUTPUT          [ get_parameter_value PC_PORT10_OUTPUT ]
    set PC_PORT20_OUTPUT          [ get_parameter_value PC_PORT20_OUTPUT ]
    set PC_PORT30_OUTPUT          [ get_parameter_value PC_PORT30_OUTPUT ]
    set PC_PORT40_OUTPUT          [ get_parameter_value PC_PORT40_OUTPUT ]
    set PC_PORT50_OUTPUT          [ get_parameter_value PC_PORT50_OUTPUT ]
    set PC_PORT60_OUTPUT          [ get_parameter_value PC_PORT60_OUTPUT ]
    set PC_PORT70_OUTPUT          [ get_parameter_value PC_PORT70_OUTPUT ]
    set PC_PORT80_OUTPUT          [ get_parameter_value PC_PORT80_OUTPUT ]
    set PC_PORT90_OUTPUT          [ get_parameter_value PC_PORT90_OUTPUT ]
    set PC_PORTA0_OUTPUT          [ get_parameter_value PC_PORTA0_OUTPUT ]
	
    set_parameter_value PC_PORT00_EN [lindex $pc_port_enable_list 0] 
    set_parameter_value PORT00_DWIDTH [lindex $pc_port_dwidth_list 0] 
	
    set_parameter_value PC_PORT10_EN [lindex $pc_port_enable_list 1] 
    set_parameter_value PORT10_DWIDTH [lindex $pc_port_dwidth_list 1] 
	
    set_parameter_value PC_PORT20_EN [lindex $pc_port_enable_list 2] 
    set_parameter_value PORT20_DWIDTH [lindex $pc_port_dwidth_list 2] 
	
    set_parameter_value PC_PORT30_EN [lindex $pc_port_enable_list 3] 
    set_parameter_value PORT30_DWIDTH [lindex $pc_port_dwidth_list 3] 
	
    set_parameter_value PC_PORT40_EN [lindex $pc_port_enable_list 4] 
    set_parameter_value PORT40_DWIDTH [lindex $pc_port_dwidth_list 4] 
	
    set_parameter_value PC_PORT50_EN [lindex $pc_port_enable_list 5] 
    set_parameter_value PORT50_DWIDTH [lindex $pc_port_dwidth_list 5] 
	
    set_parameter_value PC_PORT60_EN [lindex $pc_port_enable_list 6] 
    set_parameter_value PORT60_DWIDTH [lindex $pc_port_dwidth_list 6] 

    set_parameter_value PC_PORT70_EN [lindex $pc_port_enable_list 7] 
    set_parameter_value PORT70_DWIDTH [lindex $pc_port_dwidth_list 7] 
	
    set_parameter_value PC_PORT80_EN [lindex $pc_port_enable_list 8] 
    set_parameter_value PORT80_DWIDTH [lindex $pc_port_dwidth_list 8] 
	
    set_parameter_value PC_PORT90_EN [lindex $pc_port_enable_list 9] 
    set_parameter_value PORT90_DWIDTH [lindex $pc_port_dwidth_list 9] 
	
    set_parameter_value PC_PORTA0_EN [lindex $pc_port_enable_list 10] 
    set_parameter_value PORTA0_DWIDTH [lindex $pc_port_dwidth_list 10] 
	
    if {[lindex $pc_port_output_list 0] eq "output"} {
        set_parameter_value PC_PORT00_OUTPUT 1
	} else {
        set_parameter_value PC_PORT00_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 1] eq "output"} {
        set_parameter_value PC_PORT10_OUTPUT 1
	} else {
        set_parameter_value PC_PORT10_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 2] eq "output"} {
        set_parameter_value PC_PORT20_OUTPUT 1
	} else {
        set_parameter_value PC_PORT20_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 3] eq "output"} {
        set_parameter_value PC_PORT30_OUTPUT 1
	} else {
        set_parameter_value PC_PORT30_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 4] eq "output"} {
        set_parameter_value PC_PORT40_OUTPUT 1
	} else {
        set_parameter_value PC_PORT40_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 5] eq "output"} {
        set_parameter_value PC_PORT50_OUTPUT 1
	} else {
        set_parameter_value PC_PORT50_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 6] eq "output"} {
        set_parameter_value PC_PORT60_OUTPUT 1
	} else {
        set_parameter_value PC_PORT60_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 7] eq "output"} {
        set_parameter_value PC_PORT70_OUTPUT 1
	} else {
        set_parameter_value PC_PORT70_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 8] eq "output"} {
        set_parameter_value PC_PORT80_OUTPUT 1
	} else {
        set_parameter_value PC_PORT80_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 9] eq "output"} {
        set_parameter_value PC_PORT90_OUTPUT 1
	} else {
        set_parameter_value PC_PORT90_OUTPUT 0
	}
	
    if {[lindex $pc_port_output_list 10] eq "output"} {
        set_parameter_value PC_PORTA0_OUTPUT 1
	} else {
        set_parameter_value PC_PORTA0_OUTPUT 0
	}
	
    if {$IO_MODE_RANGE == 0} {
	    set_parameter_value DWIDTH 2
	} elseif {$IO_MODE_RANGE == 1} {
	    set_parameter_value DWIDTH 2
	} elseif {$IO_MODE_RANGE == 2 || $IO_MODE_RANGE == 3} {
	    set_parameter_value DWIDTH 4
	}

	if {$CHANNEL_SUPPORT == 2 || $CHANNEL_SUPPORT == 3} {
	    set_interface_property vw_conduit ENABLED true
		set_parameter_property MAX_VW_COUNT_SUPPORTED ENABLED true
	} else {
	    set_interface_property vw_conduit ENABLED false
		set_parameter_property MAX_VW_COUNT_SUPPORTED ENABLED false
	}
	
	if {$CHANNEL_SUPPORT == 1 || $CHANNEL_SUPPORT == 3} {
	    set_interface_property pc_conduit ENABLED true
		set_parameter_property MAX_PC_PAYLOAD_SIZE_RANGE ENABLED true
        set_parameter_property MAX_PC_READREQ_SIZE_RANGE ENABLED true
		set_display_item_property "Peripheral Channel IO port setting" visible true
	} else {
	    set_interface_property pc_conduit ENABLED false
		set_parameter_property MAX_PC_PAYLOAD_SIZE_RANGE ENABLED false
        set_parameter_property MAX_PC_READREQ_SIZE_RANGE ENABLED false
		set_display_item_property "Peripheral Channel IO port setting" visible false
	}
	
	## To terminate unused ports
	if {$PC_PORT00_EN eq "true"} {
        if {$PC_PORT00_OUTPUT eq "true"} {
		    set_port_property pc_port00_in TERMINATION 1
		    set_port_property pc_port00_out TERMINATION 0
		} else {
		    set_port_property pc_port00_in TERMINATION 0
		    set_port_property pc_port00_out TERMINATION 1
		}
	} else {
		    set_port_property pc_port00_in TERMINATION 1
		    set_port_property pc_port00_out TERMINATION 1
	}
	
	if {$PC_PORT10_EN eq "true"} {
        if {$PC_PORT10_OUTPUT eq "true"} {
		    set_port_property pc_port10_in TERMINATION 1
		    set_port_property pc_port10_out TERMINATION 0
		} else {
		    set_port_property pc_port10_in TERMINATION 0
		    set_port_property pc_port10_out TERMINATION 1
		}
	} else {
		    set_port_property pc_port10_in TERMINATION 1
		    set_port_property pc_port10_out TERMINATION 1
	}
	
	if {$PC_PORT20_EN eq "true"} {
        if {$PC_PORT20_OUTPUT eq "true"} {
		    set_port_property pc_port20_in TERMINATION 1
		    set_port_property pc_port20_out TERMINATION 0
		} else {
		    set_port_property pc_port20_in TERMINATION 0
		    set_port_property pc_port20_out TERMINATION 1
		}
	} else {
		    set_port_property pc_port20_in TERMINATION 1
		    set_port_property pc_port20_out TERMINATION 1
	}
	
	if {$PC_PORT30_EN eq "true"} {
        if {$PC_PORT30_OUTPUT eq "true"} {
		    set_port_property pc_port30_in TERMINATION 1
		    set_port_property pc_port30_out TERMINATION 0
		} else {
		    set_port_property pc_port30_in TERMINATION 0
		    set_port_property pc_port30_out TERMINATION 1
		}
	} else {
		    set_port_property pc_port30_in TERMINATION 1
		    set_port_property pc_port30_out TERMINATION 1
	}
	
	if {$PC_PORT40_EN eq "true"} {
        if {$PC_PORT40_OUTPUT eq "true"} {
		    set_port_property pc_port40_in TERMINATION 1
		    set_port_property pc_port40_out TERMINATION 0
