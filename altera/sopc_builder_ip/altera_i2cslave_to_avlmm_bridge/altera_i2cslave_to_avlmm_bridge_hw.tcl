add_display_item {} ramInitMessage TEXT ""

proc elaborate {} {

	set byte_addressing [ get_parameter_value BYTE_ADDRESSING ]
	set address_stealing [ get_parameter_value ADDRESS_STEALING ]
	set read_only [ get_parameter_value READ_ONLY ]
	set ramInitMessage "</br>"
	
	if { $byte_addressing == 4 } {
		if { $address_stealing != 0 } {
			send_message error "When Byte Addressing is 4, Address Stealing bit has to be 0"
		}
    }
	
	if { $byte_addressing == 1 } {
		set addr_width 8
	} elseif { $byte_addressing == 2 } {
		set addr_width 16
	} elseif { $byte_addressing == 3 } {
		set addr_width 24
	} elseif { $byte_addressing == 4 } {
		set addr_width 32
	}
	
	if { $read_only == 1 } {
		set_port_property   write      termination true
		set_port_property   writedata  termination true
	}
	
	set ramInitMessage "$ramInitMessage<br><b>Total byte address width = address width + address stealing bit</b>" 

    if { [expr { pow(2, ($addr_width+$address_stealing)) / 1024}] >= 1024} {
		set ramInitMessage "$ramInitMessage<br><b>Accessible address space is [expr { pow(2, ($addr_width+$address_stealing)) / (1024*1024)}] MByte</b>"
	} elseif { [expr { pow(2, ($addr_width+$address_stealing)) }] >= 1024} {
		set ramInitMessage "$ramInitMessage<br><b>Accessible address space is [expr { pow(2, ($addr_width+$address_stealing)) / 1024}] KByte</b>"
	} else {
		set ramInitMessage "$ramInitMessage<br><b>Accessible address space is [expr { pow(2, ($addr_width+$address_stealing)) }] Byte</b>"
	}
	
  set htmlRamInitMessage "<html><table border=\"0\" width=\"100%\"><tr><td valign=\"top\"><font size=3>$ramInitMessage</td></tr></table></html>"
  set_display_item_property ramInitMessage TEXT $htmlRamInitMessage
}

