proc ::altera_emif::util::channel_uncertainty::get_global_channel_uncertainty_value {base_family protocol format ce_type rank_string} {

   variable multi_rank_ce
   variable single_rank_ce
   
   set sr_key "${base_family},${protocol},${format},${ce_type}"
   set mr_key "${base_family},${protocol},${format},${ce_type},${rank_string}"
   
   set sr_ce $single_rank_ce($sr_key)
   
   set has_error [catch {set mr_ce $multi_rank_ce($mr_key)}]
   if {$has_error == 1} {
      set mr_key "${base_family},${protocol},${format},${ce_type},max"
	  set mr_ce $multi_rank_ce($mr_key)
   }

   return [round_num [expr ($sr_ce + $mr_ce)/1000.0] 3]
}



