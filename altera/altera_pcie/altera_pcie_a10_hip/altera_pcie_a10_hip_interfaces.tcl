proc ::altera_pcie_a10_hip::interfaces::declare_interfaces {} {
  variable interfaces
  ip_declare_interfaces $interfaces
}

proc ::altera_pcie_a10_hip::interfaces::elaborate {} {
  ip_elaborate_interfaces
}

proc ::altera_pcie_a10_hip::interfaces::elaborate_avst_interfaces {} {

   set data_width                         [ip_get "parameter.data_width_integer_hwtcl.value"]
   set multiple_packets_per_cycle         [ip_get "parameter.multiple_packets_per_cycle_hwtcl.value"]
   set enable_avst_reset_hwtcl            0
   set interface_type_integer_hwtcl       [ip_get "parameter.interface_type_integer_hwtcl.value"]

   if { $interface_type_integer_hwtcl == 0 } {
      set enable_avst_reset_hwtcl   [ip_get "parameter.enable_avst_reset_hwtcl.value"]
   }

   #Multiple packets per Cycle
   if { $multiple_packets_per_cycle == 1 } {
     set_interface_property tx_st beatsPerCycle 2
     set_interface_property tx_st dataBitsPerSymbol 128

     set_interface_property rx_st beatsPerCycle 2
     set_interface_property rx_st dataBitsPerSymbol 128
   } else {
     set_interface_property tx_st beatsPerCycle 1
     set_interface_property tx_st dataBitsPerSymbol $data_width

     set_interface_property rx_st beatsPerCycle 1
     set_interface_property rx_st dataBitsPerSymbol $data_width
   }

   #TODO When IP_SET is fixed, remove all instances of set_interface_property
   set_interface_property tx_st maxChannel 0
   set_interface_property tx_st readyLatency 3
   set_interface_property tx_st symbolsPerBeat 1
   set_interface_property tx_st associatedClock pld_clk

   set_interface_property rx_st maxChannel 0
   set_interface_property rx_st readyLatency 3
   set_interface_property rx_st symbolsPerBeat 1
   set_interface_property rx_st associatedClock pld_clk

   if { $enable_avst_reset_hwtcl > 0 } {
      set_interface_property tx_st associatedReset clr_st
      set_interface_property rx_st associatedReset clr_st
   }

   ip_set "port.tx_st_parity.WIDTH_EXPR" [ip_get "parameter.data_byte_width_integer_hwtcl.value"]

}


