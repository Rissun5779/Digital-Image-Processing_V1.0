proc ::altera_pcie_a10_hip::parameters::validate_pf1_bar {PROP_NAME PROP_VALUE pf1_bar0_size_hwtcl pf1_bar1_size_hwtcl pf1_bar2_size_hwtcl pf1_bar3_size_hwtcl pf1_bar4_size_hwtcl pf1_bar5_size_hwtcl
      pf1_bar0_present_hwtcl pf1_bar1_present_hwtcl pf1_bar2_present_hwtcl pf1_bar3_present_hwtcl pf1_bar4_present_hwtcl pf1_bar5_present_hwtcl
      pf1_bar0_type_hwtcl pf1_bar2_type_hwtcl pf1_bar4_type_hwtcl pf1_bar0_prefetchable_hwtcl pf1_bar1_prefetchable_hwtcl pf1_bar2_prefetchable_hwtcl
      pf1_bar3_prefetchable_hwtcl pf1_bar4_prefetchable_hwtcl pf1_bar5_prefetchable_hwtcl total_pf_count_hwtcl enable_nobar_slection_hwtcl} {

   set port_type_hwtcl [ get_parameter_value port_type_hwtcl ]

   set  bar_size_hwtcl(0) [ get_parameter_value pf1_bar0_size_hwtcl ]
   set  bar_size_hwtcl(1) [ get_parameter_value pf1_bar1_size_hwtcl ]
   set  bar_size_hwtcl(2) [ get_parameter_value pf1_bar2_size_hwtcl ]
   set  bar_size_hwtcl(3) [ get_parameter_value pf1_bar3_size_hwtcl ]
   set  bar_size_hwtcl(4) [ get_parameter_value pf1_bar4_size_hwtcl ]
   set  bar_size_hwtcl(5) [ get_parameter_value pf1_bar5_size_hwtcl ]

   # BAR present
   set  bar_present_hwtcl(0) [ get_parameter_value pf1_bar0_present_hwtcl ]
   set  bar_present_hwtcl(1) [ get_parameter_value pf1_bar1_present_hwtcl ]
   set  bar_present_hwtcl(2) [ get_parameter_value pf1_bar2_present_hwtcl ]
   set  bar_present_hwtcl(3) [ get_parameter_value pf1_bar3_present_hwtcl ]
   set  bar_present_hwtcl(4) [ get_parameter_value pf1_bar4_present_hwtcl ]
   set  bar_present_hwtcl(5) [ get_parameter_value pf1_bar5_present_hwtcl ]

   # BAR Type: 1 = 64bit, 0 = 32bit
   set  bar_type_hwtcl(0) [ get_parameter_value pf1_bar0_type_hwtcl ]
   set  bar_type_hwtcl(2) [ get_parameter_value pf1_bar2_type_hwtcl ]
   set  bar_type_hwtcl(4) [ get_parameter_value pf1_bar4_type_hwtcl ]

   # BAR Prefetchable : 1 = Prefetchable, 0 = Non-Prefetchable
   set  bar_pref_hwtcl(0) [ get_parameter_value pf1_bar0_prefetchable_hwtcl ]
   set  bar_pref_hwtcl(1) [ get_parameter_value pf1_bar1_prefetchable_hwtcl ]
   set  bar_pref_hwtcl(2) [ get_parameter_value pf1_bar2_prefetchable_hwtcl ]
   set  bar_pref_hwtcl(3) [ get_parameter_value pf1_bar3_prefetchable_hwtcl ]
   set  bar_pref_hwtcl(4) [ get_parameter_value pf1_bar4_prefetchable_hwtcl ]
   set  bar_pref_hwtcl(5) [ get_parameter_value pf1_bar5_prefetchable_hwtcl ]
   set  total_pf_count    [ get_parameter_value total_pf_count_hwtcl]

   set DISABLE_BAR             0
   set PREFETACHBLE_64_BAR     1
   set NON_PREFETCHABLE_32_BAR 2
   set PREFETCHABLE_32_BAR     3
   set IO_SPACE_BAR            4

   if { [ regexp endpoint $port_type_hwtcl ] } {
      if { ($total_pf_count>=2) && ($bar_present_hwtcl(0) == $DISABLE_BAR) && ($bar_present_hwtcl(1) == $DISABLE_BAR) && ($bar_present_hwtcl(2) == $DISABLE_BAR) &&
           ($bar_present_hwtcl(3) == $DISABLE_BAR) && ($bar_present_hwtcl(4) == $DISABLE_BAR) && ($bar_present_hwtcl(5) == $DISABLE_BAR) && ($enable_nobar_slection_hwtcl == 0)} {
         send_message error "A PF1 Endpoint must enable at least one PF1 BAR"
      }
      if { [ regexp Native $port_type_hwtcl ] } {
         for {set i 0} {$i < 6} {incr i 1} {
            if { $bar_pref_hwtcl($i) == $PREFETCHABLE_32_BAR } {
               send_message error "BAR$i cannot be set to 32-bit prefetchable memory for Native Endpoints"
            }
            if { (($i==0) || ($i==2) || ($i==4)) && ($bar_type_hwtcl($i) == $IO_SPACE_BAR) } {
               send_message error "BAR$i cannot be set to IO Address Space for Native Endpoints"
            }
         }
      } else {
         send_message error "Port type must be Native Endpoint"
      }
   }

   # Setting derived parameter
   for {set i 0} {$i < 6} {incr i 1} {
      if { $bar_present_hwtcl($i)>0 } {
         if { $bar_size_hwtcl($i)==0 } {
            send_message error "The size of BAR$i is incorrectly set"
         }
      }

      if { ($bar_pref_hwtcl($i) == $PREFETACHBLE_64_BAR) } {
         if { $bar_size_hwtcl($i)<7 } {
            send_message error "The size of the 64-bit prefetchable BAR$i must be greater than 7 bits"
         }
      } elseif { $bar_pref_hwtcl($i) == $NON_PREFETCHABLE_32_BAR } {
         if { $bar_size_hwtcl($i)>31 } {
            send_message error "The size of the 32-bit non-prefetchable BAR$i must be less than 31 bits"
         }
         if { $bar_size_hwtcl($i)<7 } {
            send_message error "The size of the 32-bit non-prefetchable BAR$i must be greater than 7 bits"
         }
      } elseif { $bar_pref_hwtcl($i)== $PREFETCHABLE_32_BAR } {
         if { $bar_size_hwtcl($i)>31 } {
            send_message error "The size of the 32-bit prefetchable BAR$i must be less than 31 bits"
         }
         if { $bar_size_hwtcl($i)<7 } {
            send_message error "The size of the 32-bit prefetchable BAR$i must be greater than 7 bits"
         }
      } elseif { (($i==0) || ($i==2)) && ($bar_type_hwtcl($i) == $IO_SPACE_BAR) } {
         if { $bar_size_hwtcl($i)>12 } {
            send_message error "The size of the I/O space BAR$i must be less than 12 bits"
         }
      }
   }
