                     set additional_vfs [expr 64 - $TOTAL_VF_MOD_64 ]
                     send_message error "TOTAL_VF count must be set in multiple of 64. It is short by $additional_vfs to become multiple of 64"
                 }  elseif { ($TOTAL_VF >= 1024) && ($TOTAL_VF <= 4096) && ($TOTAL_VF_MOD_512 > 0)} {
                      set additional_vfs [expr 512 - $TOTAL_VF_MOD_512 ]
                      send_message error "TOTAL_VF count must be set in multiple of 512. It is short by $additional_vfs to become multiple of 512"
                 }
                }

          } else {
              ip_set "parameter.${PROP_NAME}.value" 4
          }
  }
}
proc ::altera_pcie_a10_hip::parameters::validate_total_pf_count_width_hwtcl { PROP_NAME PROP_VALUE total_pf_count_hwtcl } {
  set num_pfcount [expr $total_pf_count_hwtcl]
  if { $num_pfcount > 0 } {
    set num_pfcount [expr $num_pfcount - 1]
    set width  [expr $num_pfcount == 0 ? 1 : 0]
    while {$num_pfcount != 0} {
      set num_pfcount [expr $num_pfcount >> 1]
      set width  [expr $width + 1]
    }
  } else {
      set width 1
  }
  ip_set "parameter.${PROP_NAME}.value" $width
}

proc ::altera_pcie_a10_hip::parameters::validate_total_vf_count_width_hwtcl { PROP_NAME PROP_VALUE pf0_vf_count_user_hwtcl pf1_vf_count_user_hwtcl pf2_vf_count_user_hwtcl pf3_vf_count_user_hwtcl } {
