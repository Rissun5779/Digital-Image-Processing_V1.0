proc ::altera_pcie_a10_hip::parameters::validate_txs_addr_width_integer_hwtcl { PROP_NAME PROP_VALUE avmm_addr_width_hwtcl cg_a2p_addr_map_num_entries_hwtcl cg_a2p_addr_map_pass_thru_bits_hwtcl user_txs_addr_width_hwtcl} {

  if {$avmm_addr_width_hwtcl == 32} {
    set temp $cg_a2p_addr_map_pass_thru_bits_hwtcl
    switch $cg_a2p_addr_map_num_entries_hwtcl {
       1     {}
       2     {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 1]}
       4     {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 2]}
       8     {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 3]}
       16    {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 4]}
       32    {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 5]}
       64    {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 6]}
       128   {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 7]}
       256   {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 8]}
       512   {set temp [expr $cg_a2p_addr_map_pass_thru_bits_hwtcl + 9]}
       default { }
    }
    ip_set "parameter.${PROP_NAME}.value" $temp
  } else {
    ip_set "parameter.${PROP_NAME}.value" $user_txs_addr_width_hwtcl
  }
}


proc ::altera_pcie_a10_hip::parameters::validate_cg_impl_cra_av_slave_port_hwtcl { PROP_NAME PROP_VALUE cg_impl_cra_av_slave_port_hwtcl cb_pcie_mode_hwtcl cb_pcie_rx_lite_hwtcl avmm_addr_width_hwtcl} {

   if {$cb_pcie_mode_hwtcl==0 && $avmm_addr_width_hwtcl==32} {
      set legal_values 1
   } else {
      set legal_values [list 0 1]
   }
   auto_invalid_value_message auto cg_impl_cra_av_slave_port_hwtcl  $cg_impl_cra_av_slave_port_hwtcl $legal_values { cb_pcie_mode_hwtcl cb_pcie_rx_lite_hwtcl avmm_addr_width_hwtcl}
}


proc ::altera_pcie_a10_hip::parameters::validate_avmm_addr_width_hwtcl { PROP_NAME PROP_VALUE avmm_addr_width_hwtcl lane_rate link_width interface_type_integer_hwtcl interface_type_hwtcl include_dma_hwtcl } {
   set interface_type_integer_hwtcl [ip_get "parameter.interface_type_integer_hwtcl.value"]
   if { $interface_type_integer_hwtcl>0} {
      set port_type           [ip_get "parameter.port_type_hwtcl.value"]
      set interface_width     [ip_get "parameter.app_interface_width_hwtcl.value"]
      if { ($port_type=="Root port") && ($interface_width=="256-bit") } {
        set legal_values [list 32 64]
      } elseif [expr { (($lane_rate=="gen3")&& ($link_width=="x8")&&($interface_type_integer_hwtcl==1)) || $include_dma_hwtcl==1}] {
        set legal_values 64
      } else {
          set legal_values [list 32 64]
      }
      auto_invalid_value_message auto avmm_addr_width_hwtcl  $avmm_addr_width_hwtcl $legal_values { lane_rate link_width interface_type_hwtcl }
   }
}

proc ::altera_pcie_a10_hip::parameters::validate_port_type_hwtcl { PROP_NAME PROP_VALUE port_type_hwtcl lane_rate link_width app_interface_width_hwtcl interface_type_integer_hwtcl interface_type_hwtcl include_dma_hwtcl } {
   if [expr { (($lane_rate=="gen3")&& ($link_width=="x8")&&($interface_type_integer_hwtcl==1)) ||  (($app_interface_width_hwtcl=="256-bit")&&($interface_type_integer_hwtcl==1)) || $include_dma_hwtcl==1 }] {
     set legal_values [list "Native endpoint" "Root port"]
       } else {
       set legal_values [list "Root port" "Legacy endpoint" "Native endpoint"]
   }
   auto_invalid_value_message auto port_type_hwtcl  $port_type_hwtcl $legal_values { lane_rate link_width app_interface_width_hwtcl interface_type_hwtcl }
}

proc ::altera_pcie_a10_hip::parameters::validate_cb_pcie_mode_hwtcl { PROP_NAME PROP_VALUE cb_pcie_mode_hwtcl port_type_hwtcl interface_type_integer_hwtcl interface_type_hwtcl } {
   set interface_type_integer_hwtcl [ip_get "parameter.interface_type_integer_hwtcl.value"]
   set include_dma_hwtcl            [ip_get "parameter.include_dma_hwtcl.value"]
   if { $interface_type_integer_hwtcl>0 && $include_dma_hwtcl==0 } {
      if [expr { (($port_type_hwtcl=="Root port") &&($interface_type_integer_hwtcl==1))}] {
        set legal_values 0
          } else {
          set legal_values [list 0 1]
      }
      auto_invalid_value_message auto cb_pcie_mode_hwtcl  $cb_pcie_mode_hwtcl $legal_values { port_type_hwtcl interface_type_hwtcl }
   }
   set cb_pcie_mode_hwtcl [ip_get "parameter.cb_pcie_mode_hwtcl.value"]
   set cb_pcie_rx_lite_hwtcl [ip_get "parameter.cb_pcie_rx_lite_hwtcl.value"]
   if { $interface_type_integer_hwtcl>0 && ($cb_pcie_rx_lite_hwtcl==1 || $cb_pcie_mode_hwtcl==1) } {
      send_message warning "MSI requests not supported for Completer-Only Endpoint with Avalon-MM interface."
  }
}


proc ::altera_pcie_a10_hip::parameters::validate_cb_pcie_rx_lite_hwtcl { PROP_NAME PROP_VALUE cb_pcie_mode_hwtcl cb_pcie_rx_lite_hwtcl lane_rate link_width interface_type_integer_hwtcl interface_type_hwtcl include_dma_hwtcl} {
   set interface_type_integer_hwtcl [ip_get "parameter.interface_type_integer_hwtcl.value"]
   set include_dma_hwtcl            [ip_get "parameter.include_dma_hwtcl.value"]
   if { $interface_type_integer_hwtcl>0 && $include_dma_hwtcl==0 } {
      if [expr { (($lane_rate=="gen3")&& ($link_width=="x8")&&($interface_type_integer_hwtcl==1)) || $include_dma_hwtcl==1 || $cb_pcie_mode_hwtcl}] {
        set legal_values 0
          } else {
          set legal_values [list 0 1]
      }
      auto_invalid_value_message auto cb_pcie_rx_lite_hwtcl  $cb_pcie_rx_lite_hwtcl $legal_values { cb_pcie_mode_hwtcl lane_rate link_width interface_type_hwtcl }
   }
}


