proc ::altera_pcie_a10_hip::parameters::select_design_example { } {

   set interface_type_hwtcl [ip_get "parameter.interface_type_hwtcl.value"]

   if { $interface_type_hwtcl == "Avalon-ST" } {
      ip_set "parameter.select_design_example_hwtcl.allowed_ranges" { "PIO" }
   } elseif { $interface_type_hwtcl == "Avalon-MM" } {
      ip_set "parameter.select_design_example_hwtcl.allowed_ranges" { "PIO" }
   } elseif { $interface_type_hwtcl == "Avalon-MM with DMA" } {
      ip_set "parameter.select_design_example_hwtcl.allowed_ranges" { "DMA" }
   } elseif { $interface_type_hwtcl == "Avalon-ST with SR-IOV" } {
      ip_set "parameter.select_design_example_hwtcl.allowed_ranges" { "NONE" }
      ip_set "parameter.select_design_example_hwtcl.enabled" false
   } 
}

#=======================================================================
# IP upgrade callback
proc ::altera_pcie_a10_hip::parameters::upgrade {ip_name version old_params} {

   # wrala_hwtcl : new in ACDS 15.1
   set upd_from_prev_15_1_version      1
   set sriov2_en_exists                0
   set upd_targ_devkit_name            0
   set current_devkit_name             ""
   foreach { name value } $old_params {
      if {[regexp $name "wrala_hwtcl"]} {
         set upd_from_prev_15_1_version 0
      }
      if {[regexp $name "sriov2_en"]} {
         set sriov2_en_exists 1
      }
      if {[regexp $name "targeted_devkit_hwtcl"]} {
         set upd_targ_devkit_name 1
         set current_devkit_name $value
      }
   }

   if { $sriov2_en_exists ==  0} {
      ip_set "parameter.sriov2_en.value" 0
   }

   if { $upd_from_prev_15_1_version == 0 } {
      foreach { name value } $old_params {
         if { ( $name != "targeted_devkit_hwtcl" ) && ( $name != "sim_sriov_dma_hwtcl" )} {
            ip_set "parameter.$name.value" $value
         }
      }
   } else {

      set link_width_hwtcl          "x1"
      set lane_rate_hwtcl           "Gen1 (2.5 Gbps)"
      set app_interface_width_hwtcl "64-bit"
      set set_pld_clk_x1_625MHz_hwtcl 0
      set interface_type_hwtcl      "Avalon-ST"

      foreach { name value } $old_params {
         if {[regexp $name "lane_rate_hwtcl"]} {
            set lane_rate_hwtcl $value
            ip_set "parameter.lane_rate_hwtcl.value" $lane_rate_hwtcl
         } elseif {[regexp $name "link_width_hwtcl"]} {
            ip_set "parameter.link_width_hwtcl.value" $link_width_hwtcl
            set link_width_hwtcl $value
         } elseif {[regexp $name "app_interface_width_hwtcl"]} {
            ip_set "parameter.app_interface_width_hwtcl.value" $app_interface_width_hwtcl
            set app_interface_width_hwtcl $value
         } elseif {[regexp $name "set_pld_clk_x1_625MHz_hwtcl"]} {
            ip_set "parameter.set_pld_clk_x1_625MHz_hwtcl.value" $set_pld_clk_x1_625MHz_hwtcl
            set set_pld_clk_x1_625MHz_hwtcl $value
         } else {
            set skip_param 0
            switch $name {
                tlp_insp_trg_dw0_hwtcl            -
                tlp_insp_trg_dw1_hwtcl            -
                tlp_insp_trg_dw2_hwtcl            -
                tlp_insp_trg_dw3_hwtcl            -
                AUTO_PLD_CLK_CLOCK_RATE           -
                AUTO_HIP_RECONFIG_CLK_CLOCK_RATE  -
                AUTO_REFCLK_CLOCK_RATE            -
                AUTO_RXM_IRQ_INTERRUPTS_USED      -
                AUTO_HIP_RECONFIG_CLK_CLOCK_RATE { set skip_param 1 }
                targeted_devkit_hwtcl            { set skip_param 1 }
                sim_sriov_dma_hwtcl              { set skip_param 1 }
                default                          { set skip_param 0 }
            }
            if { $skip_param == 0 } {
               ip_set "parameter.$name.value" $value
            }
         }
      }
      ip_set "parameter.enable_avst_reset_hwtcl.value" 0

      #"0: Gen3 x8 - Application  256-bit width operating at 250 Mhz" ""
      #"1: Gen3 x4 - Application  256-bit width operating at 125 MHz" ""
      #"2: Gen3 x4 - Application  128-bit width operating at 250 MHz" ""
      #"3: Gen3 x2 - Application  128-bit width operating at 125 MHz" "
      #"4: Gen3 x2 - Application  64-bit width operating at 250 MHz"  "
      #"5: Gen3 x1 - Application  64-bit width operating at 125 MHz"  ""
      #"6: Gen2 x8 - Application  256-bit width operating at 125 MHz" ""
      #"7: Gen2 x8 - Application  128-bit width operating at 250 MHz" ""
      #"8: Gen2 x4 - Application  128-bit width operating at 125 MHz" "
      #"9: Gen2 x4 - Application  64-bit width operating at 250 MHz"  "
      #"10:Gen2 x2 - Application 64-bit width operating at 125 MHz" "
      #"11:Gen2 x1 - Application 64-bit width operating at 125 MHz" "
      #"12:Gen1 x8 - Application 128-bit width operating at 125 MHz""
      #"13:Gen1 x8 - Application 64-bit width operating at 250 MHz" "
      #"14:Gen1 x4 - Application 64-bit width operating at 125 MHz" "
      #"15:Gen1 x2 - Application 64-bit width operating at 125 MHz" "
      #"16:Gen1 x1 - Application 64-bit width operating at 125 MHz" "
      #"17:Gen1 x1 - Application 64-bit width operating at 62.5MHz"
      if { [ regexp  "Gen3" $lane_rate_hwtcl ] } {
         if       { [ regexp  "x8" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 0
         } elseif { [ regexp  "x4" $link_width_hwtcl ] } {
            if { [ regexp "256" $app_interface_width_hwtcl ] } {
               ip_set "parameter.wrala_hwtcl.value" 1
            } else {
               ip_set "parameter.wrala_hwtcl.value" 2
            }
         } elseif { [ regexp "x2" $link_width_hwtcl  ] } {
            if { [ regexp "128" $app_interface_width_hwtcl ] } {
               ip_set "parameter.wrala_hwtcl.value" 3
            } else {
               ip_set "parameter.wrala_hwtcl.value" 4
            }
         } elseif { [ regexp "x1" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 5
         }
      } elseif  { [ regexp "Gen2" $lane_rate_hwtcl ] } {
         if       { [ regexp "x8" $link_width_hwtcl ] } {
            if { [ regexp "256" $app_interface_width_hwtcl ] } {
               ip_set "parameter.wrala_hwtcl.value" 6
            } else {
               ip_set "parameter.wrala_hwtcl.value" 7
            }
         } elseif { [ regexp "x4" $link_width_hwtcl ] } {
            if { [ regexp "128" $app_interface_width_hwtcl ] } {
               ip_set "parameter.wrala_hwtcl.value" 8
            } else {
               ip_set "parameter.wrala_hwtcl.value" 9
            }
         } elseif { [ regexp "x2" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 10
         } elseif { [ regexp "x1" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 11
         }
      } elseif  { [ regexp "Gen1" $lane_rate_hwtcl ] } {
         if       { [ regexp "x8" $link_width_hwtcl ] } {
            if { [ regexp "128" $app_interface_width_hwtcl ] } {
               ip_set "parameter.wrala_hwtcl.value" 12
            } else {
               ip_set "parameter.wrala_hwtcl.value" 13
            }
         } elseif { [ regexp "x4" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 14
         } elseif { [ regexp "x2" $link_width_hwtcl ] } {
            ip_set "parameter.wrala_hwtcl.value" 15
         } elseif { [ regexp "x1" $link_width_hwtcl ] } {
            if { $set_pld_clk_x1_625MHz_hwtcl == 1 } {
               ip_set "parameter.wrala_hwtcl.value" 17
            } else {
               ip_set "parameter.wrala_hwtcl.value" 16
            }
         }
      }
   }

   if { $upd_targ_devkit_name == 1 } {
      if { $current_devkit_name == "Arria 10 FPGA Development Kit" } {
         ip_set "parameter.targeted_devkit_hwtcl.value" "Arria 10 GX FPGA Development Kit"
      } else {
         if { $current_devkit_name == "Arria 10 FPGA Development Kit ES2" } {
            ip_set "parameter.targeted_devkit_hwtcl.value" "Arria 10 GX FPGA Development Kit ES2"
         }
      }
   }
   
  set interface_type_hwtcl [ip_get "parameter.interface_type_hwtcl.value" ]
  if { $interface_type_hwtcl == { "Avalon-ST" } } {
    ip_set "parameter.select_design_example_hwtcl.value" "PIO"
  } elseif { $interface_type_hwtcl == { "Avalon-MM" } } {
    ip_set "parameter.select_design_example_hwtcl.value" "PIO"
  } elseif { $interface_type_hwtcl == "Avalon-MM with DMA" } {
    ip_set "parameter.select_design_example_hwtcl.value" "DMA"
  } elseif { $interface_type_hwtcl == "Avalon-ST with SR-IOV" } {
    ip_set "parameter.select_design_example_hwtcl.value" "NONE"
  }

}
