proc ::altera_pcie_a10_hip::parameters::validate_total_vf_count_hwtcl { PROP_NAME PROP_VALUE total_vf_count_hwtcl include_sriov_hwtcl sr_iov_support_hwtcl pf0_vf_count_user_hwtcl pf1_vf_count_user_hwtcl total_pf_count_hwtcl ari_support_hwtcl pf2_vf_count_user_hwtcl pf3_vf_count_user_hwtcl sriov2_en} {
  if {$sriov2_en == 0} {
    if {$include_sriov_hwtcl== 1} {
      set pf0_vf_count_mod_4         [ expr {$pf0_vf_count_user_hwtcl % 4}]

      set sum_vf_user_count  [expr { $pf0_vf_count_user_hwtcl + $pf1_vf_count_user_hwtcl }]
        if ($sr_iov_support_hwtcl==1) {
                   if ($sum_vf_user_count<4) {
              send_message error "The sum of PF0 VFs and PF1 VFs must be greater than 3"
                        }
           ip_set "parameter.${PROP_NAME}.value" $sum_vf_user_count
           set total_vf_count_hwtcl_mod_4 [ expr {$total_vf_count_hwtcl % 4}]

           if { ($total_pf_count_hwtcl==1) && ($pf1_vf_count_user_hwtcl >  0) } {
              send_message error "Total VF Counts for PF1 must be zero because TOTAL Active PFs = 1"
           }

           if { ($total_pf_count_hwtcl==1) && ($ari_support_hwtcl == 0) && ($pf0_vf_count_user_hwtcl == 0) && ($pf1_vf_count_user_hwtcl == 0) } {
              send_message error "Total VF Counts for PF0 must be between 1 to 7 if SR-IOV is enabled and ARI is disabled"
           } elseif { ($total_pf_count_hwtcl==1) && ($ari_support_hwtcl == 0) && ($total_vf_count_hwtcl >  7) } {
              send_message error "Total VF Counts for PF0 must be less than 7 when ARI is disabled"
           } elseif {($total_pf_count_hwtcl==1) && ($ari_support_hwtcl == 1) && (($total_vf_count_hwtcl < 4) || ($total_vf_count_hwtcl >  128) ) } {
              send_message error "Total VF Counts for PF0 must be between 4-128 when ARI is enabled"
           } elseif {($total_pf_count_hwtcl==1) && ($ari_support_hwtcl == 1) && ($pf0_vf_count_mod_4 ) } {
              send_message error "If ARI is enabled and only PF0 is active, PF0 VF value must be multiples of 4 and within 4-128 range"
           }

           if { ($total_pf_count_hwtcl==2) && ($pf0_vf_count_user_hwtcl == 0) && ($pf1_vf_count_user_hwtcl == 0) } {
              send_message error "Total VF Counts when both PFs are enabled must be between 1 to 7 if SR-IOV is enabled and ARI is disabled"
           } elseif { ($total_pf_count_hwtcl==2) && ($ari_support_hwtcl == 0) && ($total_vf_count_hwtcl >  6) } {
              send_message error "Total VF Counts for both PF0 and PF1 must be less than 6 when ARI is disabled"
           } elseif {($total_pf_count_hwtcl==2) && ($ari_support_hwtcl == 1) && (($total_vf_count_hwtcl < 4) || ($total_vf_count_hwtcl >  128) ) } {
              send_message error "Total VF Counts for both PF0 and PF1 must be between 4-128 when ARI is enabled"
           } elseif {($total_pf_count_hwtcl==2) && ($ari_support_hwtcl == 1) && ($total_vf_count_hwtcl_mod_4 || ($total_vf_count_hwtcl < 4) || ($total_vf_count_hwtcl > 128)) } {
              send_message error "Total VF Count value must be multiples of 4 and within 4-128 range if ARI is enabled and both PF0 and PF1 are active"
           } elseif {($total_pf_count_hwtcl==2) && ($ari_support_hwtcl == 1) && ($total_vf_count_hwtcl_mod_4 || ($total_vf_count_hwtcl < 4) || ($total_vf_count_hwtcl > 128)) } {
              send_message error "Total VF Count value must be multiples of 4 and within 4-128 range if ARI is enabled and both PF0 and PF1 are active"
           }

        } else {
           ip_set "parameter.${PROP_NAME}.value" 4
        }
    } else {
      ip_set "parameter.${PROP_NAME}.value" 4
    }
  } else {
           set PF0_VF_COUNT_USER                       $pf0_vf_count_user_hwtcl
           set PF1_VF_COUNT_USER                       $pf1_vf_count_user_hwtcl
           set PF2_VF_COUNT_USER                       $pf2_vf_count_user_hwtcl
           set PF3_VF_COUNT_USER                       $pf3_vf_count_user_hwtcl
           set ARI_SUPPORT                             $ari_support_hwtcl
           set SR_IOV_SUPPORT                          $sr_iov_support_hwtcl
           set TOTAL_PF_COUNT                          $total_pf_count_hwtcl

           #=========================================================================
           # Derived and validate TOTAL_VF_COUNT = Sum of both PF0 and PF1 VF_COUNT
           set TOTAL_VF                 [ expr {$PF0_VF_COUNT_USER + $PF1_VF_COUNT_USER + $PF2_VF_COUNT_USER + $PF3_VF_COUNT_USER}]
 
           set PF0_VF_COUNT_MOD_4       [ expr {$PF0_VF_COUNT_USER % 4}]
           set PF1_VF_COUNT_MOD_4       [ expr {$PF1_VF_COUNT_USER % 4}]
           set PF2_VF_COUNT_MOD_4       [ expr {$PF2_VF_COUNT_USER % 4}]
           set PF3_VF_COUNT_MOD_4       [ expr {$PF3_VF_COUNT_USER % 4}]
           set TOTAL_VF_MOD_4           [ expr {$TOTAL_VF % 4}]

           set PF0_VF_COUNT_MOD_64      [ expr {$PF0_VF_COUNT_USER % 64}]
           set PF1_VF_COUNT_MOD_64      [ expr {$PF1_VF_COUNT_USER % 64}]
           set PF2_VF_COUNT_MOD_64      [ expr {$PF2_VF_COUNT_USER % 64}]
           set PF3_VF_COUNT_MOD_64      [ expr {$PF3_VF_COUNT_USER % 64}]
           set TOTAL_VF_MOD_64          [ expr {$TOTAL_VF % 64}]

           set PF0_VF_COUNT_MOD_512     [ expr {$PF0_VF_COUNT_USER % 512}]
           set PF1_VF_COUNT_MOD_512     [ expr {$PF1_VF_COUNT_USER % 512}]
           set PF2_VF_COUNT_MOD_512     [ expr {$PF2_VF_COUNT_USER % 512}]
           set PF3_VF_COUNT_MOD_512     [ expr {$PF3_VF_COUNT_USER % 512}]
           set TOTAL_VF_MOD_512         [ expr {$TOTAL_VF % 512}]

           if ($SR_IOV_SUPPORT) {
              ip_set "parameter.${PROP_NAME}.value" $TOTAL_VF

              if {$ARI_SUPPORT == 0} {
                 send_message error "ARI Must be Set with SR_IOV_SUPPORT = $SR_IOV_SUPPORT."
                }

              if {$TOTAL_VF > 2048} {
                 send_message error "Total VF count set is $TOTAL_VF which exceeds supported value. This version supports total 2048 Virtual Functions."
                }

              if { ($TOTAL_PF_COUNT==1) } {
                 if { ($PF1_VF_COUNT_USER >  0) || ($PF2_VF_COUNT_USER >  0) || ($PF3_VF_COUNT_USER >  0)} {
                    send_message error "VF Counts for PF1, PF2 and PF3  must be zero because TOTAL Active PFs = 1."
                 } elseif {$PF0_VF_COUNT_USER == 0} {
                    send_message error "Active PF0 must have non-zero VF Count value"
                 } elseif { ($PF0_VF_COUNT_USER >= 8) && ($PF0_VF_COUNT_USER <= 256) && ($PF0_VF_COUNT_MOD_4 > 0)} {
                     send_message error "PF0_VF_COUNT must be set in multiple of 4"
                 } elseif { ($PF0_VF_COUNT_USER >= 256) && ($PF0_VF_COUNT_USER <= 1024) && ($PF0_VF_COUNT_MOD_64 > 0)} {
                     send_message error "PF0_VF_COUNT must be set in multiple of 64"
                 }  elseif { ($PF0_VF_COUNT_USER >= 1024) && ($PF0_VF_COUNT_USER <= 4096) && ($PF0_VF_COUNT_MOD_512 > 0)} {
                      send_message error "PF0_VF_COUNT must be set in multiple of 512"
                 }
                }

              if { ($TOTAL_PF_COUNT <= 2) } {
                 if { ($PF2_VF_COUNT_USER >  0) || ($PF3_VF_COUNT_USER >  0) } {
                    send_message error "Total VF Counts for PF2 and PF3 must be zero because TOTAL Active PFs = $TOTAL_PF_COUNT."
                 } elseif {$TOTAL_VF == 0} {
                    send_message error "At least one of Active PF(PF0 or PF1) must have non-zero VF Count value."
                 } elseif { ($PF0_VF_COUNT_USER >= 8) && ($PF0_VF_COUNT_USER <= 256) && ($PF0_VF_COUNT_MOD_4 > 0)} {
                     send_message error "PF0_VF_COUNT must be set in multiple of 4"
                 } elseif { ($PF0_VF_COUNT_USER >= 256) && ($PF0_VF_COUNT_USER <= 1024) && ($PF0_VF_COUNT_MOD_64 > 0)} {
                     send_message error "PF0_VF_COUNT must be set in multiple of 64"
                 }  elseif { ($PF0_VF_COUNT_USER >= 1024) && ($PF0_VF_COUNT_USER <= 4096) && ($PF0_VF_COUNT_MOD_512 > 0)} {
                      send_message error "PF0_VF_COUNT must be set in multiple of 512"
                 } elseif { ($PF1_VF_COUNT_USER >= 8) && ($PF1_VF_COUNT_USER <= 256) && ($PF1_VF_COUNT_MOD_4 > 0)} {
                     send_message error "PF1_VF_COUNT must be set in multiple of 4"
                 } elseif { ($PF1_VF_COUNT_USER >= 256) && ($PF1_VF_COUNT_USER <= 1024) && ($PF1_VF_COUNT_MOD_64 > 0)} {
                     send_message error "PF1_VF_COUNT must be set in multiple of 64"
                 }  elseif { ($PF1_VF_COUNT_USER >= 1024) && ($PF1_VF_COUNT_USER <= 4096) && ($PF1_VF_COUNT_MOD_512 > 0)} {
                      send_message error "PF1_VF_COUNT must be set in multiple of 512"
                 } elseif { ($TOTAL_VF >= 8) && ($TOTAL_VF <= 256) && ($TOTAL_VF_MOD_4 > 0)} {
                     set additional_vfs [expr 4 - $TOTAL_VF_MOD_4 ]
                     send_message error "TOTAL_VF count must be set in multiple of 4. It is short by $additional_vfs to become multiple of 4 "
                 } elseif { ($TOTAL_VF >= 256) && ($TOTAL_VF <= 1024) && ($TOTAL_VF_MOD_64 > 0)} {
