proc ::altera_pcie_a10_hip::parameters::validate_soft_dfe { PROP_NAME PROP_VALUE enable_soft_dfe lane_rate } {
   if { ($enable_soft_dfe == 1) && (($lane_rate=="gen2") || ($lane_rate=="gen1"))} {
     send_message error "Soft DFE can be enabled only in Gen3 mode"
   }
}
proc ::altera_pcie_a10_hip::parameters::validate_targeted_devkit_hwtcl { PROP_NAME PROP_VALUE enable_example_design_synth_hwtcl } {
   if { $enable_example_design_synth_hwtcl == 1 } {
      ip_set "parameter.${PROP_NAME}.enabled" true
      set legal_values [ list "Arria 10 GX FPGA Development Kit" "Arria 10 GX FPGA Development Kit ES2" "NONE" ]
   } else {
      ip_set "parameter.${PROP_NAME}.enabled" false

   }
}

proc ::altera_pcie_a10_hip::parameters::validate_msi_req_fn_width { PROP_NAME PROP_VALUE app_msi_req_fn_hwtcl sriov2_en total_pf_count_width_hwtcl include_sriov_hwtcl } {
  if { $sriov2_en == 1 && $include_sriov_hwtcl == 1} {
    ip_set "parameter.${PROP_NAME}.value" $total_pf_count_width_hwtcl
  } else {
    ip_set "parameter.${PROP_NAME}.value" 8
  }
 }

