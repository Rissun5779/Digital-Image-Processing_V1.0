proc ::altera_pcie_a10_hip::parameters::declare_parameters { {device_family "Arria 10"} } {
  variable display_items
  variable parameters
  variable parameter_tlp_inspector
  variable parameter_ast_trs
  variable parameter_system_hidden
  variable mapped_parameters
  variable rxm_specific_parameters
  variable design_environment
  variable parameter_overrides

  ip_declare_parameters $parameters
  ip_declare_parameters $rxm_specific_parameters
  ip_declare_parameters $design_environment
  ip_declare_parameters $parameter_tlp_inspector;
  ip_declare_parameters $parameter_ast_trs;
  ip_declare_parameters $parameter_system_hidden;

  # Add NF_HIP parameters
  ip_declare_parameters [::nf_hip::parameters::get_parameters]
  # Add M_AUTOSET attribute to all NF_HIP parameters
  set nf_hip_parameters [ip_get_matching_parameters [dict set criteria M_IP_CORE nf_hip]]
  foreach param $nf_hip_parameters {
    ip_set "parameter.${param}.M_AUTOSET" 1
    ip_set "parameter.${param}.DISPLAY_ITEM" "PCI Express Attributes"
    ip_set "parameter.${param}.HDL_PARAMETER" true
    ip_set "parameter.${param}.VISIBLE" false
    if {[regexp {^bar\d{1}_size_mask} $param]} {
      ip_set "parameter.${param}.HDL_PARAMETER" false
    } elseif {[regexp expansion_base_address_register $param]} {
      ip_set "parameter.${param}.HDL_PARAMETER" false
    } elseif {[regexp {msix.*offset} $param]} {
      ip_set "parameter.${param}.HDL_PARAMETER" false
    }

    ip_set "parameter.${param}.M_AUTOWARN" 0
  }

  ip_set "parameter.cpl_spc_data_hwtcl.M_AUTOSET" 1
  ip_set "parameter.cpl_spc_header_hwtcl.M_AUTOSET" 1

  #over-constraining these parameters in order to resolve to 1 value
  foreach param {
        gen2_pma_pll_usage
        core_clk_freq_mhz
        tx_sop_ctrl
        rx_sop_ctrl
        cseb_cpl_status_during_cvp
  } {
        ip_set "parameter.${param}.M_AUTOSET" 1
        ip_set "parameter.${param}.VALIDATION_CALLBACK" "::nf_hip::parameters::validate_${param}_override"
  }

   foreach param {
       device_number
       msix_table_offset
       msix_pba_offset
       eql_rq_int_en_number
       jtag_id
       l1_exit_latency_diffclock
       l1_exit_latency_sameclock
       maximum_current
       user_id
       vsec_cap
       vsec_id
   } {
        ip_set "parameter.${param}.M_AUTOWARN" 0
   }

  # Provide parameter mappings from IP parameters to PCI Express atom parameters
  ip_declare_parameters $mapped_parameters;
  ip_declare_parameters $parameter_overrides;

  # Add display items
  ip_declare_display_items $display_items

  # Initialize device information (to allow sharing of this function across device families)
  ip_set "parameter.device_family.SYSTEM_INFO" DEVICE_FAMILY
  ip_set "parameter.device_family.DEFAULT_VALUE" $device_family

  # Pass down base_device
  ip_set "parameter.base_device.SYSTEM_INFO_TYPE" PART_TRAIT
  ip_set "parameter.base_device.SYSTEM_INFO_ARG"  BASE_DEVICE

  # Pass down part_trait_device
  ip_set "parameter.part_trait_device.SYSTEM_INFO_TYPE" PART_TRAIT
  ip_set "parameter.part_trait_device.SYSTEM_INFO_ARG"  DEVICE

  # Enable parameter mapping in the messaging package
  set_mapping_enabled 1
}

proc ::altera_pcie_a10_hip::parameters::setup_testbench {} {

   set use_rpbfm_pro [ip_get "parameter.use_rpbfm_pro.value"]
   if { ${use_rpbfm_pro} > 0 } {
      set_module_assignment testbench.partner.pcie_tb.class  altera_pcie_rp_bfm
      send_message info "Using Testbench partner altera_pcie_rp_bfm"
      set_module_assignment testbench.partner.pcie_tb.parameter.lane_mask_hwtcl  [ip_get "parameter.link_width_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.serial_sim_hwtcl [ip_get "parameter.serial_sim_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl  10
      set_module_assignment testbench.partner.pcie_tb.parameter.add_A10_HSSI_simlib_files  0
      set_module_assignment testbench.partner.map.refclk     pcie_tb.refclk
      set_module_assignment testbench.partner.map.npor       pcie_tb.npor
      set_module_assignment testbench.partner.map.hip_pipe   pcie_tb.hip_pipe
      set_module_assignment testbench.partner.map.hip_ctrl   pcie_tb.hip_ctrl
      if { ${use_rpbfm_pro} == 1 } {
         # Use A10 G3:X8 BFM
         set_module_assignment testbench.partner.pcie_tb.parameter.hip_rp_bfm_hwtcl  0
      } else {
         # Use A10 G3:X16 BFM
         set_module_assignment testbench.partner.pcie_tb.parameter.hip_rp_bfm_hwtcl  1
      }

   } else {
      set interface_type_integer_hwtcl [ip_get "parameter.interface_type_integer_hwtcl.value"]
      set data_width_integer_hwtcl [ip_get "parameter.data_width_integer_hwtcl.value"]
      set include_dma_hwtcl [ip_get "parameter.include_dma_hwtcl.value"]
      set include_sriov_hwtcl [ip_get "parameter.include_sriov_hwtcl.value"]
      set sim_sriov_dma_hwtcl 0
      set cseb_config_bypass_hwtcl [ip_get "parameter.cseb_config_bypass_hwtcl.value"]
      set sriov2_enable [ip_get "parameter.sriov2_en.value"]

      set_module_assignment testbench.partner.pcie_tb.parameter.lane_mask_hwtcl                       [ip_get "parameter.link_width_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.pll_refclk_freq_hwtcl                 [ip_get "parameter.pll_refclk_freq_hwtcl.value"]
      # set_module_assignment testbench.partner.pcie_tb.parameter.port_type_hwtcl                       [ip_get "parameter.port_type_hwtcl.value"]

      if { [ip_get "parameter.port_type_hwtcl.value"] == "Root port" && [ip_get "parameter.interface_type_hwtcl.value"] == "Avalon-MM"} {
         set_module_assignment testbench.partner.pcie_tb.parameter.port_type_hwtcl                    "Native endpoint"
      } else {
         set_module_assignment testbench.partner.pcie_tb.parameter.port_type_hwtcl                    [ip_get "parameter.port_type_hwtcl.value"] 
      }

      if { $include_dma_hwtcl == 1} {
         set_module_assignment testbench.partner.pcie_tb.parameter.gen123_lane_rate_mode_hwtcl        "Gen3 (8.0 Gbps)"
      } else {
         set_module_assignment testbench.partner.pcie_tb.parameter.gen123_lane_rate_mode_hwtcl        [ip_get "parameter.lane_rate_hwtcl.value"]
      }
      set_module_assignment testbench.partner.pcie_tb.parameter.serial_sim_hwtcl                      [ip_get "parameter.serial_sim_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.enable_pipe32_phyip_ser_driver_hwtcl  [ip_get "parameter.enable_pipe32_phyip_ser_driver_hwtcl.value"]

      set_module_assignment testbench.partner.pcie_tb.parameter.bfm_drive_interface_clk_hwtcl      [ip_get "parameter.bfm_drive_interface_clk_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.bfm_drive_interface_npor_hwtcl     [ip_get "parameter.bfm_drive_interface_npor_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.bfm_drive_interface_pipe_hwtcl     [ip_get "parameter.bfm_drive_interface_pipe_hwtcl.value"]
      set_module_assignment testbench.partner.pcie_tb.parameter.bfm_drive_interface_control_hwtcl  [ip_get "parameter.bfm_drive_interface_control_hwtcl.value"]

      if  { [ip_get "parameter.bfm_drive_interface_clk_hwtcl.value"] == 1 } {
         set_module_assignment testbench.partner.map.refclk     pcie_tb.refclk
      }

      if { [ip_get "parameter.bfm_drive_interface_npor_hwtcl.value"] == 1 } {
         set_module_assignment testbench.partner.map.npor       pcie_tb.npor
      }

      if { [ip_get "parameter.bfm_drive_interface_pipe_hwtcl.value"] == 1 } {
         set_module_assignment testbench.partner.map.hip_pipe   pcie_tb.hip_pipe
      }

      if { [ip_get "parameter.bfm_drive_interface_control_hwtcl.value"] == 1 } {
         set_module_assignment testbench.partner.map.hip_ctrl   pcie_tb.hip_ctrl
      }

      if { [ip_get "parameter.apps_type_hwtcl.value" ] > 0 } {
         set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl [ip_get "parameter.apps_type_hwtcl.value"]
      } else {
         if { $interface_type_integer_hwtcl == 0 } {
            if { ($include_sriov_hwtcl == 1) && ($sriov2_enable==1) } {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 13
            } elseif { ($include_sriov_hwtcl == 0) && ($cseb_config_bypass_hwtcl==0) } {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 3
            } elseif { $include_sriov_hwtcl == 0 && $cseb_config_bypass_hwtcl== 1 } {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 10
            } elseif { $include_sriov_hwtcl == 1 && $sim_sriov_dma_hwtcl== 1} {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 12
            } elseif { $include_sriov_hwtcl == 1 && $sim_sriov_dma_hwtcl== 0} {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 13
            } else {
               set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 2
            }
         } elseif { $include_dma_hwtcl == 1 } {
            set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 6
         } else {
            # AVMM
            if { $data_width_integer_hwtcl == 128 } {
              set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 5
            } elseif { $data_width_integer_hwtcl == 256 } {
              set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 6
            } else {
              set_module_assignment testbench.partner.pcie_tb.parameter.apps_type_hwtcl 4
            }
         }
      }
   }
#  Rest only needed for Tl-direct simulation which is not supported
#  set_module_assignment testbench.partner.pcie_tb.parameter.enable_tl_only_sim_hwtcl              [get_parameter enable_tl_only_sim_hwtcl ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.deemphasis_enable_hwtcl               [get_parameter deemphasis_enable_hwtcl ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.pld_clk_MHz                           [get_parameter pld_clk_MHz ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.millisecond_cycle_count_hwtcl         [get_parameter millisecond_cycle_count_hwtcl ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.use_crc_forwarding_hwtcl              [get_parameter use_crc_forwarding_hwtcl ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.ecrc_check_capable_hwtcl              [get_parameter ecrc_check_capable_hwtcl ]
#  set_module_assignment testbench.partner.pcie_tb.parameter.ecrc_gen_capable_hwtcl                [get_parameter ecrc_gen_capable_hwtcl ]

}

proc ::altera_pcie_a10_hip::parameters::embedded_sw_rp {} {
   if { [ip_get "parameter.port_type_hwtcl.value"] == "Root port" } {
      set_module_assignment embeddedsw.dts.vendor "altr"
      set_module_assignment embeddedsw.dts.group "pcie"
      set_module_assignment embeddedsw.dts.params.device_type "pci"
      set_module_assignment embeddedsw.dts.name "pcie-root-port"
      set_module_assignment embeddedsw.dts.compatible "altr,pcie-root-port-1.0"
   }
}

proc ::altera_pcie_a10_hip::parameters::validate {} {
    set family [get_parameter_value device_family]
    set basedevice [get_parameter_value base_device]
    set parttrait [get_parameter_value part_trait_device]
    set port_type [get_parameter_value port_type_hwtcl]
    set interface_type_hwtcl [get_parameter_value interface_type_hwtcl]
    
    send_message info "device_family is $family" 
    send_message info "base_device is $basedevice" 
    send_message info "part_trait_device is $parttrait" 
    
    if {$family == "Arria 10"} {
        set_parameter_property gen3_coeff_1_hwtcl VISIBLE true
        set_parameter_property enable_soft_dfe VISIBLE true
        
        set_parameter_property interface_type_hwtcl ALLOWED_RANGES    { "Avalon-ST" "Avalon-MM" "Avalon-MM with DMA" "Avalon-ST with SR-IOV"}
        
        if {$interface_type_hwtcl == "Avalon-MM" && $port_type!="Root port"} {
        set_parameter_property wrala_hwtcl ALLOWED_RANGES  { "2:Gen3:x4, Interface: 128 bit, 250 MHz"  \
                                                             "3:Gen3:x2, Interface: 128 bit, 125 MHz"  \
                                                             "4:Gen3:x2, Interface: 64 bit, 250 MHz"   \
                                                             "5:Gen3:x1, Interface: 64-bit, 125 MHz"   \
                                                             "6:Gen2:x8, Interface: 256-bit, 125 MHz"  \
                                                             "7:Gen2:x8, Interface: 128-bit, 250 MHz"  \
                                                             "8:Gen2:x4, Interface: 128 bit, 125 MHz"  \
                                                             "9:Gen2:x4, Interface: 64 bit, 250 MHz"   \
                                                             "10:Gen2:x2, Interface: 64 bit, 125 MHz"  \
                                                             "11:Gen2:x1, Interface: 64-bit, 125 MHz"  \
                                                             "12:Gen1:x8, Interface: 128-bit, 125 MHz" \
                                                             "13:Gen1:x8, Interface: 64-bit, 250 MHz"  \
                                                             "14:Gen1:x4, Interface: 64 bit, 125 MHz"  \
                                                             "15:Gen1:x2, Interface: 64 bit, 125 MHz"  \
                                                             "16:Gen1:x1, Interface: 64-bit, 125 MHz"  \
                                                             "17:Gen1:x1, Interface: 64-bit, 62.5 MHz"   } 
        } else {
        set_parameter_property wrala_hwtcl ALLOWED_RANGES  { "0:Gen3:x8, Interface: 256-bit, 250 MHz"  \
                                                             "1:Gen3:x4, Interface: 256 bit, 125 MHz"  \
                                                             "2:Gen3:x4, Interface: 128 bit, 250 MHz"  \
                                                             "3:Gen3:x2, Interface: 128 bit, 125 MHz"  \
                                                             "4:Gen3:x2, Interface: 64 bit, 250 MHz"   \
                                                             "5:Gen3:x1, Interface: 64-bit, 125 MHz"   \
                                                             "6:Gen2:x8, Interface: 256-bit, 125 MHz"  \
                                                             "7:Gen2:x8, Interface: 128-bit, 250 MHz"  \
                                                             "8:Gen2:x4, Interface: 128 bit, 125 MHz"  \
                                                             "9:Gen2:x4, Interface: 64 bit, 250 MHz"   \
                                                             "10:Gen2:x2, Interface: 64 bit, 125 MHz"  \
                                                             "11:Gen2:x1, Interface: 64-bit, 125 MHz"  \
                                                             "12:Gen1:x8, Interface: 128-bit, 125 MHz" \
                                                             "13:Gen1:x8, Interface: 64-bit, 250 MHz"  \
                                                             "14:Gen1:x4, Interface: 64 bit, 125 MHz"  \
                                                             "15:Gen1:x2, Interface: 64 bit, 125 MHz"  \
                                                             "16:Gen1:x1, Interface: 64-bit, 125 MHz"  \
                                                             "17:Gen1:x1, Interface: 64-bit, 62.5 MHz"   } 
        }

    } else {
        set_parameter_property gen3_coeff_1_hwtcl VISIBLE false
        set_parameter_property enable_soft_dfe VISIBLE false
        set_parameter_property interface_type_hwtcl ALLOWED_RANGES    { "Avalon-ST" "Avalon-MM" "Avalon-MM with DMA" }
        set_parameter_property wrala_hwtcl ALLOWED_RANGES { "0:Gen2:x4, Interface: 128 bit, 125 MHz"  \
                                                            "1:Gen2:x4, Interface: 64 bit, 250 MHz"   \
                                                            "2:Gen2:x2, Interface: 64 bit, 125 MHz"  \
                                                            "3:Gen2:x1, Interface: 64-bit, 125 MHz"  \
                                                            "4:Gen1:x4, Interface: 64 bit, 125 MHz"  \
                                                            "5:Gen1:x2, Interface: 64 bit, 125 MHz"  \
                                                            "6:Gen1:x1, Interface: 64-bit, 125 MHz"  \
                                                            "7:Gen1:x1, Interface: 64-bit, 62.5 MHz"   }
    }
  
  
    variable validated

    ::alt_xcvr::ip_tcl::messages::set_auto_message_level [ip_get "parameter.message_level.value"]
    ip_validate_parameters
    ip_validate_display_items
    # validate non rbc rules after validating all other parameters using rbc
    ::altera_pcie_a10_hip::parameters::validate_non_rbc_rules

    set validated 1
}

proc ::altera_pcie_a10_hip::parameters::get_validated {} {
    variable validated

    return $validated
}

proc ::altera_pcie_a10_hip::parameters::validate_non_rbc_rules { } {

   # Do not set any HDL parameters here
   set interface_type_integer_hwtcl [ip_get "parameter.interface_type_integer_hwtcl.value"]
   set port_type_hwtcl [ip_get "parameter.port_type_hwtcl.value"]
   set internal_controller_hwtcl [ip_get "parameter.internal_controller_hwtcl.value"]
   set include_dma_hwtcl [ip_get "parameter.include_dma_hwtcl.value"]

   set bar_type_integer_hwtcl(0) [ip_get "parameter.bar0_type_integer_hwtcl.value"]
   set bar_type_integer_hwtcl(1) [ip_get "parameter.bar1_type_integer_hwtcl.value"]
   set bar_type_integer_hwtcl(2) [ip_get "parameter.bar2_type_integer_hwtcl.value"]
   set bar_type_integer_hwtcl(3) [ip_get "parameter.bar3_type_integer_hwtcl.value"]
   set bar_type_integer_hwtcl(4) [ip_get "parameter.bar4_type_integer_hwtcl.value"]
   set bar_type_integer_hwtcl(5) [ip_get "parameter.bar5_type_integer_hwtcl.value"]
   set expansion_base_address_register_hwtcl [ip_get "parameter.expansion_base_address_register_hwtcl.value"]

   if [expr {($interface_type_integer_hwtcl==1)}] {
     set bar_size_mask_suffix "avmm_"
   } else {
     set bar_size_mask_suffix ""
   }

   set  bar_size_mask_hwtcl(0) [ip_get "parameter.bar0_address_width_${bar_size_mask_suffix}hwtcl.value"]
   set  bar_size_mask_hwtcl(1) [ip_get "parameter.bar1_address_width_${bar_size_mask_suffix}hwtcl.value"]
   set  bar_size_mask_hwtcl(2) [ip_get "parameter.bar2_address_width_${bar_size_mask_suffix}hwtcl.value"]
   set  bar_size_mask_hwtcl(3) [ip_get "parameter.bar3_address_width_${bar_size_mask_suffix}hwtcl.value"]
   set  bar_size_mask_hwtcl(4) [ip_get "parameter.bar4_address_width_${bar_size_mask_suffix}hwtcl.value"]
   set  bar_size_mask_hwtcl(5) [ip_get "parameter.bar5_address_width_${bar_size_mask_suffix}hwtcl.value"]

   set DISABLE_BAR             0
   set PREFETACHBLE_64_BAR     1
   set NON_PREFETCHABLE_32_BAR 2
   set PREFETCHABLE_32_BAR     3
   set IO_SPACE_BAR            4

   # Internal controller : Must enable bar0
   if { $include_dma_hwtcl == 1 && $internal_controller_hwtcl == 1 } {
      if { $bar_type_integer_hwtcl(0)!= $PREFETACHBLE_64_BAR } {
        ip_message error "When instantiating the internal descriptor controller, BAR0 must be set to <b>\"64-bit prefetchable memory\"</b>. This BAR will be used exclusively for the internal descriptor controller."
      }
   }

   if { [ regexp endpoint $port_type_hwtcl ] } {
      if { [expr {! [expr {($bar_type_integer_hwtcl(0) || $bar_type_integer_hwtcl(1) || $bar_type_integer_hwtcl(2) || $bar_type_integer_hwtcl(3) || $bar_type_integer_hwtcl(4) || $bar_type_integer_hwtcl(5))}]}] } {
        ip_message error "An endpoint design must have at least one enabled <b>\"Base Address Register\"</b>."
      }
   } else {
      if { $expansion_base_address_register_hwtcl > 0 } {
        set legal_values 0
        auto_invalid_value_message auto expansion_base_address_register_hwtcl $expansion_base_address_register_hwtcl $legal_values { port_type_hwtcl }
      }
      #TODO check bar validations for rootport
   }

   for {set i 0} {$i < 6} {incr i 1} {
      if { $bar_type_integer_hwtcl($i)== $DISABLE_BAR } {
         if { $bar_size_mask_hwtcl($i)!=0 && [expr {($interface_type_integer_hwtcl==0)}] } {
            ip_message error "The value of parameter <b>\"Size\"</b> of BAR$i must be set to <b>\"N/A\"</b> since BAR$i is <b>\"Disabled\"</b>."
         }
      } elseif { $bar_type_integer_hwtcl($i) == $PREFETACHBLE_64_BAR } {
         if { $bar_size_mask_hwtcl($i)<7 && $interface_type_integer_hwtcl!=1} {
            ip_message error "The value of parameter <b>\"Size\"</b> of the 64-bit prefetchable BAR$i must be greater than or equal to 7 bits."
         }
      } elseif { $bar_type_integer_hwtcl($i) == $NON_PREFETCHABLE_32_BAR } {
         if { $bar_size_mask_hwtcl($i)>31 } {
            ip_message error "The value of parameter <b>\"Size\"</b> of the 32-bit non-prefetchable BAR$i must be less than or equal to 31 bits."
         }
         if { $bar_size_mask_hwtcl($i)<7 && $interface_type_integer_hwtcl!=1} {
            ip_message error "The value of parameter <b>\"Size\"</b> of the 32-bit non-prefetchable BAR$i must be greater than or equal to 7 bits."
         }
      } elseif { $bar_type_integer_hwtcl($i)== $PREFETCHABLE_32_BAR } {
         if { $bar_size_mask_hwtcl($i)>31 } {
            ip_message error "The value of parameter <b>\"Size\"</b> of the 32-bit prefetchable BAR$i must be less than or equal to 31 bits."
         }
         if { $bar_size_mask_hwtcl($i)<7 && $interface_type_integer_hwtcl!=1} {
            ip_message error "The value of parameter <b>\"Size\"</b> of the 32-bit prefetchable BAR$i must be greater than or equal to 7 bits."
         }
      } elseif { $bar_type_integer_hwtcl($i) == $IO_SPACE_BAR } {
         if { $bar_size_mask_hwtcl($i)>12 } {
            ip_message error "The value of parameter <b>\"Size\"</b> of the I/O space BAR$i must be less than or equal to 12 bits."
         }
      }
   }
}

proc ::altera_pcie_a10_hip::parameters::validate_enable_rxm_burst_hwtcl { PROP_NAME PROP_VALUE enable_rxm_burst_hwtcl app_interface_width_hwtcl } {
    set legal_values [list 1 0]

    auto_invalid_value_message auto enable_rxm_burst_hwtcl $enable_rxm_burst_hwtcl $legal_values { app_interface_width_hwtcl }
}

proc ::altera_pcie_a10_hip::parameters::validate_completion_timeout_disable_hwtcl { PROP_NAME PROP_VALUE completion_timeout_disable_hwtcl interface_type_hwtcl } {
    set legal_values [list 1 0]

    if [expr { ($interface_type_hwtcl=="Avalon-MM with DMA") }] {
      set legal_values [::nf_hip::parameters::intersect $legal_values [list 1]]
    } else {
      set legal_values [::nf_hip::parameters::intersect $legal_values [list 1 0]]
    }
    auto_invalid_value_message auto completion_timeout_disable_hwtcl $completion_timeout_disable_hwtcl $legal_values { interface_type_hwtcl }
}

proc ::altera_pcie_a10_hip::parameters::validate_rx_buffer_credit_alloc_hwtcl { PROP_NAME PROP_VALUE rx_buffer_credit_alloc_hwtcl interface_type_hwtcl port_type_hwtcl } {
   if [expr { (($interface_type_hwtcl=="Avalon-MM with DMA" || $interface_type_hwtcl=="Avalon-MM") ) && $port_type_hwtcl != "Root port" }] {
      if [expr { ($rx_buffer_credit_alloc_hwtcl=="High") || ($rx_buffer_credit_alloc_hwtcl=="Maximum")}] {
         send_message error "RX Buffer credit allocation \"$PROP_VALUE\" is invalid when Application interface type is \"Avalon-MM\", please choose Low OR Minimum OR Balanced "
      }
   }
}

