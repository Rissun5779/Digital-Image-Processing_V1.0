proc ::altera_pcie_a10_hip::parameters::validate_bar0_address_width_mux_hwtcl { PROP_NAME PROP_VALUE interface_type_integer_hwtcl interface_type_hwtcl bar0_type_hwtcl bar0_address_width_hwtcl bar0_address_width_hwtcl bar0_address_width_avmm_hwtcl internal_controller_hwtcl include_dma_hwtcl} {
  if {$interface_type_integer_hwtcl == 0} {
    # AST
    ip_set "parameter.${PROP_NAME}.value" $bar0_address_width_hwtcl
  } elseif {$interface_type_integer_hwtcl == 1} {
    # AVMM
    if {$bar0_type_hwtcl == "Disabled"} {
      ip_set "parameter.${PROP_NAME}.value" 0
    } else {
      if { $bar0_address_width_avmm_hwtcl < 4 && $interface_type_hwtcl != "Avalon-MM with DMA"} {
        ip_set "parameter.${PROP_NAME}.value" 4
        #send_message error "BAR0 SIZE of $bar0_address_width_avmm_hwtcl - bit is less than 4. Please increase memory size"
        }
      if { $internal_controller_hwtcl==1 && $include_dma_hwtcl==1 } {
        ip_set "parameter.${PROP_NAME}.value" 9
      } else {
        ip_set "parameter.${PROP_NAME}.value" $bar0_address_width_avmm_hwtcl
      }
    }
  }
}

