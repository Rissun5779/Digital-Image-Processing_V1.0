proc ::altera_pcie_a10_hip::parameters::validate_wrala { PROP_NAME PROP_VALUE } {
    set family [get_parameter_value device_family]
    
    if {$family == "Arria 10" } {
        validate_wrala_hwtcl PROP_NAME PROP_VALUE
    } else {
        validate_wrala_hwtcl_c10 PROP_NAME PROP_VALUE
    }
}

