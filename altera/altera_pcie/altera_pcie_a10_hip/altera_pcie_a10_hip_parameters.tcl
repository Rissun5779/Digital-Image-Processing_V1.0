proc ::altera_pcie_a10_hip::parameters::validate_interface_type_hwtcl { PROP_NAME PROP_VALUE interface_type_hwtcl design_environment_hwtcl app_interface_width_hwtcl lane_rate_hwtcl sriov2_en } {
   set port_type [ip_get "parameter.port_type_hwtcl.value"]
   set interface_type_hwtcl_display_name [ip_get "parameter.$PROP_NAME.display_name"]

    if { $interface_type_hwtcl == "Avalon-ST" } {
        ip_set "parameter.cseb_config_bypass_gui_hwtcl.VISIBLE" 1
    } else {
        ip_set "parameter.cseb_config_bypass_gui_hwtcl.VISIBLE" 0
    }
     set cseb_config_bypass_gui_hwtcl [ip_get "parameter.cseb_config_bypass_gui_hwtcl.value"]

   if { $PROP_VALUE == "Avalon-ST with SR-IOV"} {
       ip_set "parameter.cseb_config_bypass_hwtcl.value" 1
   } else {
       ip_set "parameter.cseb_config_bypass_hwtcl.value" $cseb_config_bypass_gui_hwtcl
   }

   if [expr {($design_environment_hwtcl=="NATIVE")}] {
      ip_set "parameter.${PROP_NAME}.allowed_ranges" { "Avalon-ST" "Avalon-ST with SR-IOV"}
   }

   if { $app_interface_width_hwtcl == "64-bit" } {
      set legal_values [list "Avalon-ST" "Avalon-MM"]
      if { $PROP_VALUE == "Avalon-MM with DMA" || $PROP_VALUE == "Avalon-ST with SR-IOV" } {
         send_message error "The current value <b>\"$PROP_VALUE\"</b> for parameter <b>\"$interface_type_hwtcl_display_name\"</b> is invalid under setting <b>Interface Width=\"64-Bit\"</b>."
      }
   } elseif { $app_interface_width_hwtcl=="128-bit" } {
      if {$port_type=="Root port"} {
         set legal_values [list "Avalon-ST" "Avalon-MM" ]
         send_message warning "PRELIMINARY SUPPORT: Interface type <b>\"128-bit Avalon-MM Root Port\"</> is subject to updates."
         if { $PROP_VALUE == "Avalon-MM with DMA" || $PROP_VALUE == "Avalon-ST with SR-IOV" } {
            send_message error "The current value <b>\"$PROP_VALUE\"</b> for parameter <b>\"$interface_type_hwtcl_display_name\"</b> is invalid under setting <b>Port type=\"Root port\"</b>."
         }
      } elseif { $PROP_VALUE == "Avalon-ST with SR-IOV" && $sriov2_en == 1 } {
         set legal_values [list "Avalon-ST" "Avalon-MM" "Avalon-MM with DMA"]
         send_message error "The current value <b>\"$PROP_VALUE\"</b> for parameter <b>\"$interface_type_hwtcl_display_name\"</b> is invalid under setting <b>Interface Width=\"128-Bit\"</b>."
      } else {
         set legal_values [list "Avalon-ST" "Avalon-MM" "Avalon-MM with DMA" "Avalon-ST with SR-IOV"]
      }
   } elseif { $app_interface_width_hwtcl=="256-bit" } {
      if {$port_type=="Root port"} {
         set legal_values [list "Avalon-ST" "Avalon-MM" ]
         if { $PROP_VALUE == "Avalon-MM with DMA" || $PROP_VALUE == "Avalon-ST with SR-IOV" } {
            send_message error "The current value <b>\"$PROP_VALUE\"</b> for parameter <b>\"$interface_type_hwtcl_display_name\"</b> is invalid under setting <b>Port type=\"Root port\"</b>."
         }
         if { $PROP_VALUE == "Avalon-MM" } {
         send_message warning "PRELIMINARY SUPPORT: Interface type <b>\"256-bit Avalon-MM Root Port\"</> is subject to updates."
         }
      } else {
         set legal_values [list "Avalon-ST" "Avalon-MM with DMA" "Avalon-ST with SR-IOV"]
         if { $PROP_VALUE == "Avalon-MM"} {
            send_message error "The current value <b>\"$PROP_VALUE\"</b> for parameter <b>\"$interface_type_hwtcl_display_name\"</b> is invalid under setting <b>Interface Width=\"256-Bit\"</b>."
         }
      }
   } else {
      set legal_values [list "Avalon-ST" "Avalon-MM" "Avalon-MM with DMA" "Avalon-ST with SR-IOV"]
   }
   auto_invalid_value_message auto interface_type_hwtcl $interface_type_hwtcl $legal_values { app_interface_width_hwtcl }
}

