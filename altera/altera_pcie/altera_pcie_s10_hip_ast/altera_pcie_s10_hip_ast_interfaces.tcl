proc ::altera_pcie_s10_hip_ast::interfaces::declare_interfaces {} {
  variable interfaces
  ip_declare_interfaces $interfaces
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate {} {
  ip_elaborate_interfaces
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_avst_interfaces {} {
   set enable_avst_reset_hwtcl            0
   set interface_type_integer_hwtcl       [ip_get "parameter.interface_type_integer_hwtcl.value"]

   if { $interface_type_integer_hwtcl == 0 } {
      set enable_avst_reset_hwtcl   [ip_get "parameter.enable_avst_reset_hwtcl.value"]
   }


   set_interface_property tx_st beatsPerCycle 1
   set_interface_property tx_st dataBitsPerSymbol 256
   set_interface_property tx_st maxChannel 0
   set_interface_property tx_st readyLatency 3
   set_interface_property tx_st symbolsPerBeat 1
   set_interface_property tx_st associatedClock coreclkout_hip

   set_interface_property rx_st beatsPerCycle 1
   set_interface_property rx_st dataBitsPerSymbol 256
   set_interface_property rx_st maxChannel 0
   set_interface_property rx_st readyLatency 3
   set_interface_property rx_st symbolsPerBeat 1
   set_interface_property rx_st associatedClock coreclkout_hip

   if { $enable_avst_reset_hwtcl > 0 } {
      set_interface_property tx_st associatedReset clr_st
      set_interface_property rx_st associatedReset clr_st
   }

}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_clr_st {} {

   set enable_avst_reset_hwtcl 0
   set interface_type_integer_hwtcl       [ip_get "parameter.interface_type_integer_hwtcl.value"]
   if { $interface_type_integer_hwtcl == 0 } {
      set enable_avst_reset_hwtcl   [ ip_get "parameter.enable_avst_reset_hwtcl.value"]
   }

   if { $enable_avst_reset_hwtcl==1  && $interface_type_integer_hwtcl==0 } {
       set_interface_property clr_st associatedClock coreclkout_hip
       set_interface_property clr_st synchronousEdges both
   }
}



proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_hip_port_clks {} {
   set pld_clk_mhz         [ip_get "parameter.pld_clk_mhz_integer_hwtcl.value"]

   set_interface_property coreclkout_hip clockRate [expr {$pld_clk_mhz * 1000000}]
   set_interface_property coreclkout_hip clockRateKnown 1
   set_interface_property refclk         clockRate 100000000
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_hip_reconfig {} {
  set_interface_property hip_reconfig_rst associatedClock hip_reconfig_clk
  set_interface_property hip_reconfig addressAlignment DYNAMIC
  set_interface_property hip_reconfig writeWaitTime 0
  set_interface_property hip_reconfig associatedClock hip_reconfig_clk
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_xcvr_reconfig {} {
  set_interface_property xcvr_reconfig_reset associatedClock xcvr_reconfig_clk
  set_interface_property xcvr_reconfig associatedClock xcvr_reconfig_clk
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_reconfig_pll0 {} {
  set_interface_property reconfig_pll0_reset associatedClock reconfig_pll0_clk
  set_interface_property reconfig_pll0 associatedClock reconfig_pll0_clk
}

proc ::altera_pcie_s10_hip_ast::interfaces::elaborate_reconfig_pll1 {} {
  set_interface_property reconfig_pll1_reset associatedClock reconfig_pll1_clk
  set_interface_property reconfig_pll1 associatedClock reconfig_pll1_clk
}

