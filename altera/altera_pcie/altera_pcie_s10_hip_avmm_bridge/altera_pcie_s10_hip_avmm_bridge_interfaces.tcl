proc ::altera_pcie_s10_hip_avmm_bridge::interfaces::elaborate_hip_port_clks {} {
   set pld_clk_mhz         [ip_get "parameter.pld_clk_mhz_integer_hwtcl.value"]

   set_interface_property coreclkout_hip clockRate [expr {$pld_clk_mhz * 1000000}]
   set_interface_property coreclkout_hip clockRateKnown 1
   set_interface_property refclk         clockRate 100000000
