proc HDL_autogenerated_files_for_encoder {} {

    set m                  [ get_parameter_value BITSPERSYMBOL ]   
    set n                  [ get_parameter_value N ]   
    set check              [ get_parameter_value CHECK ]   
    set irrpol             [ get_parameter_value IRRPOL ]
    set par                [ get_parameter_value PAR ]

    set max_n          [expr (1<<$m)-1]
    set k              [expr $n-$check]
    
    set cwd [pwd]
    
    # send_message warning "m is $m, n is $n, check is $check, par is $par"
    
    
    #----------------------------------------------------------------------------------------------------------------------------
    # evaluate the lagrangian intrpolation coeficients


    # Initialisation of vectors
    set AlphaToThePower                 [list ]
    for {set ii 0} {$ii < [expr $max_n+1]} {incr ii} {
        lappend AlphaToThePower 1
    }
    set ExponentOf                     $AlphaToThePower
    set InverseOf                      $AlphaToThePower


    set generator_polynomial [list ]
    for {set ii 0} {$ii < [expr $check+1]} {incr ii} {
        lappend generator_polynomial  0
    }
    
    
    lset AlphaToThePower       0 1
    for {set ii 1} {$ii < [expr $max_n+1]} {incr ii} {
        set prevAlphato             [lindex $AlphaToThePower [expr $ii-1]]
        if {($prevAlphato>>($m-1))==1} {
            set newAlphato              [expr {($prevAlphato<<1) ^  $irrpol  }]
        } else {
            set newAlphato              [expr ($prevAlphato<<1) ]
        } 
        lset AlphaToThePower      $ii                $newAlphato
        lset ExponentOf           $newAlphato        $ii
    }
    lset InverseOf 0 0
    for {set ii 1} {$ii < [expr $max_n+1]} {incr ii} {
        set inv  [lindex $AlphaToThePower [expr $max_n-[lindex $ExponentOf $ii]]]
        lset InverseOf $ii $inv
    }    


    set  list_of_root [list 1 2]
    set generator_temp $generator_polynomial
    lset generator_polynomial 0 2
    lset generator_polynomial 1 3
    lset generator_polynomial 2 1
    set current_root   2
    for {set ii 3} {$ii < [expr $check+1] } {incr ii} {
        # a a^2 a^3 a^4....
        set current_root [GFmult $current_root 2 $m $irrpol]
        # test set current_root [lindex $AlphaToThePower 1<<($ii-2)]
        lappend list_of_root $current_root

        lset generator_temp 0 0
        for {set jj 1} {$jj < [expr $ii+1]} {incr jj} {
            lset generator_temp $jj [lindex $generator_polynomial [expr $jj-1]]
        }        
        
        for {set jj 0} {$jj < [expr $ii+1]} {incr jj} {
            lset generator_polynomial $jj [expr {[GFmult [expr [lindex $generator_polynomial $jj]] $current_root $m $irrpol] ^ [lindex $generator_temp $jj] }]
        } 
    }

    # send_message warning "generator poly is $generator_polynomial"
    

    # offset coeficient: syndrome computation produce and offset value
    set offset [list ]
    for {set ii 0} {$ii < $check} {incr ii} {
        if {$k%$par==0} {
            lappend offset [lindex $AlphaToThePower [expr ($ii*$check)%$max_n]]
        } else {
            set temp [expr ($max_n+$check-($par-($k%$par)))%$max_n ]
            lappend offset [lindex $AlphaToThePower [expr ($ii*$temp)%$max_n]]
        }
    }
    # send_message warning "offset coef are $offset"
    
    # Finding normalization coeficients: ni = (alpha^i+alpha^j1)(alpha^i+alpha^j2)(alpha^i+alpha^j3)....
    # method with rootspace=1 and rootstart=0

    set norm_coef [list ]
    # set norm_coef0 [list ]
    for {set ii 0} {$ii < $check} {incr ii} {
        set current_root [lindex $AlphaToThePower $ii]

        set temp 1
        for {set jj 0} {$jj < [expr $check-1]} {incr jj} {
            set other_root [lindex $AlphaToThePower [expr ($ii+$jj+1)% $check ]]
            set temp  [GFmult [expr $current_root^$other_root ] $temp $m $irrpol]
        }
        lappend norm_coef [lindex $InverseOf $temp]
        # lappend norm_coef0 $temp
    }

	# send_message warning "norm is $norm_coef"
	
    # Finding lagrangian sub polynomial : L(X) = y1.l1(X) + y2.l2(X) + ...
    set lagrangian_poly_list [list ]
    # set lagrangian_poly_list0 [list ]
    # set lagrangian_poly_list1 [list ]
    for {set ii 0} {$ii < $check} {incr ii} {
        set current_root [lindex $AlphaToThePower $ii]
        set norm [lindex $norm_coef $ii]
        set off  [lindex $offset $ii]

        set poly_temp [list [GFmult $norm $off $m $irrpol]]
        # set poly_temp1 [list $norm]
        # set poly_temp0 [list 1]
        set prev_coef 1
        for {set jj 0} {$jj < $check-1} {incr jj} {
            set coef_temp [expr [lindex $generator_polynomial [expr ($check-1-$jj)]] ^ [GFmult $current_root $prev_coef $m $irrpol]] 
            set prev_coef $coef_temp


            # set poly_temp0 [list {*}$coef_temp {*}$poly_temp0]
            set norm_coef_temp [GFmult $norm $coef_temp $m $irrpol]
            # set poly_temp1 [list {*}$norm_coef_temp {*}$poly_temp1]
            set off_norm_coef_temp [GFmult $off $norm_coef_temp $m $irrpol]
            set poly_temp [list {*}$off_norm_coef_temp {*}$poly_temp]
            
        }

        lappend lagrangian_poly_list $poly_temp
        # lappend lagrangian_poly_list0 $poly_temp0
        # lappend lagrangian_poly_list1 $poly_temp1
    
    }

    
    # send_message warning "L0 is $lagrangian_poly_list0"
    # send_message warning "L1 is $lagrangian_poly_list1"
    # send_message warning "L is $lagrangian_poly_list"

    
    send_message info "----Writing altera_highspeed_rs_enc_lagr_pkg.sv"

    append text     "`timescale 1 ps / 1 ps\n\n";
    append text     "module altera_highspeed_rs_enc_lagr_poly(\n";
    append text     "     lagrange_poly\n";
    append text     ");\n\n";
    append text     "    output \[$check-1:0\]\[$check-1:0\]\[$m-1:0\] lagrange_poly;\n\n";
    append text     "    wire \[$check-1:0\]\[$check-1:0\]\[$m-1:0\] T;\n\n";


    for {set ii 0} {$ii<$check} {incr ii} {
        append text     "    ";
        for {set jj 0} {$jj<$check} {incr jj} {
            set alpha [lindex [lindex $lagrangian_poly_list $ii] $jj]
            append text     "assign T\[$ii\]\[$jj\] = $alpha; ";
        }
        append text     "\n";
        
    }

    append text     "    assign lagrange_poly = T;\n\n";
    append text     "endmodule\n\n\n";

    # List of alpha powers
    append text     "`timescale 1 ps / 1 ps\n\n";
    append text     "module altera_highspeed_rs_enc_alphas(\n";
    append text     "     alphas\n";
    append text     ");\n\n";
    append text     "    output \[$max_n:0\]\[$m-1:0\] alphas;\n\n";
    append text     "    wire \[$max_n:0\]\[$m-1:0\] T;\n\n";


    append text     "    ";
    for {set jj 0} {$jj<$max_n+1} {incr jj} {
            
        set alpha [lindex $AlphaToThePower $jj]
       
        append text     "assign T\[$jj\] = $alpha; ";
        if {(($jj+1)%($max_n/10))==0} {append text     "\n    ";}
    }
    append text     "\n";


    append text     "    assign alphas = T;\n\n";
    append text     "endmodule\n\n\n";
    
    
    
    # append text     "package composite_pkg;\n";
    # append text     "    function int get_composite_polynomial;\n";
    # append text     "        return  [expr $p0 ^ ($p1<<$m_inter)]; \n";
    # append text     "    endfunction\n\n";
    # append text     "    function int get_intermediate_polynomial;\n";
    # append text     "        return  $irrpol_inter; \n";
    # append text     "    endfunction\n";
    # append text     "endpackage : composite_pkg\n";
    

    #----------------------------------------------------------------------------------------------------------------------------
    
    add_fileset_file "altera_highspeed_rs_enc_lagr_pkg.sv" SYSTEM_VERILOG TEXT $text

}




proc GFmult {a b m irrpol} {

    set expand 0
    for {set ii 0} {$ii<$m} {incr ii} {
        if {($b & (1<<$ii))!=0} {set expand [expr {$expand ^($a<<$ii)}]}
    }

    for {set ii 0} {$ii<$m-1} {incr ii} {
        if { [expr {($expand>> (2*$m-2-$ii)) & 1}]!=0} {set expand [expr {$expand ^($irrpol<<($m-2-$ii))}]}
    }

    return $expand
}
