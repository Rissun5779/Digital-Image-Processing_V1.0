package require -exact qsys 14.0
package require altera_hdl_wrapper 1.0

source "../../../lib/altera_hsrs_utilities.tcl"
source "./altera_frac100_rs_enc_utilities.tcl"
source "../../../lib/avalon_streaming_util.tcl"


# |
# +-----------------------------------

# +-----------------------------------
# | module altera_viterbi
# |
set_module_property DESCRIPTION "Altera Fracturable 100G Ethernet Reed-Solomon Encoder"
set_module_property NAME altera_frac100_rs_enc
set_module_property VERSION 18.1
set_module_property INTERNAL true
set_module_property GROUP "DSP/Error Detection and Correction"
set_module_property AUTHOR "Intel Corporation"
set_module_property DISPLAY_NAME "Fracturable 100G Ethernet Reed-Solomon Encoder"
set_module_property INSTANTIATE_IN_SYSTEM_MODULE true
set_module_property EDITABLE false
add_module_parametersFRACMODES
add_module_parametersUSEBKP
set_module_property ELABORATION_CALLBACK elaborate

set_parameter_property design_env HDL_PARAMETER false
add_parameter selected_device_family STRING
set_parameter_property selected_device_family VISIBLE false
set_parameter_property selected_device_family SYSTEM_INFO {DEVICE_FAMILY}

set_parameter_property USE_BKP HDL_PARAMETER true
set_parameter_property TWO_CHANNELS HDL_PARAMETER true
set_parameter_property FOUR_CHANNELS HDL_PARAMETER true

# | 
# +-----------------------------------

# +-----------------------------------
# | files
# | 


add_filesets "altera_frac100_rs_enc"

proc get_simulator_list {} {
    return { \
             {mentor   1   } \
             {aldec    1    } \
             {synopsys 1 } \
             {cadence  1  } \
           }
}

proc generate {type entity} {
    
    HDL_autogenerated_files_for_encoder

    add_encrypted_file $type altera_frac100_rs_enc_pkg.sv
    add_encrypted_file $type altera_frac100_rs_enc.sv
    add_encrypted_file $type altera_frac100_rs_enc_syndrome.sv
    add_encrypted_file $type altera_frac100_rs_enc_interpolation.sv
    
}





# +-----------------------------------
# | Callbacks
# | 
proc elaborate {} {
    set bits_per_symbol     10   
    set par                 8
    set channel             4
    set use_backpressure    [ get_parameter_value USE_BKP ]

    
    set symbol_size    [ expr $bits_per_symbol*$par*$channel]
    
    set nb_modes        [ expr 1 +  [ get_parameter_value TWO_CHANNELS] + [ get_parameter_value FOUR_CHANNELS]]
    if {$nb_modes==3} {
        set mode_width      2
    } elseif {$nb_modes==2} {
       set mode_width       1
    } else {
       set mode_width       0
    }

    set in_datawidth    [expr $symbol_size + $mode_width]
    set out_datawidth   [expr $symbol_size + $mode_width]
    
    send_message warning "in_datawidth is $in_datawidth, use_backpressure is $use_backpressure"
    
    add_interface end_ports conduit end
    set_interface_property end_ports ENABLED false

    # +-----------------------------------
    # | Elaborate sink interface (sch_in)
    # +-----------------------------------
    
    dsp_add_streaming_interface in sink
    set_interface_property in ENABLED true
    set_interface_property in associatedClock clk
    set_interface_property in associatedReset rst
    dsp_set_interface_property in readyLatency 0
    dsp_set_interface_property in dataBitsPerSymbol $in_datawidth
 
    add_interface_port in ready_in   ready Output 1    
    add_interface_port in valid_in   valid Input 1
    
    add_interface_port in sop_in     startofpacket Input 1    
    add_interface_port in eop_in     endofpacket Input 1    
    
    set fraglist_in          [list ]   
    set fraglist_in_display  [list ]
            
    if {$nb_modes>1} {
        lappend fraglist_in  mode_in $mode_width
        lappend fraglist_in_display mode_in\[[expr $mode_width-1]:0\]
    } else {
        add_interface_port end_ports mode_in   export Input 1
        set_port_property mode_in termination_value 0
        set_port_property mode_in VHDL_TYPE STD_LOGIC_VECTOR
    }
    
    lappend fraglist_in  symbols_in  $symbol_size
    lappend fraglist_in_display symbols_in\[[expr $symbol_size-1]:0\]
    
    dsp_add_interface_port in in_data data Input $in_datawidth $fraglist_in
    send_message note "in_data = \{$fraglist_in_display\}"

    # +-----------------------------------
    # | Elaborate sink interface (cw_out)
    # +-----------------------------------
    dsp_add_streaming_interface out source
    set_interface_property out ENABLED true
    set_interface_property out associatedClock clk
    set_interface_property out associatedReset rst
    dsp_set_interface_property out readyLatency 0
    dsp_set_interface_property out dataBitsPerSymbol $out_datawidth

    add_interface_port out ready_out ready Input 1
    

    if {$use_backpressure==0} {
        set_port_property ready_out termination true
        set_port_property ready_out termination_value 1
    }
    
    add_interface_port out valid_out valid Output 1
    add_interface_port out sop_out  startofpacket Output 1
    add_interface_port out eop_out  endofpacket Output 1
    
    set fraglist_out       [list ]
    set fraglist_out_display       [list ]
    
    if {$nb_modes>1} {
        lappend fraglist_out  mode_out $mode_width
        lappend fraglist_out_display mode_out\[[expr $mode_width-1]:0\]
    } else {
        add_interface_port end_ports mode_out   export Output 1
        set_port_property mode_out termination_value 0
        set_port_property mode_out VHDL_TYPE STD_LOGIC_VECTOR
    }
    
    lappend fraglist_out symbols_out $symbol_size
    lappend fraglist_out_display symbols_out\[[expr $symbol_size-1]:0\]
    dsp_add_interface_port out out_data data Output $out_datawidth $fraglist_out
    send_message note "out_data = \{$fraglist_out_display\}"
}


# +-----------------------------------
# | connection point clock
# | 
add_interface clk clock end
set_interface_property clk ENABLED true
add_interface_port clk clk clk Input 1
# | 
# +-----------------------------------

# +-----------------------------------
# | connection point reset
# | 
add_interface rst reset end
set_interface_property rst ENABLED true
set_interface_property rst associatedClock clk
add_interface_port rst rst reset Input 1
# | 
