# +-----------------------------------
# | files
# | 


add_filesets "rsx_decoder"

proc get_simulator_list {} {
    return { \
             {mentor   1   } \
             {aldec    1    } \
             {synopsys 1 } \
             {cadence  1  } \
           }
}

proc generate {type entity} {

    
    set list_of_generated_files [HDL_autogenerated_files_for_decoder $entity]

    set dir_list [list ./ ]
    set dir_list_gen [file dirname [lindex $list_of_generated_files 0] ]
    add_file_list  $type  ${dir_list_gen}/rsx_parameters_auto.vhd
     add_file_list  $type  ${dir_list}/rsx_functions.vhd 1
     add_file_list  $type  ${dir_list}/rsx_package.vhd 1
    # add_file_list  $type  ${dir_list}/rsx_functions.vhd 0
    # add_file_list  $type  ${dir_list}/rsx_package.vhd 0
     add_file_list  $type  ${dir_list_gen}/rsx_roots_auto.vhd
     add_file_list  $type  ${dir_list_gen}/rsx_bm_auto.vhd
    if {[ get_parameter_value USERAM]} {
        add_file_list  $type  ${dir_list}/rsx_inverse_ROM_bkp.vhd 1
      # add_file_list  $type  ${dir_list}/rsx_inverse_ROM_bkp.vhd 0
    }
    add_file_list  $type  ${dir_list_gen}/rsx_inverse_ROM_auto.vhd

    set list_of_files [list]
    set file_list  [get_file_list  $dir_list {*.vhd} {*_auto.vhd *rsx_package.vhd *rsx_functions.vhd *_bkp.vhd} ]  
    foreach thatfile $file_list {
        lappend list_of_files  $thatfile
    }   

     add_file_list  $type $list_of_files 1
    # add_file_list  $type $list_of_files 0
    
}





# +-----------------------------------
# | Callbacks
# | 
proc elaborate {} {
    set bits_per_symbol     10   
    set par                 8
    set check               14
    set channel             4
    set use_backpressure    [ get_parameter_value USE_BKP ]

    set use_decfail         [ get_parameter_value USE_DECFAIL ]
    set use_nberror         [ get_parameter_value USE_NBERROR ]
    set use_sopeop          [ get_parameter_value USE_SOPEOP ]
    
    set error_symbols  [ expr int($check/2) ]
    set error_size     [ expr int(ceil(log($error_symbols+1) / log(2)))*$channel ]
    set symbol_size    [ expr $bits_per_symbol*$par*$channel]
    set decfail_size   $channel
    
    set nb_modes        [ expr 1 +  [ get_parameter_value TWO_CHANNELS] + [ get_parameter_value FOUR_CHANNELS]]
    if {$nb_modes==3} {
        set mode_width      2
    } elseif {$nb_modes==2} {
       set mode_width       1
    } else {
       set mode_width       0
    }

    set in_datawidth    [expr $symbol_size + $channel + $mode_width + 1]
    set out_datawidth   [expr $symbol_size + $channel + $mode_width + $error_size*$use_nberror + $decfail_size*$use_decfail + 8*$use_sopeop]
    
    add_interface end_ports conduit end
    set_interface_property end_ports ENABLED false

    # +-----------------------------------
    # | Elaborate sink interface (sch_in)
    # +-----------------------------------
    
    dsp_add_streaming_interface in sink
    set_interface_property in ENABLED true
    set_interface_property in associatedClock clk
    set_interface_property in associatedReset rst
    dsp_set_interface_property in readyLatency 0
    dsp_set_interface_property in dataBitsPerSymbol $in_datawidth

    # add_interface_port in sop_in     startofpacket Input $channel   
    # add_interface_port in eop_in     endofpacket Input $channel    
    if {$use_backpressure==1} {
        add_interface_port in ready_in   ready Output 1    
    }
    add_interface_port in valid_in   valid Input 1
    
    set fraglist_in          [list ]   
    set fraglist_in_display  [list ]
    
    lappend fraglist_in  sync_in 1
    lappend fraglist_in_display sync_in\[0:0\]
    if {$nb_modes>1} {
        lappend fraglist_in  mode_in $mode_width
        lappend fraglist_in_display mode_in\[[expr $mode_width-1]:0\]
    }
    lappend fraglist_in  valid_ch_in $channel
    lappend fraglist_in_display valid_ch_in\[[expr $channel-1]:0\]
    
    lappend fraglist_in  symbols_in  $symbol_size
    lappend fraglist_in_display symbols_in\[[expr $symbol_size-1]:0\]
    dsp_add_interface_port in in_data data Input $in_datawidth $fraglist_in
    send_message note "in_data = \{$fraglist_in_display\}"

    # +-----------------------------------
    # | Elaborate sink interface (cw_out)
    # +-----------------------------------
    dsp_add_streaming_interface out source
    set_interface_property out ENABLED true
    set_interface_property out associatedClock clk
    set_interface_property out associatedReset rst
    dsp_set_interface_property out readyLatency 0
    dsp_set_interface_property out dataBitsPerSymbol $out_datawidth

    add_interface_port out enable ready Input 1

    if {$use_backpressure==0} {
        set_port_property enable termination true
        set_port_property enable termination_value 1
    } else {
        set_port_property enable termination false
    }
    
    add_interface_port out valid_out valid Output 1
    set fraglist_out       [list ]
    set fraglist_out_display       [list ]
    if {$use_nberror} {
        lappend fraglist_out  errors_out $error_size
        lappend fraglist_out_display errors_out\[[expr $error_size-1]:0\]
    } 
    if {$use_decfail} {
        lappend fraglist_out  decfail $decfail_size
        lappend fraglist_out_display decfail\[[expr $decfail_size-1]:0\]
    }    
    
    if {$use_sopeop} {
        lappend fraglist_out  eop_out $channel
        lappend fraglist_out_display eop_out\[[expr $channel-1]:0\]    
        lappend fraglist_out  sop_out $channel
        lappend fraglist_out_display sop_out\[[expr $channel-1]:0\]
    }
    
    if {$nb_modes>1} {
        lappend fraglist_out  mode_out $mode_width
        lappend fraglist_out_display mode_out\[[expr $mode_width-1]:0\]
    }
    lappend fraglist_out  valid_ch_out $channel
    lappend fraglist_out_display valid_ch_out\[[expr $channel-1]:0\]
    
    lappend fraglist_out symbols_out $symbol_size
    lappend fraglist_out_display symbols_out\[[expr $symbol_size-1]:0\]
    dsp_add_interface_port out out_data data Output $out_datawidth $fraglist_out
    send_message note "out_data = \{$fraglist_out_display\}"
}


