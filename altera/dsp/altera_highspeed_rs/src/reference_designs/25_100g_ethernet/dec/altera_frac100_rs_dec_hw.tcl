set_module_property DESCRIPTION "Altera Fracturable 100G Ethernet Reed-Solomon Decoder"
set_module_property NAME altera_frac100_rs_dec
set_module_property VERSION 18.1
set_module_property INTERNAL true
set_module_property GROUP "DSP/Error Detection and Correction"
set_module_property AUTHOR "Intel Corporation"
set_module_property DISPLAY_NAME "Fracturable 100G Ethernet Reed-Solomon Decoder"
set_module_property INSTANTIATE_IN_SYSTEM_MODULE true
set_module_property EDITABLE false
add_module_parametersDEC_FRAC421
set_module_property ELABORATION_CALLBACK elaborate

set_parameter_property design_env HDL_PARAMETER false
add_parameter selected_device_family STRING
set_parameter_property selected_device_family VISIBLE false
set_parameter_property selected_device_family SYSTEM_INFO {DEVICE_FAMILY}

set_parameter_property PAR HDL_PARAMETER false
set_parameter_property BMSPEED HDL_PARAMETER false
set_parameter_property USERAM HDL_PARAMETER false
set_parameter_property USEECCFORRAM HDL_PARAMETER false
set_parameter_property USETRUEDUALRAM HDL_PARAMETER false
set_parameter_property USE_BKP HDL_PARAMETER false


