 <interface name="clk" internal="clk_0.clk_in" type="clock" dir="end" />
 <interface
   name="clk_0_clk_in_reset"
   internal="clk_0.clk_in_reset"
   type="reset"
   dir="end" />
 <interface
   name="master_0_master"
   internal="master_0.master"
   type="avalon"
   dir="start" />
 <interface
   name="master_0_master_reset"
   internal="master_0.master_reset"
   type="reset"
   dir="start" />
 <module name="clk_0" kind="clock_source" version="16.0" enabled="1">
  <parameter name="clockFrequency" value="50000000" />
  <parameter name="clockFrequencyKnown" value="true" />
  <parameter name="inputClockFrequency" value="0" />
  <parameter name="resetSynchronousEdges" value="NONE" />
 </module>
 <module
   name="master_0"
   kind="altera_jtag_avalon_master"
   version="16.0"
   enabled="1">
  <parameter name="AUTO_DEVICE" value="10AX115S3F45I2SG" />
